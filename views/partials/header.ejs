<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title ? title : 'MozAic' %></title>
  <meta name="description" content="MozAic" />

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Bootstrap & Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css">

  
  <%
    // Page-specific styles (if provided), else fall back to the default
    let styles = [];
    if (typeof pageStyles !== 'undefined' && pageStyles) {
      // allow string or array
      styles = Array.isArray(pageStyles) ? pageStyles : [pageStyles];
    } else {
      // Default style if not specified
      styles = ['/css/style.css'];
    }
    
    styles.forEach(function(href) {
      %>
      <link rel="stylesheet" href="<%= href %>">
      <%
    });
  %>
</head>
<body<%= bodyClass ? ' class="' + bodyClass + '"' : '' %>>

<%
  // Flash messages from session (will be passed from server)
  const flashes = typeof flashMessages !== 'undefined' ? flashMessages : [];
%>