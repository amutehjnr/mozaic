  </div>
</nav>

<header id="header">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-8">
        <h1 class="fw-bold mb-2">Verify Your Identity</h1>
        <p class="lead mb-0 opacity-75">Complete KYC to increase your transaction limits</p>
      </div>
      <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <span class="badge bg-white text-dark px-3 py-2">
          <i class="bi bi-shield-check me-1 text-success"></i>
          Status: <span class="badge-soft <%= getStatusBadge(kyc.status) %>"><%= getStatusText(kyc.status) %></span>
        </span>
      </div>
    </div>
  </div>
</header>

<main class="section py-4">
  <div class="container">
    
    <!-- Flash Messages -->
    <% if (flash.success) { %>
      <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <%= flash.success %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
    
    <% if (flash.error) { %>
      <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <%= flash.error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Rejection Reason (if rejected) -->
    <% if (kyc.status === 'rejected' && kyc.rejection_reason) { %>
      <div class="alert alert-danger mb-4">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Verification Failed:</strong> <%= kyc.rejection_reason %>
        <p class="small mt-2 mb-0">Please correct the issues above and resubmit.</p>
      </div>
    <% } %>

    <!-- Progress Steps -->
    <div class="progress-steps mb-4">
      <div class="step <%= kyc.first_name && kyc.last_name ? 'completed' : (kyc.status !== 'not_started' ? 'active' : '') %>">
        <%= kyc.first_name && kyc.last_name ? '✓' : '1' %>
      </div>
      <div class="step <%= kyc.id_front_path ? 'completed' : (kyc.status === 'pending' || kyc.status === 'verified' ? 'active' : '') %>">
        <%= kyc.id_front_path ? '✓' : '2' %>
      </div>
      <div class="step <%= kyc.status === 'verified' ? 'completed' : (kyc.status === 'pending' ? 'active' : '') %>">
        <%= kyc.status === 'verified' ? '✓' : '3' %>
      </div>
    </div>

    <!-- Current Status Banner (for pending/verified) -->
    <% if (kyc.status === 'pending') { %>
      <div class="status-banner">
        <div class="d-flex align-items-center gap-3">
          <i class="bi bi-hourglass-split fs-1"></i>
          <div>
            <h4 class="fw-bold mb-1">Verification in Progress</h4>
            <p class="mb-0 opacity-75">Your documents are being reviewed. This usually takes 5-30 minutes.</p>
          </div>
        </div>
      </div>
    <% } %>

    <% if (kyc.status === 'verified') { %>
      <div class="status-banner" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
        <div class="d-flex align-items-center gap-3">
          <i class="bi bi-patch-check-fill fs-1"></i>
          <div>
            <h4 class="fw-bold mb-1">Verification Complete! 🎉</h4>
            <p class="mb-0 opacity-75">Your identity has been verified. You now have higher transaction limits.</p>
          </div>
        </div>
      </div>
    <% } %>

    <div class="row g-4">
      <!-- Left Column - Personal Details -->
      <div class="col-lg-6">
        <div class="card p-4 h-100">
          <div class="d-flex align-items-center gap-2 mb-4">
            <div class="step completed" style="width: 30px; height: 30px; font-size: 0.9rem;">1</div>
            <h5 class="fw-bold mb-0">Personal Information</h5>
          </div>
          
          <form class="row g-3 needs-validation" method="POST" action="/api/kyc/personal" id="personalForm" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="col-md-6">
              <label class="form-label fw-semibold">First name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="first_name" value="<%= kyc.first_name ? kyc.first_name : '' %>" required>
              <div class="invalid-feedback">Please enter your first name</div>
            </div>
            
            <div class="col-md-6">
              <label class="form-label fw-semibold">Last name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="last_name" value="<%= kyc.last_name ? kyc.last_name : '' %>" required>
              <div class="invalid-feedback">Please enter your last name</div>
            </div>
            
            <div class="col-md-6">
              <label class="form-label fw-semibold">Date of birth <span class="text-danger">*</span></label>
              <input type="date" class="form-control" name="dob" value="<%= formatDateForInput(kyc.dob) %>" 
                     max="<%= new Date().toISOString().split('T')[0] %>" required>
              <div class="invalid-feedback">Please enter your date of birth</div>
            </div>
            
            <div class="col-md-6">
              <label class="form-label fw-semibold">BVN (optional)</label>
              <input type="text" class="form-control" name="bvn" value="<%= kyc.bvn ? kyc.bvn : '' %>" 
                     pattern="[0-9]{11}" maxlength="11" placeholder="11-digit BVN">
              <small class="text-muted">11-digit Bank Verification Number</small>
            </div>
            
            <div class="col-12">
              <label class="form-label fw-semibold">Address <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="address" value="<%= kyc.address ? kyc.address : '' %>" 
                     placeholder="Your residential address" required>
              <div class="invalid-feedback">Please enter your address</div>
            </div>

            <div class="col-12">
              <button class="btn btn-theme" type="submit" id="savePersonalBtn">
                <i class="bi bi-check-lg me-1"></i> Save Personal Details
              </button>
            </div>
          </form>
        </div>
      </div>

      <!-- Right Column - Document Upload -->
      <div class="col-lg-6">
        <div class="card p-4 h-100">
          <div class="d-flex align-items-center gap-2 mb-4">
            <div class="step <%= kyc.id_front_path ? 'completed' : '' %>" style="width: 30px; height: 30px; font-size: 0.9rem;">2</div>
            <h5 class="fw-bold mb-0">Document Upload</h5>
          </div>
          
          <form class="row g-3 needs-validation" method="POST" action="/api/kyc/documents" enctype="multipart/form-data" id="documentsForm" novalidate>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <div class="col-12">
              <label class="form-label fw-semibold">ID Type <span class="text-danger">*</span></label>
              <select class="form-select" name="id_type" required id="idType">
                <option value="">Select ID type...</option>
                <% idTypeOptions.forEach(opt => { %>
                  <option value="<%= opt %>" <%= (kyc.id_type === opt ? 'selected' : '') %>><%= opt %></option>
                <% }); %>
              </select>
              <div class="invalid-feedback">Please select an ID type</div>
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold">ID Number <span class="text-danger">*</span></label>
              <input type="text" class="form-control" name="id_number" value="<%= kyc.id_number ? kyc.id_number : '' %>" 
                     placeholder="Enter your ID number" required>
              <div class="invalid-feedback">Please enter your ID number</div>
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold">Front of ID <span class="text-danger">*</span></label>
              <div class="file-upload-area" id="frontUploadArea" onclick="document.getElementById('id_front').click()">
                <i class="bi bi-cloud-upload fs-1 text-muted"></i>
                <p class="mb-1">Click to upload or drag and drop</p>
                <small class="text-muted">JPG, PNG or PDF (max 5MB)</small>
                <input type="file" class="d-none" name="id_front" id="id_front" accept=".jpg,.jpeg,.png,.pdf" 
                       <%= !kyc.id_front_path ? 'required' : '' %>>
              </div>
              <div id="frontPreview" class="file-preview" style="<%= !kyc.id_front_path ? 'display: none;' : '' %>">
                <i class="bi bi-file-earmark-check text-success fs-4"></i>
                <div class="flex-grow-1">
                  <div class="small fw-semibold">Front of ID</div>
                  <small class="text-muted" id="frontFileName"><%= kyc.id_front_path ? 'Uploaded' : '' %></small>
                </div>
                <% if (kyc.id_front_path) { %>
                  <a href="<%= kyc.id_front_path %>" target="_blank" class="btn btn-sm btn-outline-primary">View</a>
                <% } %>
              </div>
              <div class="invalid-feedback">Please upload the front of your ID</div>
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold">Back of ID <span class="text-danger">*</span></label>
              <div class="file-upload-area" id="backUploadArea" onclick="document.getElementById('id_back').click()">
                <i class="bi bi-cloud-upload fs-1 text-muted"></i>
                <p class="mb-1">Click to upload or drag and drop</p>
                <small class="text-muted">JPG, PNG or PDF (max 5MB)</small>
                <input type="file" class="d-none" name="id_back" id="id_back" accept=".jpg,.jpeg,.png,.pdf"
                       <%= !kyc.id_back_path ? 'required' : '' %>>
              </div>
              <div id="backPreview" class="file-preview" style="<%= !kyc.id_back_path ? 'display: none;' : '' %>">
                <i class="bi bi-file-earmark-check text-success fs-4"></i>
                <div class="flex-grow-1">
                  <div class="small fw-semibold">Back of ID</div>
                  <small class="text-muted" id="backFileName"><%= kyc.id_back_path ? 'Uploaded' : '' %></small>
                </div>
                <% if (kyc.id_back_path) { %>
                  <a href="<%= kyc.id_back_path %>" target="_blank" class="btn btn-sm btn-outline-primary">View</a>
                <% } %>
              </div>
              <div class="invalid-feedback">Please upload the back of your ID</div>
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold">Selfie with ID (optional)</label>
              <div class="file-upload-area" onclick="document.getElementById('selfie').click()">
                <i class="bi bi-cloud-upload fs-1 text-muted"></i>
                <p class="mb-1">Click to upload or drag and drop</p>
                <small class="text-muted">JPG or PNG (max 5MB)</small>
                <input type="file" class="d-none" name="selfie" id="selfie" accept=".jpg,.jpeg,.png">
              </div>
            </div>

            <div class="col-12 mt-4">
              <button class="btn btn-theme w-100" type="button" id="submitKycBtn" 
                      <%= (!kyc.first_name || !kyc.last_name) ? 'disabled' : '' %>>
                <i class="bi bi-send me-1"></i> Submit for Verification
              </button>
            </div>
            
            <div class="col-12">
              <div class="alert alert-info mb-0">
                <i class="bi bi-info-circle me-2"></i>
                <small>Your documents are secure and encrypted. We'll notify you once verification is complete.</small>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Tier Information -->
    <div class="row mt-4">
      <div class="col-12">
        <div class="card p-4">
          <h5 class="fw-bold mb-3">
            <i class="bi bi-bar-chart-steps me-2 text-primary"></i>
            Account Tiers & Limits
          </h5>
          
          <div class="row g-3">
            <div class="col-md-4">
              <div class="tier-card <%= kyc.tier === 'tier1' ? 'active' : '' %>">
                <div class="tier-name">🥉 Tier 1</div>
                <div class="tier-limit">Daily: ₦50,000</div>
                <div class="tier-limit">Monthly: ₦500,000</div>
                <div class="tier-limit mt-2">No KYC required</div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="tier-card <%= kyc.tier === 'tier2' ? 'active' : '' %>">
                <div class="tier-name">🥈 Tier 2</div>
                <div class="tier-limit">Daily: ₦200,000</div>
                <div class="tier-limit">Monthly: ₦2,000,000</div>
                <div class="tier-limit mt-2">Basic KYC required</div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="tier-card <%= kyc.tier === 'tier3' ? 'active' : '' %>">
                <div class="tier-name">🥇 Tier 3</div>
                <div class="tier-limit">Daily: ₦1,000,000</div>
                <div class="tier-limit">Monthly: ₦10,000,000</div>
                <div class="tier-limit mt-2">Full KYC required</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
(function() {
    'use strict';

    // Toast function
    function showToast(message, type = 'success') {
        const container = document.querySelector('.toast-container');
        const toastId = 'toast-' + Date.now();
        
        const bgColor = {
            'success': 'text-bg-success',
            'error': 'text-bg-danger',
            'warning': 'text-bg-warning',
            'info': 'text-bg-info'
        }[type] || 'text-bg-success';
        
        const icon = {
            'success': 'bi-check-circle-fill',
            'error': 'bi-exclamation-triangle-fill',
            'warning': 'bi-exclamation-circle-fill',
            'info': 'bi-info-circle-fill'
        }[type] || 'bi-bell-fill';
        
        const toastHtml = `
            <div id="${toastId}" class="toast align-items-center ${bgColor} border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi ${icon}"></i>
                        <span>${escapeHtml(message)}</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        `;
        
        container.insertAdjacentHTML('beforeend', toastHtml);
        
        const toastElement = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastElement, { autohide: true, delay: 5000 });
        toast.show();
        
        toastElement.addEventListener('hidden.bs.toast', () => toastElement.remove());
    }

    function escapeHtml(s) {
        if (!s) return '';
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    // File upload preview
    function setupFileUpload(inputId, previewId, fileNameId, areaId) {
        const input = document.getElementById(inputId);
        const preview = document.getElementById(previewId);
        const fileName = document.getElementById(fileNameId);
        const area = document.getElementById(areaId);

        if (!input) return;

        input.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const file = this.files[0];
                fileName.textContent = file.name;
                preview.style.display = 'flex';
                area.classList.add('has-file');
                
                // Validate file size
                if (file.size > 5 * 1024 * 1024) {
                    showToast('File size must be less than 5MB', 'error');
                    this.value = '';
                    preview.style.display = 'none';
                    area.classList.remove('has-file');
                }
            }
        });
    }

    // Setup file upload previews
    setupFileUpload('id_front', 'frontPreview', 'frontFileName', 'frontUploadArea');
    setupFileUpload('id_back', 'backPreview', 'backFileName', 'backUploadArea');
    setupFileUpload('selfie', 'selfiePreview', 'selfieFileName', 'selfieUploadArea');

    // Personal form submission
    const personalForm = document.getElementById('personalForm');
    if (personalForm) {
        personalForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (!personalForm.checkValidity()) {
                personalForm.classList.add('was-validated');
                return;
            }
            
            const btn = document.getElementById('savePersonalBtn');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Saving...';
            
            try {
                const formData = new FormData(personalForm);
                const response = await fetch(personalForm.action, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin'
                });
                
                const data = await response.json();
                
                if (!response.ok || data.error) {
                    throw new Error(data.error || 'Failed to save');
                }
                
                showToast('Personal details saved!', 'success');
                
                // Enable submit button if both forms are complete
                checkCompletion();
                
            } catch (error) {
                console.error('Save error:', error);
                showToast(error.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });
    }

    // Documents form submission
    const documentsForm = document.getElementById('documentsForm');
    if (documentsForm) {
        documentsForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (!documentsForm.checkValidity()) {
                documentsForm.classList.add('was-validated');
                return;
            }
            
            const btn = documentsForm.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Uploading...';
            
            try {
                const formData = new FormData(documentsForm);
                const response = await fetch(documentsForm.action, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin'
                });
                
                const data = await response.json();
                
                if (!response.ok || data.error) {
                    throw new Error(data.error || 'Upload failed');
                }
                
                showToast('Documents uploaded! You can now submit for verification.', 'success');
                
                // Enable submit button
                document.getElementById('submitKycBtn').disabled = false;
                
            } catch (error) {
                console.error('Upload error:', error);
                showToast(error.message, 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });
    }

    // Submit KYC
    document.getElementById('submitKycBtn')?.addEventListener('click', async () => {
        const btn = document.getElementById('submitKycBtn');
        const originalText = btn.innerHTML;
        
        if (!confirm('Are you sure you want to submit your KYC for verification? You cannot edit after submission.')) {
            return;
        }
        
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Submitting...';
        
        try {
            const response = await fetch('/api/kyc/submit', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '<%= csrfToken %>'
                },
                credentials: 'same-origin'
            });
            
            const data = await response.json();
            
            if (!response.ok || data.error) {
                throw new Error(data.error || 'Submission failed');
            }
            
            showToast('KYC submitted successfully!', 'success');
            
            // Redirect to refresh page
            setTimeout(() => {
                window.location.reload();
            }, 2000);
            
        } catch (error) {
            console.error('Submit error:', error);
            showToast(error.message, 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    });

    // Check if personal details are complete to enable document upload
    function checkCompletion() {
        const firstName = document.querySelector('[name="first_name"]').value;
        const lastName = document.querySelector('[name="last_name"]').value;
        const dob = document.querySelector('[name="dob"]').value;
        const address = document.querySelector('[name="address"]').value;
        
        const submitBtn = document.getElementById('submitKycBtn');
        
        if (firstName && lastName && dob && address) {
            submitBtn.disabled = false;
        }
    }

    // Check initial completion
    checkCompletion();

    // Auto-save on field blur
    document.querySelectorAll('#personalForm input').forEach(input => {
        input.addEventListener('blur', () => {
            if (input.value.trim()) {
                // Could implement auto-save here
            }
        });
    });
})();
</script>

