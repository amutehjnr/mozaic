<%
const user = typeof userData !== 'undefined' ? userData : { id: 0, name: '', email: '', referral_code: '' };
const referrals = typeof referralsData !== 'undefined' ? referralsData : [];
const totalClicks = typeof clicksData !== 'undefined' ? clicksData : 0;

// Calculate totals
let totalRewards = 0;
let activeCount = 0;
let pendingCount = 0;
let convertedCount = 0;

referrals.forEach(r => {
    if (r.reward > 0) totalRewards += r.reward;
    if (r.status === 'Active') activeCount++;
    if (r.status === 'Pending') pendingCount++;
    if (r.status === 'Converted') convertedCount++;
});

// Calculate conversion rate
const conversion = totalClicks ? Math.round((referrals.length / totalClicks) * 100) : 0;
const clickConversion = totalClicks ? Math.round((referrals.length / totalClicks) * 100) : 0;

// Determine tier based on active referrals
let tier = 'Bronze';
let nextAt = 10;
let base = 0;
let tierReward = 150;

if (activeCount >= 10 && activeCount < 30) { 
    tier = 'Silver'; 
    nextAt = 30; 
    base = 10;
    tierReward = 250;
} else if (activeCount >= 30 && activeCount < 100) { 
    tier = 'Gold'; 
    nextAt = 100; 
    base = 30;
    tierReward = 400;
} else if (activeCount >= 100) { 
    tier = 'Platinum'; 
    nextAt = activeCount; 
    base = 100;
    tierReward = 600;
}

const progress = Math.max(0, Math.min(100, Math.round(((activeCount - base) / Math.max(1, (nextAt - base))) * 100)));

// Format helpers
const formatNaira = (amount) => '₦' + Number(amount).toLocaleString('en-NG', { minimumFractionDigits: 0 });
const formatDate = (dateStr) => {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return dateStr;
    return date.toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
};

// Prepare export data
const exportData = referrals.map(r => ({
    name: r.name || r.email || '—',
    joined: r.joined ? formatDate(r.joined) : '',
    status: r.status || 'Pending',
    reward: r.reward || 0,
    email: r.email || ''
}));

// Sort by joined date (newest first)
exportData.sort((a, b) => (b.joined || '').localeCompare(a.joined || ''));

// Referral link
const refLink = `${baseUrl}/r/${user.referral_code}`;
%>
