<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
// Data from server
const invited = <%- JSON.stringify(exportData) %>;
const clicks = <%= totalClicks %>;
const rows = document.getElementById('rows');
let currentPage = 1;
const itemsPerPage = 10;

// Helper functions
function showToast(message, type = 'success') {
    const container = document.querySelector('.toast-container');
    const toastId = 'toast-' + Date.now();
    
    const bgColor = {
        'success': 'text-bg-success',
        'error': 'text-bg-danger',
        'warning': 'text-bg-warning',
        'info': 'text-bg-info'
    }[type] || 'text-bg-success';
    
    const icon = {
        'success': 'bi-check-circle-fill',
        'error': 'bi-exclamation-triangle-fill',
        'warning': 'bi-exclamation-circle-fill',
        'info': 'bi-info-circle-fill'
    }[type] || 'bi-bell-fill';
    
    const toastHtml = `
        <div id="${toastId}" class="toast align-items-center ${bgColor} border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <i class="bi ${icon}"></i>
                    <span>${escapeHtml(message)}</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    `;
    
    container.insertAdjacentHTML('beforeend', toastHtml);
    
    const toastElement = document.getElementById(toastId);
    const toast = new bootstrap.Toast(toastElement, { autohide: true, delay: 5000 });
    toast.show();
    
    toastElement.addEventListener('hidden.bs.toast', () => toastElement.remove());
}

function escapeHtml(s) {
    if (!s) return '';
    return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

function formatNaira(n) {
    return '₦' + Number(n).toLocaleString('en-NG', { minimumFractionDigits: 0 });
}

function getStatusBadge(status) {
    const badges = {
        'Active': 'badge-soft-success',
        'Pending': 'badge-soft-warning',
        'Converted': 'badge-soft-info',
        'Clicked': 'badge-soft-secondary',
        'Signed Up': 'badge-soft-primary'
    };
    const badgeClass = badges[status] || 'badge-soft-secondary';
    return `<span class="badge-soft ${badgeClass}">${status || 'Pending'}</span>`;
}

function renderTable() {
    rows.innerHTML = '';
    
    if (invited.length === 0) {
        rows.innerHTML = `
            <tr>
                <td colspan="5" class="text-center py-5">
                    <i class="bi bi-people fs-1 text-muted d-block mb-3"></i>
                    <h6 class="text-muted">No referrals yet</h6>
                    <p class="small text-muted mb-3">Share your referral link to start earning</p>
                    <button class="btn btn-sm btn-theme" onclick="shareReferral()">
                        <i class="bi bi-share me-1"></i> Share Now
                    </button>
                </td>
            </tr>
        `;
        return;
    }
    
    invited.forEach(r => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>
                <div class="fw-semibold">${escapeHtml(r.name)}</div>
                <small class="text-muted">${r.email || ''}</small>
            </td>
            <td><small>${r.joined || '—'}</small></td>
            <td>${getStatusBadge(r.status)}</td>
            <td class="text-end ${r.reward > 0 ? 'text-success fw-bold' : 'text-muted'}">
                ${r.reward > 0 ? formatNaira(r.reward) : '—'}
            </td>
            <td class="text-center">
                <button class="btn btn-sm btn-outline-primary" onclick="remindFriend('${escapeHtml(r.email)}')" ${!r.email ? 'disabled' : ''}>
                    <i class="bi bi-envelope"></i>
                </button>
            </td>
        `;
        rows.appendChild(tr);
    });
}

// Copy referral link
document.getElementById('copyBtn').addEventListener('click', async () => {
    const input = document.getElementById('refLink');
    try {
        await navigator.clipboard.writeText(input.value);
        const btn = document.getElementById('copyBtn');
        btn.innerHTML = '<i class="bi bi-check-lg"></i>';
        showToast('Link copied to clipboard!', 'success');
        setTimeout(() => btn.innerHTML = '<i class="bi bi-clipboard"></i>', 1500);
    } catch (e) {
        input.select();
        document.execCommand('copy');
        showToast('Link copied!', 'success');
    }
});

// Share referral
function shareReferral() {
    if (navigator.share) {
        navigator.share({
            title: 'Join MozAic',
            text: 'Join me on MozAic for affordable data, airtime & bills!',
            url: document.getElementById('refLink').value
        }).catch(() => {});
    } else {
        showToast('Click a social media button to share', 'info');
    }
}

// Remind friend
function remindFriend(email) {
    if (!email) return;
    const subject = encodeURIComponent('Join me on MozAic!');
    const body = encodeURIComponent(
        `Hey! I've been using MozAic for my data, airtime, and bills. It's really affordable and reliable.\n\n` +
        `Use my referral link to join: ${document.getElementById('refLink').value}\n\n` +
        `We both earn rewards when you make your first transaction!`
    );
    window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
}

// Export CSV
document.getElementById('exportCsv').addEventListener('click', () => {
    const btn = document.getElementById('exportCsv');
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Exporting...';
    
    try {
        let csv = 'Name,Email,Joined,Status,Reward (₦)\n';
        invited.forEach(r => {
            const line = [
                r.name,
                r.email || '',
                r.joined,
                r.status,
                r.reward
            ].map(v => `"${String(v || '').replace(/"/g, '""')}"`).join(',');
            csv += line + '\n';
        });
        
        const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `referrals_${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        
        showToast('Export completed successfully', 'success');
    } catch (error) {
        console.error('Export error:', error);
        showToast('Export failed', 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
});

// Update share links
function updateShareLinks() {
    const url = encodeURIComponent(document.getElementById('refLink').value);
    const text = encodeURIComponent('Join me on MozAic for affordable data, airtime & bills!');
    
    document.getElementById('shareWa').href = `https://wa.me/?text=${text}%20${url}`;
    document.getElementById('shareTg').href = `https://t.me/share/url?url=${url}&text=${text}`;
    document.getElementById('shareTw').href = `https://twitter.com/intent/tweet?text=${text}&url=${url}`;
    document.getElementById('shareFb').href = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
}

// Initialize
renderTable();
updateShareLinks();

// Update year in footer
document.getElementById('y').textContent = new Date().getFullYear();
</script>

