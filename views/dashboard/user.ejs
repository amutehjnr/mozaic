    showToast('Electricity payment successful ✅', 'success');
    setAlert('electricityAlert', `Payment successful! Reference: ${result.data.ref || ''}`, 'success');
    if (result.data.new_balance !== undefined) updateBalanceUI(result.data.new_balance);
    this.reset(); this.classList.remove('was-validated');
    document.getElementById('meterCustomerInfo').style.display = 'none';
    setTimeout(() => location.reload(), 2500);
  } catch (err) {
    showToast(err.message, 'danger');
    setAlert('electricityAlert', err.message);
  }
  setLoading(btn, false);
});

// ─── CABLE TV ─────────────────────────────────────────────────────────────────
document.getElementById('verifySmartcardBtn').addEventListener('click', async function() {
  const provider   = document.getElementById('tvProvider').value;
  const smartcard  = document.getElementById('tvSmartcard').value.trim();
  const pkgSelect  = document.getElementById('tvPackageSelect');
  const submitBtn  = document.getElementById('tvSubmitBtn');
  const hint       = document.getElementById('tvVerifyHint');
  const amtDisplay = document.getElementById('tvAmountDisplay');

  if (!provider) { showToast('Select a provider first', 'warning'); return; }
  if (!smartcard) { showToast('Enter smartcard number', 'warning'); return; }

  const btn = this;
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Verifying…';
  pkgSelect.innerHTML = '<option value="">Loading packages…</option>';
  pkgSelect.disabled = true;
  submitBtn.disabled = true;
  document.getElementById('tvCustomerInfo').style.display = 'none';
  amtDisplay.style.display = 'none';

  try {
    // GET /api/bill/tv/packages (singular)
    const res = await apiGet(`/api/bill/tv/packages?provider=${encodeURIComponent(provider)}&smartcard=${encodeURIComponent(smartcard)}`);

    if (!res.ok || (!res.data.packages && !res.data.ok)) {
      throw new Error(res.data.error || 'Failed to load packages');
    }

    const packages = res.data.packages || [];
    const customerName = res.data.customerName || '';

    if (customerName) {
      document.getElementById('tvCustomerName').textContent = customerName;
      document.getElementById('tvCustomerInfo').style.display = 'block';
    }

    if (!packages.length) {
      pkgSelect.innerHTML = '<option value="">No packages available</option>';
      showToast('No packages found for this provider', 'warning');
      return;
    }

    pkgSelect.innerHTML = '<option value="">Select a package…</option>';
    packages.forEach(pkg => {
      const code   = pkg.code || pkg.variation_code;
      const label  = pkg.label || pkg.name || code;
      const amount = pkg.amount || pkg.variation_amount || 0;
      const opt = document.createElement('option');
      opt.value        = code;
      opt.textContent  = `${label} — ${formatNaira(amount)}`;
      opt.dataset.amount = amount;
      pkgSelect.appendChild(opt);
    });

    pkgSelect.disabled = false;
    hint.textContent = 'Select a package to continue';
    showToast(`${packages.length} packages loaded for ${customerName || provider.toUpperCase()}`, 'success');

  } catch (err) {
    showToast(err.message, 'danger');
    pkgSelect.innerHTML = '<option value="">Verification failed — try again</option>';
  }
  btn.disabled = false;
  btn.innerHTML = orig;
});

document.getElementById('tvPackageSelect').addEventListener('change', function() {
  const opt = this.options[this.selectedIndex];
  const code = opt.value;
  const amount = opt.dataset.amount || 0;
  const submitBtn = document.getElementById('tvSubmitBtn');
  const amtDisplay = document.getElementById('tvAmountDisplay');
  const amtText    = document.getElementById('tvAmountText');
  const hint       = document.getElementById('tvVerifyHint');

  if (code) {
    document.getElementById('tvPackageCode').value = code;
    document.getElementById('tvPackageAmount').value = amount;
    submitBtn.disabled = false;
    amtDisplay.style.display = 'block';
    amtText.textContent = formatNaira(amount);
    hint.textContent = '';
  } else {
    document.getElementById('tvPackageCode').value = '';
    document.getElementById('tvPackageAmount').value = '';
    submitBtn.disabled = true;
    amtDisplay.style.display = 'none';
    hint.textContent = 'Select a package to continue';
  }
});

document.getElementById('tvForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  clearAlert('tvAlert');

  const pkgCode = document.getElementById('tvPackageCode').value;
  const pkgAmount = document.getElementById('tvPackageAmount').value;

  if (!pkgCode) { showToast('Please select a package', 'warning'); return; }
  if (!this.checkValidity()) { this.classList.add('was-validated'); return; }

  const btn = document.getElementById('tvSubmitBtn');
  const payload = {
    provider: this.provider.value,
    card:     this.card.value,
    package:  pkgCode,
    amount:   pkgAmount,
    phone:    this.phone.value || '',
    confirm:  '1'
  };

  setLoading(btn, true);
  try {
    // POST to correct endpoint: /api/bill/tv (singular)
    const result = await apiPost('/api/bill/tv', payload);
    if (!result.ok) throw new Error(result.data.error || 'TV subscription failed');

    showToast('TV subscription renewed ✅', 'success');
    setAlert('tvAlert', `Subscription successful! Reference: ${result.data.ref || ''}`, 'success');
    if (result.data.new_balance !== undefined) updateBalanceUI(result.data.new_balance);
    this.reset(); this.classList.remove('was-validated');
    document.getElementById('tvPackageSelect').disabled = true;
    document.getElementById('tvPackageSelect').innerHTML = '<option value="">Verify smartcard first</option>';
    document.getElementById('tvSubmitBtn').disabled = true;
    document.getElementById('tvCustomerInfo').style.display = 'none';
    document.getElementById('tvAmountDisplay').style.display = 'none';
    setTimeout(() => location.reload(), 2500);
  } catch (err) {
    showToast(err.message, 'danger');
    setAlert('tvAlert', err.message);
  }
  setLoading(btn, false);
});

// ─── Clean URL params on load ─────────────────────────────────────────────────
(function() {
  if (window.location.search) {
    window.history.replaceState({}, document.title, window.location.pathname);
  }
})();
</script>

