                <div class="col-md-6">
                  <label class="form-label fw-semibold">Phone (Optional)</label>
                  <input type="tel" class="form-control" name="phone" placeholder="0801 234 5678">
                </div>
                
                <div class="col-12">
                  <button class="btn btn-theme" type="submit">
                    <i class="bi bi-lightning me-1"></i> Pay Electricity Bill
