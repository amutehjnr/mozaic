                    </label>
                  </div>
                </div>
                
                <div class="col-12">
                  <button class="btn btn-theme" type="submit">
                    <i class="bi bi-wifi me-1"></i> Buy Data
                  </button>
                </div>
                
                <div class="col-12">
                  <div class="alert alert-info status-alert" id="dataStatusAlert" role="alert" style="display: none;">
                    <i class="bi bi-info-circle me-2"></i>
                    <span id="dataStatusMessage"></span>
                  </div>
                </div>
              </form>
            </div>

            <!-- Electricity Tab -->
            <div class="tab-pane fade" id="electricity" role="tabpanel">
              <form class="row g-3 needs-validation" novalidate id="electricityForm" action="/api/bills/electricity" method="post">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Distribution Company</label>
                  <select class="form-select" name="disco" required>
                    <option value="">Choose...</option>
