            <!-- TV Tab -->
            <div class="tab-pane fade" id="tv" role="tabpanel">
              <form class="row g-3 needs-validation" novalidate id="tvForm" action="/api/bills/tv" method="post">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Provider</label>
                  <select class="form-select" name="provider" required id="tvProviderSelect">
                    <option value="">Choose...</option>
                    <option value="dstv">DStv</option>
                    <option value="gotv">GOtv</option>
                    <option value="startimes">Startimes</option>
                  </select>
                  <div class="invalid-feedback">Select provider.</div>
                </div>
                
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Smartcard / IUC Number</label>
                  <input type="text" class="form-control" name="card" id="tvSmartcardInput" placeholder="Enter smartcard number" required>
                  <div class="invalid-feedback">Enter a valid smartcard number.</div>
                </div>
                
                <div class="col-md-4">
                  <label class="form-label fw-semibold">Package</label>
                  <div class="input-group">
                    <select class="form-select" name="package" required id="tvPackageSelect" disabled>
                      <option value="">Verify smartcard first</option>
                    </select>
                    <button class="btn btn-outline-primary" type="button" id="verifySmartcardBtn">
                      <i class="bi bi-check-circle"></i> Verify
                    </button>
                  </div>
                  <div class="invalid-feedback">Select a package.</div>
                  
