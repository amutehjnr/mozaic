<!-- TOAST -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:1100">
  <div id="mainToast" class="toast align-items-center border-0" role="alert" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body fw-semibold" id="mainToastBody"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
'use strict';

// ─── Utilities ────────────────────────────────────────────────────────────────
const CSRF = '<%= csrfToken %>';

function showToast(msg, type = 'success') {
  const toast = document.getElementById('mainToast');
  const body  = document.getElementById('mainToastBody');
  body.textContent = msg;
  toast.className = `toast align-items-center border-0 text-bg-${type}`;
  bootstrap.Toast.getOrCreateInstance(toast, { delay: 5000 }).show();
}

function formatNaira(n) {
  return '₦' + Number(n).toLocaleString('en-NG', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function updateBalanceUI(newBal) {
  ['bigBalance', 'navBalance'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = formatNaira(newBal);
  });
}

function escapeHtml(s) {
  const d = document.createElement('div');
  d.textContent = String(s || '');
  return d.innerHTML;
}

function setAlert(elId, msg, type = 'danger') {
  const el = document.getElementById(elId);
  if (!el) return;
  el.className = `alert alert-${type} status-alert`;
  el.innerHTML = `<i class="bi bi-${type === 'success' ? 'check-circle' : type === 'info' ? 'info-circle' : 'exclamation-triangle'}-fill me-2"></i>${escapeHtml(msg)}`;
  el.style.display = 'block';
}

function clearAlert(elId) {
  const el = document.getElementById(elId);
  if (el) { el.style.display = 'none'; el.textContent = ''; }
}

function setLoading(btn, loading, originalHTML) {
  if (loading) {
    btn.disabled = true;
    btn.dataset.orig = btn.innerHTML;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
  } else {
    btn.disabled = false;
    btn.innerHTML = originalHTML || btn.dataset.orig || btn.innerHTML;
  }
}

function switchTab(tabId) {
  const tab = document.getElementById(tabId);
  if (tab) bootstrap.Tab.getOrCreateInstance(tab).show();
  document.getElementById('services')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Generic POST to API
async function apiPost(endpoint, data) {
  data['_csrf'] = CSRF;
  const fd = new FormData();
  Object.entries(data).forEach(([k, v]) => { if (v !== null && v !== undefined) fd.append(k, v); });
  const res = await fetch(endpoint, { method: 'POST', body: fd, credentials: 'same-origin' });
  const json = await res.json().catch(() => ({ ok: false, error: `Server error (${res.status})` }));
  return { ok: res.ok && (json.ok !== false), data: json, status: res.status };
}

async function apiGet(endpoint) {
  const res = await fetch(endpoint, { credentials: 'same-origin' });
  const json = await res.json().catch(() => ({ ok: false, error: `Server error (${res.status})` }));
  return { ok: res.ok, data: json, status: res.status };
}

// ─── Fund Wallet ──────────────────────────────────────────────────────────────
document.getElementById('fundForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  if (!this.checkValidity()) { this.classList.add('was-validated'); return; }
  const btn = document.getElementById('fundSubmitBtn');
  setLoading(btn, true);
  try {
    const fd = new FormData(this);
    fd.append('_csrf', CSRF);
    const res = await fetch('/api/wallet/fund', { method: 'POST', body: fd, credentials: 'same-origin' });
    const data = await res.json();
    if (data.ok && data.link) {
      showToast('Redirecting to payment gateway…', 'info');
      setTimeout(() => { window.location.href = data.link; }, 800);
    } else {
      throw new Error(data.error || 'Failed to create payment link');
    }
  } catch (err) {
    showToast(err.message, 'danger');
    setLoading(btn, false);
  }
});

// ─── Withdraw ─────────────────────────────────────────────────────────────────
document.getElementById('withdrawBankSelect').addEventListener('change', function() {
  const other = document.getElementById('otherBankField');
  other.style.display = this.value === 'Other' ? 'block' : 'none';
});

document.getElementById('withdrawForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  if (!this.checkValidity()) { this.classList.add('was-validated'); return; }
  const btn = document.getElementById('withdrawSubmitBtn');
  setLoading(btn, true);
  try {
    const bankSel = document.getElementById('withdrawBankSelect');
    const bank = bankSel.value === 'Other' ? document.getElementById('otherBankInput').value : bankSel.value;
    if (!bank) { showToast('Please enter a bank name', 'warning'); setLoading(btn, false); return; }

    const fd = new FormData(this);
    fd.set('bank', bank);
    fd.append('_csrf', CSRF);
    const res = await fetch('/api/wallet/withdraw', { method: 'POST', body: fd, credentials: 'same-origin' });
    const data = await res.json();
    if (data.ok) {
      showToast('Withdrawal request submitted!', 'success');
      bootstrap.Modal.getInstance(document.getElementById('withdrawModal'))?.hide();
      this.reset(); this.classList.remove('was-validated');
      if (data.new_balance !== undefined) updateBalanceUI(data.new_balance);
    } else {
      throw new Error(data.error || 'Withdrawal failed');
    }
  } catch (err) {
    showToast(err.message, 'danger');
  }
  setLoading(btn, false);
});

// ─── AIRTIME ──────────────────────────────────────────────────────────────────
document.getElementById('airtimeForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  clearAlert('airtimeAlert');
  if (!this.checkValidity()) { this.classList.add('was-validated'); return; }

  const btn = document.getElementById('airtimeSubmitBtn');
  const data = {
    network:       this.network.value,
    phone:         this.phone.value,
    amount:        this.amount.value,
    saveBeneficiary: this.saveBeneficiary?.checked ? '1' : '0',
    confirm:       '1'
  };

  setLoading(btn, true);
  try {
    // POST to correct endpoint: /api/bill/airtime (singular)
    const result = await apiPost('/api/bill/airtime', data);
    if (!result.ok) throw new Error(result.data.error || 'Airtime purchase failed');

    showToast(`Airtime sent to ${data.phone} ✅`, 'success');
    setAlert('airtimeAlert', `Airtime purchase successful! Reference: ${result.data.ref || ''}`, 'success');
    if (result.data.new_balance !== undefined) updateBalanceUI(result.data.new_balance);
    this.reset(); this.classList.remove('was-validated');
    setTimeout(() => location.reload(), 2500);
  } catch (err) {
    showToast(err.message, 'danger');
    setAlert('airtimeAlert', err.message);
  }
  setLoading(btn, false);
});

// ─── DATA PLANS ───────────────────────────────────────────────────────────────
let selectedPlan = null;

document.getElementById('dataNetwork').addEventListener('change', async function() {
  const net = this.value;
  const btn = document.getElementById('dataPlanBtn');
  const menu = document.getElementById('dataPlanMenu');
  const label = document.getElementById('dataPlanLabel');

  if (!net) {
    btn.disabled = true;
    label.innerHTML = '<i class="bi bi-wifi me-2 text-muted"></i>Select network first';
    menu.innerHTML = '';
    selectedPlan = null;
    document.getElementById('dataPlanCode').value = '';
    return;
  }

  btn.disabled = true;
  label.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Loading plans…';
  menu.innerHTML = '<li><span class="dropdown-item-text text-muted small">Loading…</span></li>';
  selectedPlan = null;
  document.getElementById('dataPlanCode').value = '';

  try {
    // GET correct endpoint: /api/bill/data/plans (singular)
    const res = await apiGet(`/api/bill/data/plans?network=${encodeURIComponent(net)}`);
    let plans = res.data;

    // The endpoint returns either an array directly or wrapped in plans/content
    if (!Array.isArray(plans)) {
      plans = plans.plans || plans.content?.variations || plans.data || [];
    }

    if (!plans.length) {
      menu.innerHTML = '<li><span class="dropdown-item-text text-muted small">No plans available</span></li>';
      label.innerHTML = '<i class="bi bi-wifi me-2 text-muted"></i>No plans found';
      btn.disabled = true;
      return;
    }

    menu.innerHTML = '';
    plans.forEach(plan => {
      const code   = plan.code || plan.variation_code;
      const planLbl = plan.label || plan.name || code;
      const amount = plan.amount || plan.variation_amount || 0;

      const li = document.createElement('li');
      li.innerHTML = `
        <a class="dropdown-item plan-item d-flex justify-content-between align-items-center py-2 px-3" href="#" data-code="${escapeHtml(code)}" data-amount="${amount}">
          <span class="small fw-semibold">${escapeHtml(planLbl)}</span>
          <span class="text-success fw-bold small">${formatNaira(amount)}</span>
        </a>`;

      li.querySelector('a').addEventListener('click', function(ev) {
        ev.preventDefault();
        selectedPlan = { code, label: planLbl, amount };
        document.getElementById('dataPlanCode').value = code;
        document.getElementById('dataPlanAmount').value = amount;
        label.innerHTML = `<i class="bi bi-check-circle-fill text-success me-2"></i>${escapeHtml(planLbl)} — ${formatNaira(amount)}`;
        menu.querySelectorAll('.plan-item').forEach(i => i.classList.remove('selected'));
        this.classList.add('selected');
      });

      menu.appendChild(li);
    });

    btn.disabled = false;
    label.innerHTML = `<i class="bi bi-wifi me-2 text-primary"></i>${plans.length} plans available`;
  } catch (err) {
    menu.innerHTML = `<li><span class="dropdown-item-text text-danger small">${escapeHtml(err.message)}</span></li>`;
    label.innerHTML = '<i class="bi bi-exclamation-triangle me-2 text-danger"></i>Failed to load plans';
    btn.disabled = false;
  }
});

document.getElementById('dataForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  clearAlert('dataAlert');

  if (!selectedPlan) {
    showToast('Please select a data plan', 'warning');
    return;
  }
  if (!this.checkValidity()) { this.classList.add('was-validated'); return; }

  const btn = document.getElementById('dataSubmitBtn');
  const payload = {
    network:  this.network.value,
    phone:    this.phone.value,
    planCode: selectedPlan.code,
    amount:   selectedPlan.amount,
    saveBeneficiary: this.saveBeneficiary?.checked ? '1' : '0',
    confirm:  '1'
  };

  setLoading(btn, true);
  try {
    // POST to correct endpoint: /api/bill/data (singular)
    const result = await apiPost('/api/bill/data', payload);
    if (!result.ok) throw new Error(result.data.error || 'Data purchase failed');

    showToast(`Data bundle sent to ${payload.phone} ✅`, 'success');
    setAlert('dataAlert', `Data purchase successful! Reference: ${result.data.ref || ''}`, 'success');
    if (result.data.new_balance !== undefined) updateBalanceUI(result.data.new_balance);
    this.reset(); this.classList.remove('was-validated');
    selectedPlan = null;
    document.getElementById('dataPlanBtn').disabled = true;
    document.getElementById('dataPlanLabel').innerHTML = '<i class="bi bi-wifi me-2 text-muted"></i>Select network first';
    setTimeout(() => location.reload(), 2500);
  } catch (err) {
    showToast(err.message, 'danger');
    setAlert('dataAlert', err.message);
  }
  setLoading(btn, false);
});

// ─── ELECTRICITY ──────────────────────────────────────────────────────────────
document.getElementById('verifyMeterBtn').addEventListener('click', async function() {
  const disco  = document.getElementById('discoSelect').value;
  const meterNo = document.getElementById('meterNo').value.trim();

  if (!disco) { showToast('Select a DISCO first', 'warning'); return; }
  if (!meterNo) { showToast('Enter a meter number', 'warning'); return; }

  const btn = this;
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

  try {
    // GET /api/bill/verify (singular)
    const res = await apiGet(`/api/bill/verify?provider=${encodeURIComponent(disco)}&number=${encodeURIComponent(meterNo)}&type=prepaid`);
    if (res.ok && res.data.ok && res.data.customerName) {
      document.getElementById('meterCustomerName').textContent = res.data.customerName;
      document.getElementById('meterCustomerInfo').style.display = 'block';
      showToast(`Meter verified: ${res.data.customerName}`, 'success');
    } else {
      document.getElementById('meterCustomerInfo').style.display = 'none';
      showToast(res.data.error || 'Could not verify meter — double-check and try again', 'warning');
    }
  } catch (err) {
    showToast('Meter verification failed', 'danger');
  }
  btn.disabled = false;
  btn.innerHTML = orig;
});

document.getElementById('electricityForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  clearAlert('electricityAlert');
  if (!this.checkValidity()) { this.classList.add('was-validated'); return; }

  const btn = document.getElementById('electricitySubmitBtn');
  const payload = {
    disco:     this.disco.value,
    meterNo:   this.meterNo.value,
    meterType: this.meterType.value,
