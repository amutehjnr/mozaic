<!-- OFFCANVAS -->
<div class="offcanvas offcanvas-end offcanvas-user" tabindex="-1" id="userMenu" aria-labelledby="userMenuLabel">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title text-white" id="userMenuLabel">Menu</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body d-flex flex-column gap-3">
    <div class="d-flex align-items-center gap-2 p-3 bg-white bg-opacity-10 rounded-3">
      <i class="bi bi-wallet2 fs-4"></i>
      <div>
        <div class="small text-white-50">Balance</div>
        <strong class="fs-5 text-white" id="navBalanceMobile"><%= formatNaira(walletBalance) %></strong>
      </div>
    </div>
    
    <a class="btn btn-theme w-100" data-bs-toggle="modal" data-bs-target="#fundModal">
      <i class="bi bi-plus-circle me-1"></i> Fund Wallet
    </a>
    <a class="btn btn-outline-light w-100" data-bs-toggle="modal" data-bs-target="#withdrawModal">
      <i class="bi bi-arrow-down-circle me-1"></i> Withdraw
    </a>
    
    <% if (debugMode) { %>
    <a class="btn btn-warning w-100" href="/dashboard/debug/wallet" target="_blank">
      <i class="bi bi-bug me-1"></i> Debug Wallet
    </a>
    <% } %>
    
    <hr class="border-white-50">
    
    <a class="nav-link" href="/"><i class="bi bi-house me-2"></i> Home</a>
    <a class="nav-link" href="#services"><i class="bi bi-grid me-2"></i> Services</a>
    <a class="nav-link" href="/dashboard/history"><i class="bi bi-clock-history me-2"></i> History</a>
    <a class="nav-link" href="/dashboard/beneficiaries"><i class="bi bi-people me-2"></i> Beneficiaries</a>
    <a class="nav-link" href="/dashboard/referrals"><i class="bi bi-gift me-2"></i> Referrals</a>
    <a class="nav-link" href="/dashboard/settings"><i class="bi bi-gear me-2"></i> Settings</a>
    <a class="nav-link" href="/support"><i class="bi bi-question-circle me-2"></i> Support</a>
    
    <form method="POST" action="/auth/logout" class="mt-auto">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-light w-100">
        <i class="bi bi-box-arrow-right me-1"></i> Logout
      </button>
    </form>
  </div>
</div>

<!-- HEADER -->
<header id="header" style="background-image:url('https://images.unsplash.com/photo-1520975682031-1f236b54a3c5?q=80&w=1600&auto=format&fit=crop');">
  <div class="container">
    <div class="row align-items-center g-3">
      <div class="col-lg-8">
        <h1 class="fw-bold mb-1">Welcome back, <span id="welcomeName"><%= displayName %></span> 👋</h1>
        <p class="lead mb-0 opacity-75">Manage wallet, buy data & airtime, pay bills, and track every transaction — all in one place.</p>
        <div class="d-flex flex-wrap align-items-center gap-2 mt-3">
          <span class="badge-soft bg-white bg-opacity-20 text-white">Verified</span>
          <span class="badge-soft bg-white bg-opacity-20 text-white">Secure</span>
          <% if (debugMode) { %>
          <span class="badge bg-warning text-dark">Test Mode</span>
          <% } else { %>
          <span class="badge bg-success">Live Mode</span>
          <% } %>
          <% if (walletStatus !== 'active') { %>
          <span class="badge bg-danger">Wallet: <%= walletStatus %></span>
          <% } %>
        </div>
      </div>
      <div class="col-lg-4 text-lg-end">
        <a href="/dashboard/history" class="btn btn-outline-light me-2">
          <i class="bi bi-clock-history me-1"></i> History
        </a>
        <button class="btn btn-theme" data-bs-toggle="modal" data-bs-target="#fundModal">
          <i class="bi bi-plus-circle me-1"></i> Fund
        </button>
      </div>
    </div>
  </div>
</header>

<!-- ALERTS -->
<div class="container mt-3">
  <% if (successMsg) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i>
      <%= successMsg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  
  <% if (errorMsg) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      <%= errorMsg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  
  <% if (flwDebugMode) { %>
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      <strong>Flutterwave API Key Missing:</strong> Add FLW_SECRET_KEY and FLW_PUBLIC_KEY to your .env file to enable real payments.
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  
  <% if (vtpassDebugMode) { %>
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      <strong>VTPass API Key Missing:</strong> Add VTPASS_API_KEY and VTPASS_SECRET_KEY to your .env file for live bill payments.
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  
  <% if (walletStatus !== 'active') { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      <strong>Wallet Issue:</strong> Your wallet is <%= walletStatus %>. Some features may be limited.
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
</div>

<!-- CONTENT -->
<main class="section py-4">
  <div class="container">
    <div class="row g-4">
      <!-- LEFT COLUMN -->
      <div class="col-lg-8">
        <!-- Wallet Card -->
        <div class="card p-4 mb-4">
          <div class="d-flex flex-wrap justify-content-between align-items-end gap-3">
            <div>
              <div class="small text-muted mb-1">Wallet Balance</div>
              <div class="balance-amount" id="bigBalance"><%= formatNaira(walletBalance) %></div>
              <div class="d-flex flex-wrap gap-3 mt-3">
                <span class="small text-muted">
                  <i class="bi bi-hash"></i> ID: <span class="fw-semibold" id="walletId"><%= walletDisplayId %></span>
                </span>
                <span class="small text-muted">
                  <i class="bi bi-shield-check"></i> Tier: <span class="fw-semibold" id="tier"><%= wallet.tier || 'Basic' %></span>
                </span>
                <span class="small text-muted">
                  <i class="bi bi-cone-striped"></i> Mode: <span class="fw-semibold" id="mode"><%= debugMode ? 'Test' : 'Live' %></span>
                </span>
                <span class="small text-muted">
                  <i class="bi bi-wallet2"></i> Status: 
                  <span class="fw-semibold <%= walletStatus === 'active' ? 'text-success' : 'text-danger' %>" id="walletStatus">
                    <%= walletStatus %>
