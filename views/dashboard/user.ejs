<%
// Get user data from session (passed from server)
const user = typeof userData !== 'undefined' ? userData : { id: 0, name: '', email: '', phone: '' };
const wallet = typeof walletData !== 'undefined' ? walletData : { id: 0, balance: 0, status: 'active' };
const transactions = typeof transactionsData !== 'undefined' ? transactionsData : [];
const todayTotal = typeof todayTotalData !== 'undefined' ? todayTotalData : 0;
const kpiTx = transactions.length;

// Format helpers
const formatNaira = (amount) => '₦' + Number(amount).toLocaleString('en-NG', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const walletBalance = wallet.balance || 0;

// Wallet display ID
const walletDisplayId = 'WLT-' + String(wallet._id || wallet.id || '').slice(-6).padStart(6, '0').toUpperCase();
const walletStatus = wallet.status || 'active';

// Debug mode flags
const flwDebugMode = typeof flwDebugMode !== 'undefined' ? flwDebugMode : false;
const vtpassDebugMode = typeof vtpassDebugMode !== 'undefined' ? vtpassDebugMode : false;
const debugMode = flwDebugMode || vtpassDebugMode;

// Display name
const displayName = user.name && user.name !== '' ? user.name : (user.email || 'User');

// Check for payment messages from query params
let successMsg = '';
let errorMsg = '';

if (typeof queryParams !== 'undefined' && queryParams) {
    if (queryParams.payment_success === '1') {
        const amount = queryParams.amount || 0;
        const balance = queryParams.balance || walletBalance;
        successMsg = `✅ Payment successful! ₦${Number(amount).toFixed(2)} has been added to your wallet. New balance: ₦${Number(balance).toFixed(2)}`;
        if (balance) wallet.balance = parseFloat(balance);
    }
    if (queryParams.payment_failed === '1') {
        const tx_ref = queryParams.tx_ref || '';
        const status = queryParams.status || '';
        errorMsg = `❌ Payment failed. ${tx_ref ? 'Reference: ' + tx_ref + '. ' : ''}${status ? 'Status: ' + status : ''}`;
    }
    if (queryParams.payment_error) {
        const err_map = {
            'missing_reference': 'Missing transaction reference',
            'transaction_not_found': 'Transaction not found',
            'processing_error': 'Payment processing error. Please contact support.'
        };
        errorMsg = `❌ Payment error: ${err_map[queryParams.payment_error] || 'An error occurred'}`;
    }
}

// Transaction helpers
const amountNaira = (t) => {
    if (!t) return 0;
    if (t.amount_kobo) return t.amount_kobo / 100;
    if (t.amount_naira) return t.amount_naira;
    if (t.amount) return t.amount;
    return 0;
};

const transactionDetails = (t) => {
    if (!t) return '—';
    if (t.details) return t.details;
    const parts = [];
    if (t.provider) parts.push(t.provider.toUpperCase());
    if (t.account_target) parts.push(t.account_target);
    try {
        const meta = typeof t.metadata === 'string' ? JSON.parse(t.metadata) : t.metadata;
        if (meta) {
            if (meta.phone) parts.push(meta.phone);
            if (meta.network) parts.push(meta.network.toUpperCase());
        }
    } catch(e) {}
    return parts.filter(Boolean).join(' — ') || '—';
};

const transactionType = (t) => {
    if (!t) return '-';
    if (t.type) return t.type.charAt(0).toUpperCase() + t.type.slice(1);
    if (t.provider) return t.provider.charAt(0).toUpperCase() + t.provider.slice(1);
    return '-';
};

const transactionCreated = (t) => {
    if (!t) return '';
    const raw = t.created_at || t.createdAt || '';
    if (!raw) return '';
    const ts = new Date(raw);
    if (isNaN(ts.getTime())) return raw;
    return ts.toLocaleString('en-NG', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
};

const transactionStatusClass = (status) => {
    const classes = { 'success': 'badge-soft-success', 'pending': 'badge-soft-warning', 'failed': 'badge-soft-danger', 'processing': 'badge-soft-info' };
    return classes[status?.toLowerCase()] || 'badge-soft-secondary';
};
%>
<%- include('../partials/header') %>

<style>
  :root{
    --jn-font:'Poppins',system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    --jn-primary:#EF5134; --jn-primary-600:#e3472b;
    --jn-bg:#0f172a; --jn-surface:#ffffff; --jn-muted:#64748b; --jn-border:#e5e7eb;
    --jn-shadow-lg:0 24px 48px rgba(2,6,23,.15); --jn-shadow-sm:0 1px 3px rgba(2,6,23,.12),0 1px 2px rgba(2,6,23,.06);
  }
  body { font-family: var(--jn-font); background: #f8fafc; }
  .navbar { background: rgba(11, 18, 32, 0.95); backdrop-filter: blur(10px); padding: 0.75rem 0; }
  .navbar-brand { font-weight: 800; font-size: 1.5rem; color: white !important; }
  .navbar-brand span { color: var(--jn-primary); }
  .nav-link { color: rgba(255,255,255,0.8) !important; font-weight: 500; transition: all 0.2s; }
  .nav-link:hover, .nav-link.active { color: white !important; }
  .stat-pill { background: rgba(255,255,255,0.1); padding: 0.5rem 1rem; border-radius: 100px; color: white; font-weight: 600; }
  #header { background-size: cover; background-position: center; position: relative; padding: 3rem 0; margin-bottom: 2rem; }
  #header::before { content: ''; position: absolute; top:0; left:0; right:0; bottom:0; background: linear-gradient(to right, rgba(11,18,32,0.95), rgba(11,18,32,0.7)); }
  #header .container { position: relative; z-index: 1; color: white; }
  .card { border: none; border-radius: 16px; box-shadow: var(--jn-shadow-sm); transition: all 0.2s; }
  .card:hover { box-shadow: var(--jn-shadow-lg); }
  .balance-amount { font-size: 2.5rem; font-weight: 700; color: var(--jn-primary); line-height: 1.2; }
  .badge-soft { background: #f1f5f9; color: #334155; padding: 0.25rem 0.75rem; border-radius: 100px; font-size: 0.875rem; font-weight: 500; }
  .badge-soft-success { background: #dcfce7; color: #166534; }
  .badge-soft-warning { background: #fef9c3; color: #854d0e; }
  .badge-soft-danger { background: #fee2e2; color: #991b1b; }
  .badge-soft-info { background: #e0f2fe; color: #075985; }
  .badge-soft-secondary { background: #f1f5f9; color: #334155; }
  .nav-tabs { border-bottom: 2px solid #e2e8f0; }
  .nav-tabs .nav-link { color: #64748b !important; border: none; padding: 0.85rem 1.25rem; font-weight: 600; margin-bottom: -2px; }
  .nav-tabs .nav-link:hover { color: #334155 !important; border: none; }
  .nav-tabs .nav-link.active { color: var(--jn-primary) !important; background: none; border-bottom: 2px solid var(--jn-primary); }
  .tab-content { background: white; border: 1px solid #e2e8f0; border-top: none; border-radius: 0 0 16px 16px; }
  .form-control, .form-select { border-radius: 10px; border: 1px solid #e2e8f0; }
  .form-control:focus, .form-select:focus { border-color: var(--jn-primary); box-shadow: 0 0 0 3px rgba(239,81,52,.15); }
  .btn-theme { background: var(--jn-primary); border: none; border-radius: 10px; font-weight: 600; padding: 0.65rem 1.5rem; color: white; transition: all 0.2s; }
  .btn-theme:hover { background: var(--jn-primary-600); transform: translateY(-1px); box-shadow: 0 4px 12px rgba(239,81,52,0.3); color: white; }
  .btn-theme:disabled { opacity: 0.6; transform: none; }
  .spinner-border-sm { width: 1rem; height: 1rem; border-width: 2px; }
  .status-alert { border-radius: 10px; }
  .plan-item { cursor: pointer; transition: background 0.15s; }
  .plan-item:hover { background: #f8fafc; }
  .plan-item.selected { background: #fff5f2; }
  .network-badge { display: inline-flex; align-items: center; gap: 0.4rem; background: #f1f5f9; border-radius: 8px; padding: 0.4rem 0.75rem; font-size: 0.85rem; font-weight: 600; }
  .offcanvas-user { background: #0b1220; color: white; }
  .offcanvas-user .nav-link { color: rgba(255,255,255,0.8) !important; padding: 0.75rem 1rem; border-radius: 8px; }
  .offcanvas-user .nav-link:hover { color: white !important; background: rgba(255,255,255,0.1); }
  @media (max-width: 768px) {
    .balance-amount { font-size: 2rem; }
    .nav-tabs .nav-link { padding: 0.65rem 0.75rem; font-size: 0.85rem; }
  }
  /* Quick action tiles */
  .quick-tile { cursor: pointer; transition: all 0.2s; }
  .quick-tile:hover { transform: translateY(-3px); }
  .quick-tile .card { border: 2px solid transparent; }
  .quick-tile:hover .card { border-color: var(--jn-primary); }
</style>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/"><span>Moz</span>Aic</a>
    <button class="navbar-toggler text-light" type="button" data-bs-toggle="offcanvas" data-bs-target="#userMenu" aria-label="Open menu">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link active" href="/dashboard/user">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/dashboard/history">History</a></li>
        <li class="nav-item"><a class="nav-link" href="/dashboard/beneficiaries">Saved</a></li>
        <li class="nav-item"><a class="nav-link" href="/support">Support</a></li>
      </ul>
      <div class="d-none d-lg-flex align-items-center gap-2">
        <span class="stat-pill">
          <i class="bi bi-wallet2 me-1"></i>
          <span id="navBalance"><%= formatNaira(walletBalance) %></span>
        </span>
        <div class="dropdown">
          <button class="btn btn-outline-light dropdown-toggle" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle me-1"></i> <%= displayName %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="/dashboard/settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
            <li><a class="dropdown-item" href="/dashboard/referrals"><i class="bi bi-gift me-2"></i>Referrals</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <form method="POST" action="/auth/logout">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
              </form>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</nav>

<!-- OFFCANVAS MENU -->
<div class="offcanvas offcanvas-end offcanvas-user" tabindex="-1" id="userMenu">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title text-white">Menu</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
  </div>
  <div class="offcanvas-body d-flex flex-column gap-2">
    <div class="d-flex align-items-center gap-2 p-3 bg-white bg-opacity-10 rounded-3 mb-2">
      <i class="bi bi-wallet2 fs-4"></i>
      <div>
        <div class="small text-white-50">Balance</div>
        <strong class="fs-5 text-white"><%= formatNaira(walletBalance) %></strong>
      </div>
    </div>
    <button class="btn btn-theme w-100" data-bs-toggle="modal" data-bs-target="#fundModal" data-bs-dismiss="offcanvas">
      <i class="bi bi-plus-circle me-1"></i> Fund Wallet
    </button>
    <button class="btn btn-outline-light w-100" data-bs-toggle="modal" data-bs-target="#withdrawModal" data-bs-dismiss="offcanvas">
      <i class="bi bi-arrow-down-circle me-1"></i> Withdraw
    </button>
    <hr class="border-white-50">
    <a class="nav-link" href="/dashboard/user"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
    <a class="nav-link" href="/dashboard/history"><i class="bi bi-clock-history me-2"></i>History</a>
    <a class="nav-link" href="/dashboard/beneficiaries"><i class="bi bi-people me-2"></i>Beneficiaries</a>
    <a class="nav-link" href="/dashboard/referrals"><i class="bi bi-gift me-2"></i>Referrals</a>
    <a class="nav-link" href="/dashboard/settings"><i class="bi bi-gear me-2"></i>Settings</a>
    <a class="nav-link" href="/support"><i class="bi bi-question-circle me-2"></i>Support</a>
    <form method="POST" action="/auth/logout" class="mt-auto">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="btn btn-light w-100"><i class="bi bi-box-arrow-right me-1"></i>Logout</button>
    </form>
  </div>
</div>

<!-- HEADER -->
<header id="header" style="background-image:url('https://images.unsplash.com/photo-1520975682031-1f236b54a3c5?q=80&w=1600&auto=format&fit=crop');">
  <div class="container">
    <div class="row align-items-center g-3">
      <div class="col-lg-8">
        <h1 class="fw-bold mb-1">Welcome back, <%= displayName %> 👋</h1>
        <p class="lead mb-0 opacity-75">Buy data, airtime, pay bills — all from your wallet.</p>
        <div class="d-flex flex-wrap gap-2 mt-3">
          <span class="badge bg-white bg-opacity-20 text-white">Secure</span>
          <% if (debugMode) { %><span class="badge bg-warning text-dark">Test Mode</span><% } else { %><span class="badge bg-success">Live Mode</span><% } %>
          <% if (walletStatus !== 'active') { %><span class="badge bg-danger">Wallet: <%= walletStatus %></span><% } %>
        </div>
      </div>
      <div class="col-lg-4 text-lg-end">
        <a href="/dashboard/history" class="btn btn-outline-light me-2"><i class="bi bi-clock-history me-1"></i>History</a>
        <button class="btn btn-theme" data-bs-toggle="modal" data-bs-target="#fundModal"><i class="bi bi-plus-circle me-1"></i>Fund Wallet</button>
      </div>
    </div>
  </div>
</header>

<!-- ALERTS -->
<div class="container mt-3">
  <% if (successMsg) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle-fill me-2"></i><%= successMsg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (errorMsg) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i><%= errorMsg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (flwDebugMode) { %>
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Flutterwave keys missing</strong> — payments run in test mode.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
  <% if (walletStatus !== 'active') { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>Your wallet is <strong><%= walletStatus %></strong>. Contact support.
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>
</div>

<!-- MAIN CONTENT -->
<main class="py-4">
  <div class="container">
    <div class="row g-4">

      <!-- LEFT COLUMN -->
      <div class="col-lg-8">

        <!-- WALLET CARD -->
        <div class="card p-4 mb-4">
          <div class="d-flex flex-wrap justify-content-between align-items-end gap-3">
            <div>
              <div class="small text-muted mb-1">Wallet Balance</div>
              <div class="balance-amount" id="bigBalance"><%= formatNaira(walletBalance) %></div>
              <div class="d-flex flex-wrap gap-3 mt-2">
                <span class="small text-muted"><i class="bi bi-hash"></i> <%= walletDisplayId %></span>
                <span class="small text-muted"><i class="bi bi-shield-check"></i> Tier: <%= wallet.tier || 'Basic' %></span>
                <span class="small <%= walletStatus === 'active' ? 'text-success' : 'text-danger' %>">
                  <i class="bi bi-circle-fill" style="font-size:0.5rem;vertical-align:middle;"></i> <%= walletStatus %>
                </span>
              </div>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <button class="btn btn-theme" data-bs-toggle="modal" data-bs-target="#fundModal">
                <i class="bi bi-plus-circle me-1"></i>Fund
              </button>
              <button class="btn btn-outline-dark" data-bs-toggle="modal" data-bs-target="#withdrawModal">
                <i class="bi bi-arrow-down-circle me-1"></i>Withdraw
              </button>
              <a href="/dashboard/requery" class="btn btn-outline-dark">
                <i class="bi bi-arrow-repeat me-1"></i>Requery
              </a>
            </div>
          </div>
        </div>

        <!-- QUICK ACTION TILES -->
        <div class="row g-3 mb-4">
          <div class="col-6 col-sm-3 quick-tile" onclick="switchTab('airtime-tab')">
            <div class="card p-3 text-center">
              <div class="fs-1 mb-1">📱</div>
              <div class="small fw-semibold">Airtime</div>
            </div>
          </div>
          <div class="col-6 col-sm-3 quick-tile" onclick="switchTab('data-tab')">
            <div class="card p-3 text-center">
              <div class="fs-1 mb-1">📶</div>
              <div class="small fw-semibold">Data</div>
            </div>
          </div>
          <div class="col-6 col-sm-3 quick-tile" onclick="switchTab('electricity-tab')">
            <div class="card p-3 text-center">
              <div class="fs-1 mb-1">⚡</div>
              <div class="small fw-semibold">Electricity</div>
            </div>
          </div>
          <div class="col-6 col-sm-3 quick-tile" onclick="switchTab('tv-tab')">
            <div class="card p-3 text-center">
              <div class="fs-1 mb-1">📺</div>
              <div class="small fw-semibold">Cable TV</div>
            </div>
          </div>
        </div>

        <!-- SERVICES TABS -->
        <div id="services">
          <ul class="nav nav-tabs" id="serviceTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active" id="airtime-tab" data-bs-toggle="tab" data-bs-target="#airtime" type="button">
                <i class="bi bi-phone-fill me-1"></i>Airtime
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="data-tab" data-bs-toggle="tab" data-bs-target="#data" type="button">
                <i class="bi bi-wifi me-1"></i>Data
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="electricity-tab" data-bs-toggle="tab" data-bs-target="#electricity" type="button">
                <i class="bi bi-plug me-1"></i>Electricity
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link" id="tv-tab" data-bs-toggle="tab" data-bs-target="#tv" type="button">
                <i class="bi bi-tv me-1"></i>Cable TV
              </button>
            </li>
          </ul>

          <div class="tab-content p-4">

            <!-- ===== AIRTIME TAB ===== -->
            <div class="tab-pane fade show active" id="airtime" role="tabpanel">
              <h6 class="fw-bold mb-3 text-muted">Buy Airtime</h6>
              <form class="row g-3 needs-validation" novalidate id="airtimeForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                <div class="col-md-4">
                  <label class="form-label fw-semibold">Network</label>
                  <select class="form-select" name="network" required>
                    <option value="">Choose network...</option>
                    <option value="mtn">MTN</option>
                    <option value="glo">GLO</option>
                    <option value="airtel">Airtel</option>
                    <option value="9mobile">9mobile</option>
                  </select>
                  <div class="invalid-feedback">Select a network.</div>
                </div>

                <div class="col-md-4">
                  <label class="form-label fw-semibold">Phone Number</label>
                  <input type="tel" class="form-control" name="phone" placeholder="0801 234 5678" inputmode="tel" required>
                  <div class="invalid-feedback">Enter a valid number.</div>
                </div>

                <div class="col-md-4">
                  <label class="form-label fw-semibold">Amount (₦)</label>
                  <input type="number" min="50" step="50" class="form-control" name="amount" placeholder="e.g. 500" required>
                  <div class="invalid-feedback">Minimum ₦50.</div>
                </div>

                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="saveAirtimeBen" name="saveBeneficiary" value="1">
                    <label class="form-check-label small" for="saveAirtimeBen">Save as beneficiary</label>
                  </div>
                </div>

                <div class="col-12">
                  <button class="btn btn-theme" type="submit" id="airtimeSubmitBtn">
                    <i class="bi bi-lightning-charge me-1"></i>Buy Airtime
                  </button>
                </div>

                <div class="col-12">
                  <div class="alert status-alert" id="airtimeAlert" style="display:none;" role="alert"></div>
                </div>
              </form>
            </div>

            <!-- ===== DATA TAB ===== -->
            <div class="tab-pane fade" id="data" role="tabpanel">
              <h6 class="fw-bold mb-3 text-muted">Buy Data Bundle</h6>
              <form class="row g-3 needs-validation" novalidate id="dataForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="planCode" id="dataPlanCode">
                <input type="hidden" name="amount" id="dataPlanAmount">

                <div class="col-md-4">
                  <label class="form-label fw-semibold">Network</label>
                  <select class="form-select" name="network" id="dataNetwork" required>
                    <option value="">Choose network...</option>
                    <option value="mtn">MTN</option>
                    <option value="glo">GLO</option>
                    <option value="airtel">Airtel</option>
                    <option value="9mobile">9mobile</option>
                  </select>
                  <div class="invalid-feedback">Select a network.</div>
                </div>

                <div class="col-md-4">
                  <label class="form-label fw-semibold">Phone Number</label>
                  <input type="tel" class="form-control" name="phone" placeholder="0801 234 5678" inputmode="tel" required>
                  <div class="invalid-feedback">Enter a valid number.</div>
                </div>

                <div class="col-md-4">
                  <label class="form-label fw-semibold">Data Plan</label>
                  <div class="dropdown">
                    <button class="btn btn-outline-dark w-100 text-start d-flex justify-content-between align-items-center"
                            type="button" id="dataPlanBtn" data-bs-toggle="dropdown" disabled>
                      <span id="dataPlanLabel"><i class="bi bi-wifi me-2 text-muted"></i>Select network first</span>
                      <i class="bi bi-chevron-down"></i>
                    </button>
                    <ul class="dropdown-menu w-100" id="dataPlanMenu" style="max-height:320px;overflow-y:auto;"></ul>
                  </div>
                  <div class="invalid-feedback d-block" id="dataPlanError" style="display:none!important;"></div>
                </div>

                <div class="col-12">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="saveDataBen" name="saveBeneficiary" value="1">
                    <label class="form-check-label small" for="saveDataBen">Save as beneficiary</label>
                  </div>
                </div>

                <div class="col-12">
                  <button class="btn btn-theme" type="submit" id="dataSubmitBtn">
                    <i class="bi bi-wifi me-1"></i>Buy Data
                  </button>
                </div>

                <div class="col-12">
