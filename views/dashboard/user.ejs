                  <div class="alert alert-success mt-2" id="tvCustomerInfo" style="display: none;">
                    <i class="bi bi-person-circle me-2"></i>
                    <span id="customerNameText">Customer</span>
                  </div>
                </div>
                
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Amount (₦)</label>
                  <input type="number" class="form-control" name="amount" id="tvAmountInput" readonly required>
                  <div class="invalid-feedback">Amount will auto-fill after package selection.</div>
                </div>
                
                <div class="col-md-6">
                  <label class="form-label fw-semibold">Phone (Optional)</label>
                  <input type="tel" class="form-control" name="phone" placeholder="0801 234 5678">
                </div>
                
                <div class="col-12 d-flex gap-2 flex-wrap">
                  <button class="btn btn-theme" type="submit" id="tvSubmitBtn" disabled>
                    <i class="bi bi-tv me-1"></i> Renew Subscription
                  </button>
                  <button class="btn btn-outline-primary" type="button" id="refreshTvPackages">
                    <i class="bi bi-arrow-clockwise me-1"></i> Refresh
                  </button>
                  <button class="btn btn-outline-info" type="button" data-bs-toggle="modal" data-bs-target="#tvPackagesModal">
                    <i class="bi bi-grid me-1"></i> View All Packages
                  </button>
                </div>
                
                <div class="col-12">
                  <div class="alert alert-info status-alert" id="tvStatusAlert" role="alert" style="display: none;">
                    <i class="bi bi-info-circle me-2"></i>
                    <span id="tvStatusMessage"></span>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT COLUMN -->
      <div class="col-lg-4">
        <!-- Mini KPIs -->
        <div class="row g-3">
          <div class="col-12">
            <div class="card p-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <div class="text-muted small">Today's Spend</div>
                  <div class="h4 mb-0 fw-bold" id="kpiToday"><%= formatNaira(todayTotal) %></div>
                </div>
                <i class="bi bi-graph-up-arrow fs-2 text-primary opacity-25"></i>
              </div>
            </div>
          </div>
          
          <div class="col-12">
            <div class="card p-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <div class="text-muted small">Total Transactions</div>
                  <div class="h4 mb-0 fw-bold" id="kpiTx"><%= kpiTx %></div>
                </div>
                <i class="bi bi-receipt fs-2 text-success opacity-25"></i>
              </div>
            </div>
          </div>
          
          <div class="col-12">
            <div class="card p-3">
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <div class="text-muted small">KYC Status</div>
                  <div class="h5 mb-0">
                    <span class="badge-soft <%= user.kycStatus === 'verified' ? 'badge-soft-success' : 'badge-soft-warning' %>">
                      <%= user.kycStatus || 'Not Started' %>
                    </span>
                  </div>
                </div>
                <a href="/dashboard/verify" class="btn btn-sm btn-outline-primary">Verify</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Recent Activity -->
        <div class="card mt-3">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>Recent Activity</strong>
            <a href="/dashboard/history" class="small text-decoration-none">View all</a>
          </div>
          <div class="list-group list-group-flush">
            <% if (!transactions || transactions.length === 0) { %>
              <div class="list-group-item text-center py-4 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                No recent transactions
              </div>
            <% } else { 
              // Safely iterate over transactions with for loop
              const recentTransactions = transactions.slice(0, 5);
              for (let i = 0; i < recentTransactions.length; i++) {
                const t = recentTransactions[i];
                const type = transactionType(t);
                const details = transactionDetails(t);
                const amt = amountNaira(t);
                const cls = amt < 0 ? 'text-danger' : 'text-success';
                const sign = amt < 0 ? '-' : '';
            %>
              <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <div class="fw-semibold"><%= type %></div>
                    <small class="text-muted d-block"><%= details %></small>
                    <small class="text-muted"><%= transactionCreated(t) %></small>
                  </div>
                  <div class="text-end">
                    <span class="fw-bold <%= cls %>"><%= sign %><%= formatNaira(Math.abs(amt)) %></span>
                    <br>
                    <span class="badge-soft <%= transactionStatusClass(t.status) %>"><%= t.status %></span>
                  </div>
                </div>
              </div>
            <% } } %>
          </div>
        </div>

        <!-- Support Card -->
        <div class="card mt-3 bg-primary bg-opacity-10 border-0">
          <div class="card-body">
            <div class="d-flex align-items-center gap-3">
              <i class="bi bi-headset fs-1 text-primary"></i>
              <div>
                <h6 class="fw-bold mb-1">Need Help?</h6>
                <p class="small text-muted mb-2">Our support team is available 24/7</p>
                <a href="/support" class="btn btn-sm btn-primary">
                  <i class="bi bi-chat-dots me-1"></i> Contact Support
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

