        <!-- Recent Activity -->
        <div class="card">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong class="small">Recent Activity</strong>
            <a href="/dashboard/history" class="small text-decoration-none">See all</a>
          </div>
          <div class="list-group list-group-flush">
            <% if (!transactions || transactions.length === 0) { %>
              <div class="list-group-item text-center py-4 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                <small>No transactions yet</small>
              </div>
            <% } else {
              const recent = transactions.slice(0, 6);
              for (let i = 0; i < recent.length; i++) {
                const t = recent[i];
                const amt = amountNaira(t);
                const isCredit = t.type === 'credit' || amt > 0;
            %>
              <div class="list-group-item py-2 px-3">
                <div class="d-flex justify-content-between align-items-start">
                  <div class="me-2" style="min-width:0;">
                    <div class="fw-semibold small text-truncate"><%= transactionType(t) %></div>
                    <div class="text-muted" style="font-size:0.78rem;" title="<%= transactionDetails(t) %>">
