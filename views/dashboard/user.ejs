                    <span class="badge-soft <%= transactionStatusClass(t.status) %>" style="font-size:0.7rem;"><%= t.status %></span>
                  </div>
                </div>
              </div>
            <% } } %>
          </div>
        </div>

        <!-- Support -->
        <div class="card mt-3 p-3 bg-primary bg-opacity-10 border-0">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-headset fs-2 text-primary"></i>
