  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="tvPackagesModalLabel">
          <i class="bi bi-grid me-2 text-primary"></i>
          Available TV Packages
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <!-- Customer Info -->
        <div class="alert alert-success" id="modalCustomerInfo" style="display: none;">
          <div class="d-flex align-items-center">
            <i class="bi bi-person-circle fs-4 me-3"></i>
            <div>
              <strong id="modalCustomerName">Customer Name</strong>
              <br>
              <small>Smartcard: <span id="modalSmartcardNumber">0000000000</span></small>
            </div>
          </div>
        </div>
        
        <!-- Packages Grid -->
        <div class="package-grid" id="tvPackagesGrid">
          <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">Loading packages...</span>
            </div>
            <p class="mt-3 text-muted">Loading available packages...</p>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary" id="selectPackageBtn" disabled>
          <i class="bi bi-check-circle me-1"></i> Select Package
        </button>
      </div>
    </div>
  </div>
</div>

<!-- TOAST NOTIFICATION -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080">
  <div id="toast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
      <div class="toast-body" id="toastBody"></div>
      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
  </div>
</div>

<!-- SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
(function() {
  'use strict';
  
  // ==================== UTILITIES ====================
  const log = (...args) => console.log('[Dashboard]', ...args);
  
  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    const toastBody = document.getElementById('toastBody');
    
    if (!toast || !toastBody) return;
    
    toastBody.textContent = message;
    toast.className = `toast align-items-center border-0 text-bg-${type}`;
    
    const bsToast = new bootstrap.Toast(toast, {
      autohide: true,
      delay: 5000
    });
    bsToast.show();
  }
  
  function formatNaira(amount) {
    return '₦' + Number(amount).toLocaleString('en-NG', {
      minimumFractionDigits: 2,
      maximumFractionDigits: 2
    });
  }
  
  function parseNaira(text) {
    return parseFloat(String(text).replace(/[^\d.-]/g, '')) || 0;
  }
  
  function updateBalance(newBalance) {
    const ids = ['bigBalance', 'navBalance', 'navBalanceMobile'];
    for (let i = 0; i < ids.length; i++) {
      const el = document.getElementById(ids[i]);
      if (el) {
        el.textContent = formatNaira(newBalance);
      }
    }
  }
  
  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }
  
  async function handleResponse(response) {
    const contentType = response.headers.get('content-type');
    if (contentType && contentType.includes('application/json')) {
      return await response.json();
    }
    const text = await response.text();
    try {
      return JSON.parse(text);
    } catch {
      return { ok: false, error: text };
    }
  }
  
  // ==================== TV PACKAGES ====================
  let currentTvPackages = [];
  let selectedPackage = null;
  
  async function loadTvPackages(provider, smartcard, showInModal = false) {
    const pkgSelect = document.getElementById('tvPackageSelect');
    const amountInput = document.getElementById('tvAmountInput');
    const submitBtn = document.getElementById('tvSubmitBtn');
    const statusAlert = document.getElementById('tvStatusAlert');
    const statusMessage = document.getElementById('tvStatusMessage');
    const customerInfo = document.getElementById('tvCustomerInfo');
    const customerName = document.getElementById('customerNameText');
    const verifyBtn = document.getElementById('verifySmartcardBtn');
    
    if (showInModal) {
      const packagesGrid = document.getElementById('tvPackagesGrid');
      packagesGrid.innerHTML = `
        <div class="text-center py-5">
          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading packages...</span>
          </div>
          <p class="mt-3 text-muted">Loading available packages...</p>
        </div>
      `;
    } else {
      if (statusAlert && statusMessage) {
        statusAlert.style.display = 'block';
        statusAlert.className = 'alert alert-info';
        statusMessage.textContent = 'Verifying smartcard...';
      }
      
      if (verifyBtn) {
        verifyBtn.disabled = true;
        verifyBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Verifying';
      }
    }
    
    try {
      const response = await fetch(`/api/bills/tv/packages?provider=${encodeURIComponent(provider)}&smartcard=${encodeURIComponent(smartcard)}`, {
        credentials: 'same-origin'
      });
      
      const data = await handleResponse(response);
      
      if (!response.ok || data.error) {
        throw new Error(data.error || 'Failed to load packages');
      }
      
      currentTvPackages = data.packages || [];
      
      // Update customer info
      if (data.customerName) {
        if (!showInModal) {
          customerName.textContent = data.customerName;
          customerInfo.style.display = 'block';
        }
        
        // Update modal customer info
        const modalCustomerInfo = document.getElementById('modalCustomerInfo');
        const modalCustomerName = document.getElementById('modalCustomerName');
        const modalSmartcard = document.getElementById('modalSmartcardNumber');
        
        if (modalCustomerInfo && modalCustomerName && modalSmartcard) {
          modalCustomerName.textContent = data.customerName;
          modalSmartcard.textContent = smartcard;
          modalCustomerInfo.style.display = 'block';
        }
      }
      
      if (showInModal) {
        displayPackagesInModal(currentTvPackages);
      } else {
        updatePackageSelect(currentTvPackages);
      }
      
      if (!showInModal) {
        pkgSelect.disabled = false;
        submitBtn.disabled = currentTvPackages.length === 0;
        
        if (currentTvPackages.length > 0) {
          if (pkgSelect.options.length > 1) {
            pkgSelect.value = currentTvPackages[0].code;
            amountInput.value = currentTvPackages[0].amount;
          }
          
          statusMessage.textContent = `Found ${currentTvPackages.length} packages`;
          statusAlert.className = 'alert alert-success';
        } else {
          statusMessage.textContent = 'No packages available';
          statusAlert.className = 'alert alert-warning';
        }
      }
      
      if (verifyBtn) {
        verifyBtn.disabled = false;
        verifyBtn.innerHTML = '<i class="bi bi-check-circle"></i> Verified';
        verifyBtn.className = 'btn btn-success';
      }
      
    } catch (error) {
      console.error('TV packages error:', error);
      
      if (showInModal) {
        const grid = document.getElementById('tvPackagesGrid');
        if (grid) {
          grid.innerHTML = `
            <div class="text-center py-5">
              <i class="bi bi-exclamation-circle text-danger fs-1 mb-3"></i>
              <p class="text-danger">${escapeHtml(error.message)}</p>
              <button class="btn btn-outline-primary" onclick="location.reload()">Try Again</button>
            </div>
          `;
        }
      } else {
        if (statusAlert && statusMessage) {
          statusMessage.textContent = error.message;
          statusAlert.className = 'alert alert-danger';
        }
        
        if (verifyBtn) {
          verifyBtn.disabled = false;
          verifyBtn.innerHTML = '<i class="bi bi-exclamation-triangle"></i> Error';
          verifyBtn.className = 'btn btn-danger';
        }
      }
    }
  }
  
  function displayPackagesInModal(packages) {
    const grid = document.getElementById('tvPackagesGrid');
    const selectBtn = document.getElementById('selectPackageBtn');
    
    if (!grid) return;
    
    if (!packages || packages.length === 0) {
      grid.innerHTML = `
        <div class="text-center py-5">
          <i class="bi bi-info-circle text-muted fs-1 mb-3"></i>
          <p class="text-muted">No packages available</p>
        </div>
      `;
      if (selectBtn) selectBtn.disabled = true;
      return;
    }
    
    grid.innerHTML = '';
    selectedPackage = null;
    if (selectBtn) selectBtn.disabled = true;
    
    for (let i = 0; i < packages.length; i++) {
      const pkg = packages[i];
      const div = document.createElement('div');
      div.className = 'package-item';
      div.dataset.code = pkg.code;
      div.dataset.amount = pkg.amount;
      div.dataset.label = pkg.label;
      
      div.innerHTML = `
        <div class="d-flex justify-content-between align-items-start mb-2">
          <h6 class="fw-bold mb-0">${escapeHtml(pkg.label)}</h6>
          <span class="fw-bold text-success">${formatNaira(pkg.amount)}</span>
        </div>
        <div class="small text-muted mb-2">Code: ${escapeHtml(pkg.code)}</div>
        <button class="btn btn-outline-primary btn-sm w-100 select-package-btn">
          <i class="bi bi-check-circle me-1"></i> Select
        </button>
      `;
      
      grid.appendChild(div);
    }
    
    // Add click handlers
    const items = document.querySelectorAll('.package-item');
    for (let i = 0; i < items.length; i++) {
      const item = items[i];
      item.addEventListener('click', function(e) {
        if (!e.target.closest('.select-package-btn')) {
          selectPackageInModal(item.dataset.code);
        }
      });
    }
    
    const btns = document.querySelectorAll('.select-package-btn');
    for (let i = 0; i < btns.length; i++) {
      const btn = btns[i];
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const code = btn.closest('.package-item').dataset.code;
        selectPackageInModal(code);
      });
    }
  }
  
  function selectPackageInModal(code) {
    const items = document.querySelectorAll('.package-item');
    for (let i = 0; i < items.length; i++) {
      items[i].classList.remove('selected');
    }
    
    const selected = document.querySelector(`.package-item[data-code="${code}"]`);
    if (selected) {
      selected.classList.add('selected');
      for (let i = 0; i < currentTvPackages.length; i++) {
        if (currentTvPackages[i].code === code) {
          selectedPackage = currentTvPackages[i];
          break;
        }
      }
      const selectBtn = document.getElementById('selectPackageBtn');
      if (selectBtn) selectBtn.disabled = false;
    }
  }
  
  function updatePackageSelect(packages) {
    const select = document.getElementById('tvPackageSelect');
    const amountInput = document.getElementById('tvAmountInput');
    
    if (!select) return;
    
    select.innerHTML = '<option value="">Select a package</option>';
    
    for (let i = 0; i < packages.length; i++) {
      const pkg = packages[i];
      const option = document.createElement('option');
      option.value = pkg.code;
      option.textContent = `${pkg.label} - ${formatNaira(pkg.amount)}`;
      option.dataset.amount = pkg.amount;
      select.appendChild(option);
    }
    
    // Remove existing listener and add new one
    select.removeEventListener('change', handlePackageChange);
    select.addEventListener('change', handlePackageChange);
  }
  
  function handlePackageChange() {
    const select = document.getElementById('tvPackageSelect');
    const amountInput = document.getElementById('tvAmountInput');
    const selected = select.options[select.selectedIndex];
    if (selected && selected.dataset.amount) {
      amountInput.value = selected.dataset.amount;
    }
  }
  
  // ==================== DATA PLANS ====================
  async function loadDataPlans(network) {
    const btn = document.getElementById('dataPlanButton');
    const menu = document.getElementById('dataPlanMenu');
    const hidden = document.getElementById('dataPlanValue');
    
    if (!btn || !menu) return;
    
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Loading...';
    btn.disabled = true;
    
    try {
      const response = await fetch(`/api/bills/data/plans?network=${encodeURIComponent(network)}`, {
        credentials: 'same-origin'
      });
      
      const plans = await handleResponse(response);
      
      if (!Array.isArray(plans) || plans.length === 0) {
        throw new Error('No plans available');
      }
      
      menu.innerHTML = '';
      
      for (let i = 0; i < plans.length; i++) {
        const plan = plans[i];
        const item = document.createElement('li');
        item.innerHTML = `
          <a class="dropdown-item plan-item d-flex align-items-center gap-3" href="#" data-code="${plan.code}" data-amount="${plan.amount}">
            <div class="network-icon">
              <i class="bi bi-wifi ${network === 'mtn' ? 'text-success' : network === 'glo' ? 'text-danger' : 'text-primary'}"></i>
            </div>
            <div class="flex-grow-1">
              <div class="fw-semibold">${escapeHtml(plan.label)}</div>
              <small class="text-muted">Code: ${plan.code}</small>
            </div>
            <div class="fw-bold text-success">${formatNaira(plan.amount)}</div>
          </a>
        `;
        
        const link = item.querySelector('a');
        link.addEventListener('click', function(e) {
          e.preventDefault();
          
          const activeItems = document.querySelectorAll('#dataPlanMenu .plan-item');
          for (let j = 0; j < activeItems.length; j++) {
            activeItems[j].classList.remove('active');
          }
          link.classList.add('active');
          
          if (hidden) hidden.value = plan.code;
          btn.innerHTML = `
            <span class="network-icon-sm me-2">
              <i class="bi bi-wifi"></i>
            </span>
            <span>${escapeHtml(plan.label)} - ${formatNaira(plan.amount)}</span>
          `;
          btn.disabled = false;
        });
        
        menu.appendChild(item);
        
        if (i < plans.length - 1) {
          menu.appendChild(document.createElement('hr')).className = 'dropdown-divider';
        }
      }
      
      btn.innerHTML = 'Select Data Plan';
      btn.disabled = false;
      
    } catch (error) {
      console.error('Load data plans error:', error);
      menu.innerHTML = `
        <li><span class="dropdown-item-text text-danger">${escapeHtml(error.message)}</span></li>
      `;
      btn.innerHTML = 'Select Data Plan';
      btn.disabled = false;
    }
  }
  
  // ==================== FORM SUBMISSION ====================
  async function submitForm(form, endpoint, formName) {
    if (!form.checkValidity()) {
      form.classList.add('was-validated');
      return false;
    }
    
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    const statusAlert = form.querySelector('.status-alert');
    const statusMessage = form.querySelector('.status-alert span');
    
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Processing...';
    
    if (statusAlert) {
      statusAlert.style.display = 'block';
      statusAlert.className = 'alert alert-info';
      if (statusMessage) statusMessage.textContent = 'Processing your request...';
    }
    
    try {
      const formData = new FormData(form);
      const response = await fetch(endpoint, {
        method: 'POST',
        body: formData,
        credentials: 'same-origin'
      });
      
      const data = await handleResponse(response);
      
      if (!response.ok || data.error) {
        throw new Error(data.error || 'Request failed');
      }
      
      // Check if confirmation needed
      if (data.preview) {
        showConfirmationModal(data, form, endpoint, formName);
        return;
      }
      
      // Success
      showToast(`${formName} successful!`, 'success');
      
      if (data.new_balance) {
        updateBalance(data.new_balance);
      }
      
      // Reset form
      form.reset();
      form.classList.remove('was-validated');
      
      if (statusAlert) {
        statusAlert.className = 'alert alert-success';
        if (statusMessage) statusMessage.textContent = 'Transaction completed successfully!';
      }
      
      // Reload page after 2 seconds to show updated data
      setTimeout(function() { location.reload(); }, 2000);
      
    } catch (error) {
      console.error(`${formName} error:`, error);
      
      if (statusAlert) {
        statusAlert.className = 'alert alert-danger';
        if (statusMessage) statusMessage.textContent = error.message;
      }
      
      showToast(error.message, 'danger');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  }
  
  function showConfirmationModal(data, form, endpoint, formName) {
    // Create modal dynamically
    const modalHtml = `
      <div class="modal fade" id="confirmationModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Confirm ${formName} Purchase</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                ${escapeHtml(data.message || `Confirm ${formName} purchase`)}
              </div>
              
              <div class="card bg-light">
                <div class="card-body">
                  <h6 class="card-title">Transaction Details</h6>
                  <dl class="row mb-0">
                    ${data.network ? `
                      <dt class="col-sm-4">Network</dt>
                      <dd class="col-sm-8">${escapeHtml(data.network)}</dd>
                    ` : ''}
                    ${data.phone ? `
                      <dt class="col-sm-4">Phone</dt>
                      <dd class="col-sm-8">${escapeHtml(data.phone)}</dd>
                    ` : ''}
                    ${data.smartcard ? `
                      <dt class="col-sm-4">Smartcard</dt>
                      <dd class="col-sm-8">${escapeHtml(data.smartcard)}</dd>
                    ` : ''}
                    ${data.plan ? `
                      <dt class="col-sm-4">Plan</dt>
                      <dd class="col-sm-8">${escapeHtml(data.plan)}</dd>
                    ` : ''}
                    ${data.amount ? `
                      <dt class="col-sm-4">Amount</dt>
                      <dd class="col-sm-8 fw-bold text-success">${formatNaira(data.amount)}</dd>
                    ` : ''}
                  </dl>
                </div>
              </div>
              
              <div class="alert alert-warning mt-3 mb-0">
                <i class="bi bi-exclamation-triangle me-2"></i>
                This action cannot be undone.
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
              <button type="button" class="btn btn-primary" id="confirmBtn">Confirm Purchase</button>
            </div>
          </div>
        </div>
      </div>
    `;
    
    // Remove existing modal if any
    const existing = document.getElementById('confirmationModal');
    if (existing) existing.remove();
    
    // Add modal to DOM
    document.body.insertAdjacentHTML('beforeend', modalHtml);
    
    const modal = new bootstrap.Modal(document.getElementById('confirmationModal'));
    modal.show();
    
    document.getElementById('confirmBtn').addEventListener('click', async function() {
      modal.hide();
      
      const formData = new FormData(form);
      formData.append('confirm', 'true');
      
      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });
        
        const data = await handleResponse(response);
        
        if (data.error) throw new Error(data.error);
        
        showToast(`${formName} successful!`, 'success');
        
        if (data.new_balance) {
          updateBalance(data.new_balance);
        }
        
        form.reset();
        form.classList.remove('was-validated');
        
        setTimeout(function() { location.reload(); }, 2000);
        
      } catch (error) {
        console.error('Confirmation error:', error);
        showToast(error.message, 'danger');
      }
    });
  }
  
  // ==================== WALLET FUNDING ====================
  function wireFundForm() {
    const form = document.getElementById('fundForm');
    if (!form) return;
    
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
      }
      
      const submitBtn = document.getElementById('fundSubmitBtn');
      const originalText = submitBtn.innerHTML;
      
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Processing...';
      
      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });
        
        const data = await handleResponse(response);
        
        if (data.error) throw new Error(data.error);
        
        if (data.link) {
          showToast('Redirecting to payment gateway...', 'info');
          setTimeout(function() {
            window.location.href = data.link;
          }, 1000);
        } else {
          throw new Error('No payment link received');
        }
        
      } catch (error) {
        console.error('Fund wallet error:', error);
        showToast(error.message, 'danger');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  }
  
  // ==================== WITHDRAWAL ====================
  function wireWithdrawForm() {
    const form = document.getElementById('withdrawForm');
    const bankSelect = document.getElementById('bankSelect');
    const otherBankField = document.getElementById('otherBankField');
    
    if (bankSelect) {
      bankSelect.addEventListener('change', function() {
        if (bankSelect.value === 'Other') {
          otherBankField.style.display = 'block';
        } else {
          otherBankField.style.display = 'none';
        }
      });
    }
    
    if (!form) return;
    
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      if (!form.checkValidity()) {
        form.classList.add('was-validated');
        return;
      }
      
      const submitBtn = document.getElementById('withdrawSubmitBtn');
      const originalText = submitBtn.innerHTML;
      
      // Handle other bank
      if (bankSelect.value === 'Other') {
        const otherBank = form.querySelector('[name="otherBank"]').value;
        if (!otherBank) {
          showToast('Please enter bank name', 'danger');
          return;
        }
        form.querySelector('[name="bank"]').value = otherBank;
      }
      
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Processing...';
      
      try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });
        
        const data = await handleResponse(response);
        
        if (data.error) throw new Error(data.error);
        
        showToast('Withdrawal request submitted!', 'success');
        
        // Close modal and reset
        setTimeout(function() {
          const modal = bootstrap.Modal.getInstance(document.getElementById('withdrawModal'));
          if (modal) modal.hide();
          form.reset();
          form.classList.remove('was-validated');
        }, 2000);
        
      } catch (error) {
        console.error('Withdraw error:', error);
        showToast(error.message, 'danger');
      } finally {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    });
  }
  
  // ==================== INITIALIZATION ====================
  // Wait for DOM to be fully loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDashboard);
  } else {
    initDashboard();
  }
  
  function initDashboard() {
    log('Dashboard initialized');
    
    // Wire forms
    wireFundForm();
    wireWithdrawForm();
    
    // Wire bill forms
    const airtimeForm = document.getElementById('airtimeForm');
    if (airtimeForm) {
      airtimeForm.addEventListener('submit', function(e) {
        e.preventDefault();
        submitForm(airtimeForm, airtimeForm.action, 'Airtime');
      });
    }
    
    const dataForm = document.getElementById('dataForm');
    if (dataForm) {
      dataForm.addEventListener('submit', function(e) {
        e.preventDefault();
        submitForm(dataForm, dataForm.action, 'Data');
      });
    }
    
    const electricityForm = document.getElementById('electricityForm');
    if (electricityForm) {
      electricityForm.addEventListener('submit', function(e) {
        e.preventDefault();
        submitForm(electricityForm, electricityForm.action, 'Electricity');
      });
    }
    
    const tvForm = document.getElementById('tvForm');
    if (tvForm) {
      tvForm.addEventListener('submit', function(e) {
        e.preventDefault();
        submitForm(tvForm, tvForm.action, 'TV');
      });
    }
    
    // Data network change
    const networkSelect = document.getElementById('dataNetworkSelect');
    if (networkSelect) {
      networkSelect.addEventListener('change', function() {
        if (networkSelect.value) {
          loadDataPlans(networkSelect.value);
        }
      });
    }
    
    // TV verification
    const verifyBtn = document.getElementById('verifySmartcardBtn');
    const providerSelect = document.getElementById('tvProviderSelect');
    const smartcardInput = document.getElementById('tvSmartcardInput');
    
    if (verifyBtn && providerSelect && smartcardInput) {
      verifyBtn.addEventListener('click', function() {
        const provider = providerSelect.value;
        const smartcard = smartcardInput.value.trim();
        
        if (!provider) {
          showToast('Please select a provider', 'danger');
          providerSelect.focus();
          return;
        }
        
        if (!smartcard || smartcard.length < 6) {
          showToast('Please enter a valid smartcard number', 'danger');
          smartcardInput.focus();
          return;
        }
        
        loadTvPackages(provider, smartcard);
      });
    }
    
    // View all packages button
    const viewPackagesBtn = document.querySelector('[data-bs-target="#tvPackagesModal"]');
    if (viewPackagesBtn && providerSelect && smartcardInput) {
      viewPackagesBtn.addEventListener('click', function() {
        const provider = providerSelect.value;
        const smartcard = smartcardInput.value.trim();
        
        if (!provider) {
          showToast('Please select a provider', 'danger');
          return;
        }
        
        if (!smartcard || smartcard.length < 6) {
          showToast('Please enter a valid smartcard number', 'danger');
          return;
        }
        
        loadTvPackages(provider, smartcard, true);
      });
    }
    
    // Select package button
    const selectPackageBtn = document.getElementById('selectPackageBtn');
    if (selectPackageBtn) {
      selectPackageBtn.addEventListener('click', function() {
        if (!selectedPackage) {
          showToast('Please select a package', 'danger');
          return;
        }
        
        const pkgSelect = document.getElementById('tvPackageSelect');
        const amountInput = document.getElementById('tvAmountInput');
        const submitBtn = document.getElementById('tvSubmitBtn');
        
        if (pkgSelect) pkgSelect.value = selectedPackage.code;
        if (amountInput) amountInput.value = selectedPackage.amount;
        if (submitBtn) submitBtn.disabled = false;
        
        // Close modal
        const modal = bootstrap.Modal.getInstance(document.getElementById('tvPackagesModal'));
        if (modal) modal.hide();
        
        showToast(`Selected: ${selectedPackage.label}`, 'success');
      });
    }
    
    // Smooth scroll to services
    const actionLinks = document.querySelectorAll('.row.k .card a');
    for (let i = 0; i < actionLinks.length; i++) {
      const link = actionLinks[i];
      link.addEventListener('click', function(e) {
        e.preventDefault();
        const targetId = link.getAttribute('href');
        if (targetId && targetId.startsWith('#')) {
          const tab = document.querySelector(`[data-bs-target="${targetId}"]`);
          if (tab) {
            const bsTab = new bootstrap.Tab(tab);
            bsTab.show();
            
            document.getElementById('services').scrollIntoView({
              behavior: 'smooth',
              block: 'start'
            });
          }
        }
      });
    }
    
    // Clean URL params
    if (window.location.search.includes('payment_success') || 
        window.location.search.includes('payment_failed')) {
      window.history.replaceState({}, document.title, window.location.pathname);
    }
  }
})();
</script>

