<%
const user = typeof userData !== 'undefined' ? userData
           : typeof user    !== 'undefined' ? user
           : { id: 0, name: '', email: '' };

const beneficiaries = typeof beneficiariesData !== 'undefined' ? beneficiariesData
                    : typeof beneficiaries      !== 'undefined' ? beneficiaries
                    : [];

const _csrf = typeof csrfToken !== 'undefined' ? csrfToken : '';

const formatDate = (dateStr) => {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    return d.toLocaleDateString('en-NG', { year:'numeric', month:'short', day:'numeric' });
};

const esc = (text) => {
    if (!text) return '';
    return String(text)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
};

const typeIcon = (t) => ({
    data:        'bi-wifi',
    airtime:     'bi-phone-fill',
    electricity: 'bi-plug',
    tv:          'bi-tv'
}[(t||'').toLowerCase()] || 'bi-person');

const typeLabel = (t) => ({
    data:        'Data',
    airtime:     'Airtime',
    electricity: 'Electricity',
    tv:          'TV'
}[(t||'').toLowerCase()] || t || '—');

const TYPES = ['airtime','data','electricity','tv'];
%>
<%- include('../../partials/header') %>

<style>
  :root{--jn-primary:#EF5134;--jn-primary-600:#e3472b}
  body{background:#f8fafc;font-family:'Poppins',sans-serif}
  .navbar{background:rgba(11,18,32,.95);backdrop-filter:blur(10px);padding:.75rem 0}
  .navbar-brand{font-weight:800;font-size:1.5rem;color:white!important}
  .navbar-brand span{color:var(--jn-primary)}
  .nav-link{color:rgba(255,255,255,.8)!important;font-weight:500}
  .nav-link:hover,.nav-link.active{color:white!important}
  #header{position:relative;padding:3rem 0;margin-bottom:2rem;
    background:linear-gradient(135deg,#0b1220,#1a2639)}
  #header .container{position:relative;z-index:1;color:white}
  .card{border:none;border-radius:16px;box-shadow:0 1px 3px rgba(0,0,0,.05);transition:all .2s}
  .card:hover{box-shadow:0 4px 12px rgba(0,0,0,.08)}
  .btn-theme{background:var(--jn-primary);border:none;border-radius:10px;font-weight:600;
    padding:.6rem 1.5rem;color:white;transition:all .2s}
  .btn-theme:hover{background:var(--jn-primary-600);transform:translateY(-2px);color:white}
  .form-control,.form-select{border-radius:10px;border:1px solid #e2e8f0}
  .form-control:focus,.form-select:focus{border-color:var(--jn-primary);
    box-shadow:0 0 0 3px rgba(239,81,52,.15)}
  .type-badge{display:inline-flex;align-items:center;gap:.5rem;padding:.35rem 1rem;
    background:#f1f5f9;border-radius:100px;font-size:.85rem;font-weight:500}
  .beneficiary-card{border-left:3px solid var(--jn-primary)}
  .empty-state{padding:4rem 1rem;text-align:center}
  .empty-state i{font-size:4rem;color:#cbd5e1;margin-bottom:1rem;display:block}
  .spinner-border-sm{width:1rem;height:1rem;border-width:2px}
  .toast-container{z-index:1060}
</style>

<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/"><span>Moz</span>Aic</a>
    <button class="navbar-toggler text-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/dashboard/user">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/dashboard/history">History</a></li>
        <li class="nav-item"><a class="nav-link active" href="/dashboard/beneficiaries">Beneficiaries</a></li>
        <li class="nav-item"><a class="nav-link" href="/dashboard/referrals">Referrals</a></li>
      </ul>
      <div class="d-flex gap-2">
        <span class="badge bg-white text-dark d-none d-md-block px-3 py-2">
          <i class="bi bi-person-circle me-1"></i><%= esc(user.name || user.email || '') %>
        </span>
        <form method="POST" action="/auth/logout" class="d-inline">
          <input type="hidden" name="_csrf" value="<%= _csrf %>">
          <button type="submit" class="btn btn-outline-light btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i> Logout
          </button>
        </form>
      </div>
    </div>
  </div>
</nav>

<header id="header">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-8">
        <h1 class="fw-bold mb-2">Beneficiaries</h1>
        <p class="lead mb-0 opacity-75">Save frequently used payment details for quick checkout</p>
      </div>
      <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <span class="badge bg-white text-dark px-3 py-2">
          <i class="bi bi-people me-1"></i>
          <span id="totalCount"><%= beneficiaries.length %></span> saved
        </span>
      </div>
    </div>
  </div>
</header>

<main class="py-4">
  <div class="container">

    <!-- Add Form -->
    <div class="card p-4 mb-4">
      <h5 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2 text-primary"></i>Add New Beneficiary</h5>
      <form id="addForm" class="row g-3 needs-validation" novalidate>
        <input type="hidden" name="_csrf" value="<%= _csrf %>">

        <div class="col-md-3">
          <label class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
          <%# option values are lowercase to match Beneficiary model enum %>
          <select class="form-select" name="type" required>
            <option value="">Select type...</option>
            <option value="airtime">📱 Airtime</option>
            <option value="data">🌐 Data</option>
            <option value="electricity">⚡ Electricity</option>
            <option value="tv">📺 Cable TV</option>
          </select>
          <div class="invalid-feedback">Please select a type.</div>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Label / Nickname <span class="text-danger">*</span></label>
          <input class="form-control" name="label" placeholder="e.g. Mum's MTN" required>
          <div class="invalid-feedback">Please enter a label.</div>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Value <span class="text-danger">*</span></label>
          <input class="form-control" name="value" placeholder="Phone / Meter / IUC number" required>
          <div class="invalid-feedback">Please enter a value.</div>
        </div>

        <div class="col-md-3 d-flex align-items-end">
          <button class="btn btn-theme w-100" type="submit" id="addBtn">
            <i class="bi bi-plus-lg me-1"></i> Add Beneficiary
          </button>
        </div>
      </form>
    </div>

    <!-- Search & Filter -->
    <div class="card p-3 mb-4">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" id="searchInput" placeholder="Search by label or value...">
          </div>
        </div>
        <div class="col-md-6">
          <select class="form-select" id="filterType">
            <option value="">All Types</option>
            <option value="airtime">Airtime</option>
            <option value="data">Data</option>
            <option value="electricity">Electricity</option>
            <option value="tv">TV</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Beneficiary Cards -->
    <div id="beneficiariesContainer">

      <% if (!beneficiaries || beneficiaries.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-people"></i>
          <h5 class="mt-2">No beneficiaries yet</h5>
          <p class="text-muted">Add your first beneficiary using the form above.</p>
        </div>

      <% } else { %>

        <% TYPES.forEach(function(type) {
             var items = beneficiaries.filter(function(b){ return (b.type||'').toLowerCase() === type; });
             if (!items.length) return;
        %>
          <div class="mb-4 type-section" data-type="<%= type %>">
            <h6 class="fw-bold mb-3">
              <i class="<%= typeIcon(type) %> me-2 text-primary"></i>
              <%= typeLabel(type) %>
              <span class="badge bg-light text-dark ms-2"><%= items.length %></span>
            </h6>
            <div class="row g-3">
              <% items.forEach(function(b) { %>
                <div class="col-md-6 col-lg-4 ben-item"
                     data-id="<%= b.id %>"
                     data-type="<%= (b.type||'').toLowerCase() %>"
                     data-label="<%= esc((b.label||'').toLowerCase()) %>"
                     data-value="<%= esc((b.value||'').toLowerCase()) %>">
                  <div class="card p-3 h-100 beneficiary-card">
                    <div class="d-flex justify-content-between align-items-start">
                      <div class="flex-grow-1 me-2">
                        <div class="d-flex align-items-center gap-2 mb-1">
                          <span class="type-badge">
                            <i class="<%= typeIcon(b.type) %>"></i>
                            <%= typeLabel(b.type) %>
                          </span>
                          <% if (b.isFavorite) { %>
                            <i class="bi bi-star-fill text-warning small"></i>
                          <% } %>
                        </div>
                        <h6 class="fw-bold mb-1"><%= esc(b.label) %></h6>
                        <p class="small text-muted mb-1"><%= esc(b.value) %></p>
                        <% if (b.last_used) { %>
                          <small class="text-muted">
                            <i class="bi bi-clock me-1"></i><%= formatDate(b.last_used) %>
                          </small>
                        <% } %>
                      </div>
                      <div class="d-flex flex-column gap-1">
                        <button class="btn btn-sm btn-outline-warning fav-btn"
                                data-id="<%= b.id %>"
                                title="<%= b.isFavorite ? 'Remove favourite' : 'Add to favourites' %>">
                          <i class="bi bi-star<%= b.isFavorite ? '-fill' : '' %>"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger del-btn"
                                data-id="<%= b.id %>"
                                data-label="<%= esc(b.label) %>"
                                title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% }); %>

      <% } %>

    </div><!-- #beneficiariesContainer -->
  </div>
</main>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Beneficiary
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Delete <strong id="deleteLabel"></strong>? This cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
      </div>
    </div>
  </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    'use strict';

    const CSRF = '<%= _csrf %>';

    // ── Toast ─────────────────────────────────────────────────────────────
    function toast(msg, type) {
        type = type || 'success';
        var container = document.querySelector('.toast-container');
        var id  = 'toast-' + Date.now();
        var cls = { success:'text-bg-success', error:'text-bg-danger', warning:'text-bg-warning', info:'text-bg-info' }[type] || 'text-bg-success';
        var ico = { success:'bi-check-circle-fill', error:'bi-exclamation-triangle-fill', warning:'bi-exclamation-circle-fill', info:'bi-info-circle-fill' }[type] || 'bi-bell-fill';
        container.insertAdjacentHTML('beforeend',
            '<div id="'+id+'" class="toast align-items-center '+cls+' border-0" role="alert">' +
              '<div class="d-flex">' +
                '<div class="toast-body d-flex align-items-center gap-2">' +
                  '<i class="bi '+ico+'"></i><span>'+escHtml(msg)+'</span>' +
                '</div>' +
                '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>' +
              '</div>' +
            '</div>'
        );
        var el = document.getElementById(id);
        new bootstrap.Toast(el, { autohide: true, delay: 4000 }).show();
        el.addEventListener('hidden.bs.toast', function(){ el.remove(); });
    }

    function escHtml(s) {
        var d = document.createElement('div');
        d.textContent = String(s || '');
        return d.innerHTML;
    }

    function setLoading(btn, loading, label) {
        if (loading) {
            btn.disabled = true;
            btn._orig = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + (label || 'Saving...');
        } else {
            btn.disabled = false;
            btn.innerHTML = btn._orig || btn.innerHTML;
        }
    }

    // ── ADD FORM ──────────────────────────────────────────────────────────
    document.getElementById('addForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        var form = e.target;
        if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

        var btn = document.getElementById('addBtn');
        setLoading(btn, true);

        try {
            var fd = new FormData(form);
            fd.set('_csrf', CSRF);

            var res  = await fetch('/api/beneficiaries', {
                method:      'POST',
                body:        fd,
                credentials: 'same-origin',
                headers:     { 'X-CSRF-Token': CSRF }
            });
            var data = await res.json();

            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed to add beneficiary');

            toast('Beneficiary saved!', 'success');
            form.reset();
            form.classList.remove('was-validated');
            setTimeout(function(){ location.reload(); }, 1000);

        } catch (err) {
            toast(err.message, 'error');
            setLoading(btn, false);
        }
    });

    // ── SEARCH & FILTER ───────────────────────────────────────────────────
    function applyFilter() {
        var q    = (document.getElementById('searchInput').value || '').toLowerCase();
        var type = (document.getElementById('filterType').value  || '').toLowerCase();

        document.querySelectorAll('.ben-item').forEach(function(item) {
            var matchType  = !type || item.dataset.type === type;
            var matchQuery = !q    || item.dataset.label.includes(q) || item.dataset.value.includes(q);
            item.style.display = (matchType && matchQuery) ? '' : 'none';
        });

        document.querySelectorAll('.type-section').forEach(function(section) {
            var visible = section.querySelectorAll('.ben-item:not([style*="display: none"])').length;
            section.style.display = visible ? '' : 'none';
        });
    }

    document.getElementById('searchInput').addEventListener('input',  applyFilter);
    document.getElementById('filterType').addEventListener('change', applyFilter);

    // ── FAVOURITE ─────────────────────────────────────────────────────────
    document.addEventListener('click', async function(e) {
        var btn = e.target.closest('.fav-btn');
        if (!btn) return;
        var id = btn.dataset.id;

        try {
            var res  = await fetch('/api/beneficiaries/' + id + '/favorite', {
                method:      'POST',
                credentials: 'same-origin',
                headers:     { 'X-CSRF-Token': CSRF, 'Content-Type': 'application/json' },
                body:        JSON.stringify({ _csrf: CSRF })
            });
            var data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed');

            var icon = btn.querySelector('i');
            icon.className = data.isFavorite ? 'bi bi-star-fill' : 'bi bi-star';
            btn.title = data.isFavorite ? 'Remove favourite' : 'Add to favourites';
            toast(data.message, 'success');
        } catch (err) {
            toast(err.message, 'error');
        }
    });

    // ── DELETE ────────────────────────────────────────────────────────────
    var pendingDeleteId = null;

    document.addEventListener('click', function(e) {
        var btn = e.target.closest('.del-btn');
        if (!btn) return;
        pendingDeleteId = btn.dataset.id;
        document.getElementById('deleteLabel').textContent = btn.dataset.label || 'this beneficiary';
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
        if (!pendingDeleteId) return;
        var btn = document.getElementById('confirmDeleteBtn');
        setLoading(btn, true, 'Deleting...');

        try {
            var res  = await fetch('/api/beneficiaries/' + pendingDeleteId, {
                method:      'DELETE',
                credentials: 'same-origin',
                headers:     { 'X-CSRF-Token': CSRF, 'Content-Type': 'application/json' },
                body:        JSON.stringify({ _csrf: CSRF })
            });
            var data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed to delete');

            var card = document.querySelector('.ben-item[data-id="' + pendingDeleteId + '"]');
            if (card) card.remove();

            var countEl = document.getElementById('totalCount');
            if (countEl) countEl.textContent = Math.max(0, parseInt(countEl.textContent) - 1);

            bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
            toast('Beneficiary deleted', 'success');

        } catch (err) {
            toast(err.message, 'error');
        }

        setLoading(btn, false);
        pendingDeleteId = null;
    });

})();
</script>

<%- include('../../partials/footer') %>
