<header id="header">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-8">
        <h1 class="fw-bold mb-2">Beneficiaries</h1>
        <p class="lead mb-0 opacity-75">Save and manage frequently used payment details</p>
      </div>
      <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <span class="badge bg-white text-dark px-3 py-2">
          <i class="bi bi-people me-1"></i>
          <%= beneficiaries.length %> Saved
        </span>
      </div>
    </div>
  </div>
</header>

<main class="section py-4">
  <div class="container">

    <!-- Add Beneficiary Form -->
    <div class="card p-4 mb-4">
      <h5 class="fw-bold mb-3">
        <i class="bi bi-plus-circle me-2 text-primary"></i>
        Add New Beneficiary
      </h5>
      <form id="addForm" class="row g-3 needs-validation" method="POST" action="/dashboard/beneficiaries" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="col-md-3">
          <label class="form-label fw-semibold">Type</label>
          <select class="form-select" name="type" required>
            <option value="">Select type...</option>
            <option value="Airtime">📱 Airtime</option>
            <option value="Data">🌐 Data</option>
            <option value="Electricity">⚡ Electricity</option>
            <option value="TV">📺 Cable TV</option>
          </select>
          <div class="invalid-feedback">Please select a type.</div>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Label/Nickname</label>
          <input class="form-control" name="label" placeholder="e.g. Mom's MTN" required>
          <div class="invalid-feedback">Please enter a label.</div>
        </div>

        <div class="col-md-4">
          <label class="form-label fw-semibold">Value (Phone/Meter/IUC)</label>
          <input class="form-control" name="value" placeholder="0801 234 5678" required>
          <div class="invalid-feedback">Please enter a value.</div>
        </div>

        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-theme w-100" type="submit" id="addBeneficiaryBtn">
            <i class="bi bi-plus-lg me-1"></i> Add
          </button>
        </div>
      </form>

      <!-- Quick action templates -->
      <div class="quick-actions mt-3">
        <span class="text-muted small me-2">Quick add:</span>
        <a href="javascript:void(0)" class="quick-action-btn" onclick="quickAdd('Airtime', 'MTN', '080')">
          <i class="bi bi-phone me-1"></i> MTN
        </a>
        <a href="javascript:void(0)" class="quick-action-btn" onclick="quickAdd('Airtime', 'GLO', '0805')">
          <i class="bi bi-phone me-1"></i> GLO
        </a>
        <a href="javascript:void(0)" class="quick-action-btn" onclick="quickAdd('Airtime', 'Airtel', '0802')">
          <i class="bi bi-phone me-1"></i> Airtel
        </a>
        <a href="javascript:void(0)" class="quick-action-btn" onclick="quickAdd('Data', 'MTN Data', '080')">
          <i class="bi bi-wifi me-1"></i> MTN Data
        </a>
      </div>
    </div>

    <!-- Search and Filter -->
    <div class="card p-3 mb-4">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control" id="searchInput" placeholder="Search beneficiaries..." value="">
          </div>
        </div>
        <div class="col-md-6">
          <select class="form-select" id="filterType">
            <option value="">All Types</option>
            <option value="Airtime">Airtime</option>
            <option value="Data">Data</option>
            <option value="Electricity">Electricity</option>
            <option value="TV">TV</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Beneficiaries Grid -->
    <div id="beneficiariesContainer">
      <% if (beneficiaries.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-people"></i>
          <h5 class="mt-3">No beneficiaries yet</h5>
          <p class="text-muted mb-3">Add your first beneficiary using the form above</p>
          <button class="btn btn-theme" onclick="document.querySelector('[name=type]').focus()">
            <i class="bi bi-plus-circle me-1"></i> Add Beneficiary
          </button>
        </div>
      <% } else { 
        // Group by type for better organization
        const types = ['Airtime', 'Data', 'Electricity', 'TV'];
        types.forEach(type => {
          const typeBeneficiaries = beneficiaries.filter(b => b.type === type);
          if (typeBeneficiaries.length > 0) { %>
            <div class="mb-4">
              <h6 class="fw-bold mb-3">
                <i class="<%= getTypeIcon(type) %> me-2 text-primary"></i>
                <%= type %>
                <span class="badge bg-light text-dark ms-2"><%= typeBeneficiaries.length %></span>
              </h6>
              <div class="row g-3">
                <% typeBeneficiaries.forEach(b => { %>
                  <div class="col-md-6 col-lg-4 beneficiary-item" data-id="<%= b.id %>" data-type="<%= b.type %>" data-label="<%= b.label.toLowerCase() %>" data-value="<%= b.value.toLowerCase() %>">
                    <div class="card p-3 h-100 beneficiary-card">
                      <div class="d-flex justify-content-between">
                        <div class="flex-grow-1">
                          <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="type-badge">
                              <i class="<%= getTypeIcon(b.type) %>"></i>
                              <%= b.type %>
                            </span>
                            <% if (b.usage_count > 5) { %>
                              <span class="badge bg-warning text-dark" title="Frequently used">
                                <i class="bi bi-star-fill me-1"></i> Frequent
                              </span>
                            <% } %>
                          </div>
                          <h6 class="fw-bold mb-1"><%= escapeHtml(b.label) %></h6>
                          <p class="small text-muted mb-2"><%= escapeHtml(b.value) %></p>
                          <% if (b.last_used) { %>
                            <small class="text-muted">
                              <i class="bi bi-clock-history me-1"></i>
                              Last used: <%= formatDate(b.last_used) %>
                            </small>
                          <% } %>
                          <% if (b.created_at) { %>
                            <div class="small text-muted mt-1">
                              <i class="bi bi-calendar3 me-1"></i>
                              Added: <%= formatDate(b.created_at) %>
                            </div>
                          <% } %>
                        </div>
                        <div class="d-flex flex-column gap-2">
                          <button class="btn btn-sm btn-outline-warning favorite-btn <%= b.isFavorite ? 'active' : '' %>" 
                                  onclick="toggleFavorite('<%= b.id %>')" 
                                  title="<%= b.isFavorite ? 'Remove from favorites' : 'Add to favorites' %>">
                            <i class="bi bi-star<%= b.isFavorite ? '-fill' : '' %>"></i>
                          </button>
                          <div class="btn-group-vertical btn-group-sm">
                            <button class="btn btn-outline-primary edit-btn" data-id="<%= b.id %>" title="Edit">
                              <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger delete-btn" data-id="<%= b.id %>" title="Delete">
                              <i class="bi bi-trash"></i>
                            </button>
                          </div>
                        </div>
                      </div>
                      <div class="mt-2 pt-2 border-top">
                        <small>
                          <a href="/dashboard/user#<%= b.type.toLowerCase() %>" class="text-decoration-none" onclick="useBeneficiary('<%= b.id %>')">
                            <i class="bi bi-arrow-right-circle me-1"></i> Use for payment
                          </a>
                        </small>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            </div>
          <% }
        });
      } %>
    </div>
  </div>
</main>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteModalLabel">
          <i class="bi bi-exclamation-triangle text-danger me-2"></i>
          Confirm Delete
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to delete this beneficiary?</p>
        <p class="small text-muted mb-0" id="deleteBeneficiaryInfo"></p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
      </div>
    </div>
