<%
const user = typeof userData !== 'undefined' ? userData : { id: 0, name: '', email: '' };
const beneficiaries = typeof beneficiariesData !== 'undefined' ? beneficiariesData : [];

// Group beneficiaries by type for organization
const groupedBeneficiaries = beneficiaries.reduce((groups, beneficiary) => {
    const type = beneficiary.type || 'Other';
    if (!groups[type]) groups[type] = [];
    groups[type].push(beneficiary);
    return groups;
}, {});

// Format date helper
const formatDate = (dateStr) => {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return dateStr;
    return date.toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
    });
};

// Escape helper for inline JavaScript
const escapeHtml = (text) => {
    if (!text) return '';
    return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
};

// Get icon for beneficiary type
const getTypeIcon = (type) => {
    const icons = {
        'Data': 'bi-wifi',
        'Airtime': 'bi-phone-fill',
        'Electricity': 'bi-plug',
        'TV': 'bi-tv'
    };
    return icons[type] || 'bi-person';
};
%>
