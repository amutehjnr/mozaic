<header id="header">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-8">
        <h1 class="fw-bold mb-2">Beneficiaries</h1>
        <p class="lead mb-0 opacity-75">Save frequently used payment details for quick checkout</p>
      </div>
      <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <span class="badge bg-white text-dark px-3 py-2">
          <i class="bi bi-people me-1"></i>
          <span id="totalCount"><%= beneficiaries.length %></span> saved
        </span>
      </div>
    </div>
  </div>
</header>

<main class="py-4">
  <div class="container">

    <!-- Add Beneficiary Form -->
    <div class="card p-4 mb-4">
      <h5 class="fw-bold mb-3"><i class="bi bi-plus-circle me-2 text-primary"></i>Add New Beneficiary</h5>
      <%-- FIX: form posts to /api/beneficiaries (absolute path) not dashboard-relative --%>
      <form id="addForm" class="row g-3 needs-validation" novalidate>
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

        <div class="col-md-3">
          <label class="form-label fw-semibold">Type <span class="text-danger">*</span></label>
          <%-- FIX: option values are lowercase to match model enum ['data','airtime','electricity','tv'] --%>
          <select class="form-select" name="type" id="addType" required>
            <option value="">Select type...</option>
            <option value="airtime">📱 Airtime</option>
            <option value="data">🌐 Data</option>
            <option value="electricity">⚡ Electricity</option>
            <option value="tv">📺 Cable TV</option>
          </select>
          <div class="invalid-feedback">Please select a type.</div>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Label / Nickname <span class="text-danger">*</span></label>
          <input class="form-control" name="label" id="addLabel" placeholder="e.g. Mum's MTN" required>
          <div class="invalid-feedback">Please enter a label.</div>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Value <span class="text-danger">*</span></label>
          <input class="form-control" name="value" id="addValue" placeholder="Phone / Meter / IUC number" required>
          <div class="invalid-feedback">Please enter a value.</div>
        </div>

        <div class="col-md-3 d-flex align-items-end">
          <button class="btn btn-theme w-100" type="submit" id="addBtn">
            <i class="bi bi-plus-lg me-1"></i> Add Beneficiary
          </button>
        </div>
      </form>
    </div>

    <!-- Search & Filter -->
    <div class="card p-3 mb-4">
      <div class="row g-3">
        <div class="col-md-6">
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" id="searchInput" placeholder="Search by label or value...">
          </div>
        </div>
        <div class="col-md-6">
          <select class="form-select" id="filterType">
            <option value="">All Types</option>
            <option value="airtime">Airtime</option>
            <option value="data">Data</option>
            <option value="electricity">Electricity</option>
            <option value="tv">TV</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Beneficiaries Grid -->
    <div id="beneficiariesContainer">
      <% if (beneficiaries.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-people d-block"></i>
          <h5 class="mt-2">No beneficiaries yet</h5>
          <p class="text-muted">Add your first beneficiary using the form above.</p>
        </div>
      <% } else { %>
        <% ['airtime', 'data', 'electricity', 'tv'].forEach(type => {
             const items = beneficiaries.filter(b => (b.type || '').toLowerCase() === type);
             if (!items.length) return;
        %>
          <div class="mb-4 type-section" data-type="<%= type %>">
            <h6 class="fw-bold mb-3">
              <i class="<%= getTypeIcon(type) %> me-2 text-primary"></i>
              <%= getTypeLabel(type) %>
              <span class="badge bg-light text-dark ms-2"><%= items.length %></span>
            </h6>
            <div class="row g-3">
              <% items.forEach(b => { %>
                <div class="col-md-6 col-lg-4 ben-item"
                     data-id="<%= b.id %>"
                     data-type="<%= (b.type || '').toLowerCase() %>"
                     data-label="<%= escapeHtml((b.label || '').toLowerCase()) %>"
                     data-value="<%= escapeHtml((b.value || '').toLowerCase()) %>">
                  <div class="card p-3 h-100 beneficiary-card">
                    <div class="d-flex justify-content-between align-items-start">
                      <div class="flex-grow-1 me-2">
                        <div class="d-flex align-items-center gap-2 mb-1">
                          <span class="type-badge">
                            <i class="<%= getTypeIcon(b.type) %>"></i>
                            <%= getTypeLabel(b.type) %>
                          </span>
                          <% if (b.isFavorite) { %>
                            <i class="bi bi-star-fill text-warning small"></i>
                          <% } %>
                        </div>
                        <h6 class="fw-bold mb-1"><%= escapeHtml(b.label) %></h6>
                        <p class="small text-muted mb-1"><%= escapeHtml(b.value) %></p>
                        <% if (b.last_used) { %>
                          <small class="text-muted"><i class="bi bi-clock me-1"></i><%= formatDate(b.last_used) %></small>
                        <% } %>
                      </div>
                      <div class="d-flex flex-column gap-1">
                        <button class="btn btn-sm btn-outline-warning fav-btn"
                                data-id="<%= b.id %>"
                                title="<%= b.isFavorite ? 'Remove favourite' : 'Add to favourites' %>">
                          <i class="bi bi-star<%= b.isFavorite ? '-fill' : '' %>"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger del-btn"
                                data-id="<%= b.id %>"
                                data-label="<%= escapeHtml(b.label) %>"
                                title="Delete">
                          <i class="bi bi-trash"></i>
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

  </div>
</main>

<!-- Delete Confirm Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Beneficiary</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Delete <strong id="deleteLabel"></strong>? This cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
      </div>
    </div>
  </div>
</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    'use strict';

    const CSRF = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';

    // ── Toast helper ──────────────────────────────────────────────────────
    function toast(msg, type = 'success') {
        const container = document.querySelector('.toast-container');
        const id  = 'toast-' + Date.now();
        const cls = { success: 'text-bg-success', error: 'text-bg-danger', warning: 'text-bg-warning', info: 'text-bg-info' }[type] || 'text-bg-success';
        const ico = { success: 'bi-check-circle-fill', error: 'bi-exclamation-triangle-fill', warning: 'bi-exclamation-circle-fill', info: 'bi-info-circle-fill' }[type] || 'bi-bell-fill';
        container.insertAdjacentHTML('beforeend', `
            <div id="${id}" class="toast align-items-center ${cls} border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi ${ico}"></i><span>${esc(msg)}</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>`);
        const el = document.getElementById(id);
        new bootstrap.Toast(el, { autohide: true, delay: 4000 }).show();
        el.addEventListener('hidden.bs.toast', () => el.remove());
    }

    function esc(s) {
        const d = document.createElement('div');
        d.textContent = String(s || '');
        return d.innerHTML;
    }

    function setLoading(btn, loading) {
        if (loading) {
            btn.disabled = true;
            btn._orig = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
        } else {
            btn.disabled = false;
            btn.innerHTML = btn._orig || btn.innerHTML;
        }
    }

    // ── ADD FORM ──────────────────────────────────────────────────────────
    document.getElementById('addForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        if (!form.checkValidity()) { form.classList.add('was-validated'); return; }

        const btn = document.getElementById('addBtn');
        setLoading(btn, true);

        try {
            const fd = new FormData(form);
            fd.set('_csrf', CSRF);

            // FIX: post to /api/beneficiaries (absolute path)
            const res  = await fetch('/api/beneficiaries', {
                method:      'POST',
                body:        fd,
                credentials: 'same-origin',
                headers:     { 'X-CSRF-Token': CSRF }
            });
            const data = await res.json();

            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed to add beneficiary');

            toast('Beneficiary saved!', 'success');
            form.reset();
            form.classList.remove('was-validated');
            // Reload to show the new card
            setTimeout(() => location.reload(), 1000);

        } catch (err) {
            toast(err.message, 'error');
        }
        setLoading(btn, false);
    });

    // ── SEARCH & FILTER ───────────────────────────────────────────────────
    function applyFilter() {
        const q    = (document.getElementById('searchInput').value || '').toLowerCase();
        const type = (document.getElementById('filterType').value  || '').toLowerCase();

        document.querySelectorAll('.ben-item').forEach(item => {
            const matchType  = !type || item.dataset.type === type;
            const matchQuery = !q || item.dataset.label.includes(q) || item.dataset.value.includes(q);
            item.style.display = (matchType && matchQuery) ? '' : 'none';
        });

        // Hide section headings when all items in that section are hidden
        document.querySelectorAll('.type-section').forEach(section => {
            const visible = section.querySelectorAll('.ben-item:not([style*="display: none"])').length;
            section.style.display = visible ? '' : 'none';
        });
    }

    document.getElementById('searchInput').addEventListener('input',  applyFilter);
    document.getElementById('filterType').addEventListener('change', applyFilter);

    // ── FAVOURITE ─────────────────────────────────────────────────────────
    document.addEventListener('click', async (e) => {
        const btn = e.target.closest('.fav-btn');
        if (!btn) return;
        const id = btn.dataset.id;

        try {
            // FIX: calls /api/beneficiaries/:id/favorite (route now exists)
            const res  = await fetch(`/api/beneficiaries/${id}/favorite`, {
                method:      'POST',
                credentials: 'same-origin',
                headers:     { 'X-CSRF-Token': CSRF, 'Content-Type': 'application/json' },
                body:        JSON.stringify({ _csrf: CSRF })
            });
            const data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed');

            const icon = btn.querySelector('i');
            if (data.isFavorite) {
                icon.className = 'bi bi-star-fill';
                btn.title = 'Remove favourite';
            } else {
                icon.className = 'bi bi-star';
                btn.title = 'Add to favourites';
            }
            toast(data.message, 'success');
        } catch (err) {
            toast(err.message, 'error');
        }
    });

    // ── DELETE ────────────────────────────────────────────────────────────
    let pendingDeleteId = null;

    document.addEventListener('click', (e) => {
        const btn = e.target.closest('.del-btn');
        if (!btn) return;
        pendingDeleteId = btn.dataset.id;
        document.getElementById('deleteLabel').textContent = btn.dataset.label || 'this beneficiary';
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
        if (!pendingDeleteId) return;
        const btn = document.getElementById('confirmDeleteBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Deleting...';

        try {
            const res  = await fetch(`/api/beneficiaries/${pendingDeleteId}`, {
                method:      'DELETE',
                credentials: 'same-origin',
                headers:     { 'X-CSRF-Token': CSRF, 'Content-Type': 'application/json' },
                body:        JSON.stringify({ _csrf: CSRF })
            });
            const data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data.error || 'Failed to delete');

            // Remove from DOM
            const card = document.querySelector(`.ben-item[data-id="${pendingDeleteId}"]`);
            if (card) card.remove();

            // Update count
            const countEl = document.getElementById('totalCount');
            if (countEl) countEl.textContent = Math.max(0, parseInt(countEl.textContent) - 1);

            bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
            toast('Beneficiary deleted', 'success');

        } catch (err) {
            toast(err.message, 'error');
        }

        btn.disabled = false;
        btn.innerHTML = 'Delete';
        pendingDeleteId = null;
    });

})();
</script>

