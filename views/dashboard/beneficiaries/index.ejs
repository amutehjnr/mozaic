</div>

<!-- Toast Container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
// Server-side data passed to JavaScript
const initialBeneficiaries = <%- JSON.stringify(beneficiaries) %>;
let items = initialBeneficiaries;
let currentDeleteId = null;

// Helper functions
function escapeHtml(s) {
    if (!s) return '';
    return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

function showToast(message, type = 'success') {
    const container = document.querySelector('.toast-container');
    const toastId = 'toast-' + Date.now();
    
    const bgColor = {
        'success': 'text-bg-success',
        'error': 'text-bg-danger',
        'warning': 'text-bg-warning',
        'info': 'text-bg-info'
    }[type] || 'text-bg-success';
    
    const icon = {
        'success': 'bi-check-circle-fill',
        'error': 'bi-exclamation-triangle-fill',
        'warning': 'bi-exclamation-circle-fill',
        'info': 'bi-info-circle-fill'
    }[type] || 'bi-bell-fill';
    
    const toastHtml = `
        <div id="${toastId}" class="toast align-items-center ${bgColor} border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <i class="bi ${icon}"></i>
                    <span>${escapeHtml(message)}</span>
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    `;
    
    container.insertAdjacentHTML('beforeend', toastHtml);
    
    const toastElement = document.getElementById(toastId);
    const toast = new bootstrap.Toast(toastElement, {
        autohide: true,
        delay: 5000
    });
    
    toast.show();
    
    toastElement.addEventListener('hidden.bs.toast', () => {
        toastElement.remove();
    });
}

// Quick add template
function quickAdd(type, labelPrefix, valuePrefix) {
    document.querySelector('[name="type"]').value = type;
    document.querySelector('[name="label"]').value = labelPrefix + ' Beneficiary';
    document.querySelector('[name="value"]').value = valuePrefix + '12345678';
    document.querySelector('[name="label"]').focus();
}

// Search and filter functionality
function filterBeneficiaries() {
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    const filterType = document.getElementById('filterType').value;
    
    document.querySelectorAll('.beneficiary-item').forEach(item => {
        const type = item.dataset.type;
        const label = item.dataset.label;
        const value = item.dataset.value;
        
        const matchesType = !filterType || type === filterType;
        const matchesSearch = !searchTerm || 
            label.includes(searchTerm) || 
            value.includes(searchTerm) ||
            type.toLowerCase().includes(searchTerm);
        
        item.style.display = matchesType && matchesSearch ? 'block' : 'none';
    });
    
    // Show/hide empty state
    const visibleItems = document.querySelectorAll('.beneficiary-item[style="display: block"]').length;
    const emptyMessage = document.getElementById('noResultsMessage');
    
    if (!emptyMessage) {
        const message = document.createElement('div');
        message.id = 'noResultsMessage';
        message.className = 'col-12 text-center py-5';
        message.innerHTML = `
            <i class="bi bi-search fs-1 text-muted mb-3"></i>
            <h5>No matching beneficiaries</h5>
            <p class="text-muted">Try adjusting your search or filters</p>
        `;
        document.getElementById('beneficiariesContainer').appendChild(message);
    }
    
    document.getElementById('noResultsMessage').style.display = visibleItems === 0 ? 'block' : 'none';
}

document.getElementById('searchInput')?.addEventListener('input', filterBeneficiaries);
document.getElementById('filterType')?.addEventListener('change', filterBeneficiaries);

// CRUD Operations
async function deleteBeneficiary(id) {
    const beneficiary = items.find(i => i.id === id);
    if (!beneficiary) return;
    
    currentDeleteId = id;
    document.getElementById('deleteBeneficiaryInfo').textContent = 
        `${beneficiary.label} (${beneficiary.type})`;
    
    const modal = new bootstrap.Modal(document.getElementById('deleteModal'));
    modal.show();
}

document.getElementById('confirmDelete')?.addEventListener('click', async () => {
    if (!currentDeleteId) return;
    
    const btn = document.getElementById('confirmDelete');
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Deleting...';
    
    try {
        const formData = new FormData();
        formData.append('_csrf', '<%= csrfToken %>');
        formData.append('id', currentDeleteId);
        
        const response = await fetch('/api/beneficiaries/' + currentDeleteId, {
            method: 'DELETE',
            headers: {
                'X-CSRF-Token': '<%= csrfToken %>'
            },
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (!response.ok || data.error) {
            throw new Error(data.error || 'Delete failed');
        }
        
        // Remove from DOM
        const card = document.querySelector(`.beneficiary-item[data-id="${currentDeleteId}"]`);
        if (card) card.remove();
        
        // Update items array
        items = items.filter(i => i.id !== currentDeleteId);
        
        // Close modal
        bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
        
        showToast('Beneficiary deleted successfully');
        
        // Reload if empty
        if (items.length === 0) {
            setTimeout(() => location.reload(), 1500);
        }
        
    } catch (err) {
        console.error('Delete error:', err);
        showToast(err.message, 'error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
        currentDeleteId = null;
    }
});

async function editBeneficiary(id) {
    const item = items.find(i => i.id === id);
    if (!item) return;
    
    const newLabel = prompt('Update label', item.label);
    if (newLabel === null) return;
    
    const newValue = prompt('Update value', item.value);
    if (newValue === null) return;
    
    if (!newLabel.trim() || !newValue.trim()) {
        showToast('Label and value cannot be empty', 'error');
        return;
    }
    
    try {
        const response = await fetch('/api/beneficiaries/' + id, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': '<%= csrfToken %>'
            },
            body: JSON.stringify({
                label: newLabel.trim(),
                value: newValue.trim()
            }),
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (!response.ok || data.error) {
            throw new Error(data.error || 'Update failed');
        }
        
        // Update in items array
        item.label = newLabel.trim();
        item.value = newValue.trim();
        
        // Update DOM
        const card = document.querySelector(`.beneficiary-item[data-id="${id}"]`);
        if (card) {
            const html = card.innerHTML;
            // Simple update - in production, you'd want to update specific fields
            // For now, we'll reload the page
            location.reload();
        }
        
        showToast('Beneficiary updated successfully');
        
    } catch (err) {
        console.error('Edit error:', err);
        showToast(err.message, 'error');
    }
}

async function toggleFavorite(id) {
    try {
        const response = await fetch('/api/beneficiaries/' + id + '/favorite', {
            method: 'POST',
            headers: {
                'X-CSRF-Token': '<%= csrfToken %>'
            },
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (!response.ok || data.error) {
            throw new Error(data.error || 'Failed to update favorite');
        }
        
        // Update button state
        const btn = document.querySelector(`.beneficiary-item[data-id="${id}"] .favorite-btn`);
        if (btn) {
            const icon = btn.querySelector('i');
            if (data.isFavorite) {
                icon.classList.remove('bi-star');
                icon.classList.add('bi-star-fill');
                btn.classList.add('active');
            } else {
                icon.classList.remove('bi-star-fill');
                icon.classList.add('bi-star');
                btn.classList.remove('active');
            }
        }
        
        showToast(data.isFavorite ? 'Added to favorites' : 'Removed from favorites');
        
    } catch (err) {
        console.error('Toggle favorite error:', err);
        showToast(err.message, 'error');
    }
}

function useBeneficiary(id) {
    const beneficiary = items.find(i => i.id === id);
    if (!beneficiary) return;
    
    // Store in session storage for use in dashboard
    sessionStorage.setItem('selectedBeneficiary', JSON.stringify(beneficiary));
    
    // Navigate to dashboard with the appropriate tab
    window.location.href = '/dashboard/user#' + beneficiary.type.toLowerCase();
}

// Form submission handler
const addForm = document.getElementById('addForm');
if (addForm) {
    addForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!addForm.checkValidity()) {
            addForm.classList.add('was-validated');
            return;
        }
        
        const submitBtn = addForm.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Adding...';
        
        try {
            const formData = new FormData(addForm);
            
            const response = await fetch('/api/beneficiaries', {
                method: 'POST',
                headers: {
                    'X-CSRF-Token': '<%= csrfToken %>'
                },
                body: formData,
                credentials: 'same-origin'
            });
            
            const data = await response.json();
            
            if (!response.ok || data.error) {
                throw new Error(data.error || 'Add failed');
            }
            
            showToast('Beneficiary added successfully');
            
            // Reload to show new beneficiary
            setTimeout(() => location.reload(), 1500);
            
        } catch (err) {
            console.error('Add error:', err);
            showToast(err.message, 'error');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });
}

// Attach event listeners
document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', () => editBeneficiary(btn.dataset.id));
});

document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', () => deleteBeneficiary(btn.dataset.id));
});

// Initialize search if there are items
if (items.length > 0) {
    filterBeneficiaries();
}
</script>

