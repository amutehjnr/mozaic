<%
const user = typeof userData !== 'undefined' ? userData : (typeof user !== 'undefined' ? user : { id: 0, name: '', email: '' });
// FIX: view was checking 'beneficiariesData' but controller was sending 'beneficiaries'
// Controller now sends both; we handle either here
const beneficiaries = typeof beneficiariesData !== 'undefined' ? beneficiariesData
                    : typeof beneficiaries !== 'undefined' ? beneficiaries : [];

const formatDate = (dateStr) => {
    if (!dateStr) return '';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    return d.toLocaleDateString('en-NG', { year: 'numeric', month: 'short', day: 'numeric' });
};

const escapeHtml = (text) => {
    if (!text) return '';
    return String(text)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
};

// FIX: Icons mapped to lowercase type values (matching model enum)
const getTypeIcon = (type) => ({
    data:        'bi-wifi',
    airtime:     'bi-phone-fill',
    electricity: 'bi-plug',
    tv:          'bi-tv'
}[type?.toLowerCase()] || 'bi-person');

const getTypeLabel = (type) => ({
    data:        'Data',
    airtime:     'Airtime',
    electricity: 'Electricity',
    tv:          'TV'
}[type?.toLowerCase()] || type || '—');

// Group by type (lowercase)
const grouped = {};
['airtime', 'data', 'electricity', 'tv'].forEach(t => {
    const items = beneficiaries.filter(b => (b.type || '').toLowerCase() === t);
    if (items.length) grouped[t] = items;
});
%>
<%- include('../../partials/header') %>

<style>
  :root { --jn-primary:#EF5134; --jn-primary-600:#e3472b; }
  body  { background:#f8fafc; font-family:'Poppins',sans-serif; }
  .navbar { background:rgba(11,18,32,.95); backdrop-filter:blur(10px); padding:.75rem 0; }
  .navbar-brand { font-weight:800; font-size:1.5rem; color:white!important; }
  .navbar-brand span { color:var(--jn-primary); }
  .nav-link { color:rgba(255,255,255,.8)!important; font-weight:500; }
  .nav-link:hover, .nav-link.active { color:white!important; }
  #header { position:relative; padding:3rem 0; margin-bottom:2rem;
    background:linear-gradient(135deg,#0b1220,#1a2639); }
  #header .container { position:relative; z-index:1; color:white; }
  .card { border:none; border-radius:16px; box-shadow:0 1px 3px rgba(0,0,0,.05); transition:all .2s; }
  .card:hover { box-shadow:0 4px 12px rgba(0,0,0,.08); }
  .btn-theme { background:var(--jn-primary); border:none; border-radius:10px; font-weight:600; padding:.6rem 1.5rem; color:white; transition:all .2s; }
  .btn-theme:hover { background:var(--jn-primary-600); transform:translateY(-2px); color:white; }
  .form-control,.form-select { border-radius:10px; border:1px solid #e2e8f0; }
  .form-control:focus,.form-select:focus { border-color:var(--jn-primary); box-shadow:0 0 0 3px rgba(239,81,52,.15); }
  .type-badge { display:inline-flex; align-items:center; gap:.5rem; padding:.35rem 1rem; background:#f1f5f9; border-radius:100px; font-size:.85rem; font-weight:500; }
  .beneficiary-card { border-left:3px solid var(--jn-primary); }
  .empty-state { padding:4rem 1rem; text-align:center; }
  .empty-state i { font-size:4rem; color:#cbd5e1; margin-bottom:1rem; }
  .spinner-border-sm { width:1rem; height:1rem; border-width:2px; }
  .toast-container { z-index:1060; }
</style>

<nav class="navbar navbar-expand-lg sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/"><span>Moz</span>Aic</a>
    <button class="navbar-toggler text-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/dashboard/user">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link" href="/dashboard/history">History</a></li>
        <li class="nav-item"><a class="nav-link active" href="/dashboard/beneficiaries">Beneficiaries</a></li>
        <li class="nav-item"><a class="nav-link" href="/dashboard/referrals">Referrals</a></li>
      </ul>
      <div class="d-flex gap-2">
        <span class="badge bg-white text-dark d-none d-md-block px-3 py-2">
          <i class="bi bi-person-circle me-1"></i><%= escapeHtml(user.name || user.email || '') %>
        </span>
        <form method="POST" action="/auth/logout" class="d-inline">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <button type="submit" class="btn btn-outline-light btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i> Logout
          </button>
        </form>
      </div>
