<%
const user = typeof userData !== 'undefined' ? userData : { id: 0, name: '', email: '' };
const transactions = typeof transactionsData !== 'undefined' ? transactionsData : [];
const pagination = typeof paginationData !== 'undefined' ? paginationData : { page: 1, pages: 1, total: 0 };

// Read filters from query params
const query = typeof queryParams !== 'undefined' ? queryParams : {};
const type = query.type || '';
const status = query.status || '';
const from = query.from || '';
const to = query.to || '';
const page = Math.max(1, parseInt(query.page) || 1);

// Format helpers
const formatDate = (dateStr) => {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return dateStr;
    return date.toLocaleDateString('en-NG', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    });
};

const formatDateShort = (dateStr) => {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return dateStr.substring(0, 10);
    return date.toISOString().split('T')[0];
};

const formatNaira = (amount) => {
    return '₦' + Number(amount).toLocaleString('en-NG', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
};

const getStatusBadgeClass = (status) => {
    const classes = {
        'success': 'badge-soft-success',
        'pending': 'badge-soft-warning',
        'failed': 'badge-soft-danger',
        'processing': 'badge-soft-info',
        'refunded': 'badge-soft-secondary',
        'reversed': 'badge-soft-dark'
    };
    return classes[status?.toLowerCase()] || 'badge-soft-secondary';
};

// Helper to keep query params in pagination links
const qkeep = (overrides) => {
    const q = { ...query };
    Object.assign(q, overrides);
    const params = new URLSearchParams();
    Object.keys(q).forEach(k => {
        if (q[k] && q[k] !== '') params.append(k, q[k]);
    });
    return '?' + params.toString();
};

// Transaction normalizers (using actual data structure)
const normType = (t) => {
    if (t.type) return t.type.charAt(0).toUpperCase() + t.type.slice(1);
    if (t.provider) return t.provider.charAt(0).toUpperCase() + t.provider.slice(1);
    return '-';
};

const normStatus = (t) => {
    return t.status || 'unknown';
};

const normAmount = (t) => {
    return t.amount || 0;
};

const normDate = (t) => {
    return t.created_at || t.createdAt || '';
};

const normRef = (t) => {
    return t.reference || t.ref || `TXN-${t.id}`;
};

const normDetails = (t) => {
    const parts = [];
    
    // Add main identifiers
    if (t.provider) parts.push(t.provider.toUpperCase());
    if (t.account_target) parts.push(t.account_target);
    if (t.plan_code) parts.push(t.plan_code);
    
    // Add from metadata
    if (t.metadata) {
        try {
            const meta = typeof t.metadata === 'string' ? JSON.parse(t.metadata) : t.metadata;
            if (meta.phone) parts.push(meta.phone);
            if (meta.smartcard) parts.push(meta.smartcard);
            if (meta.meterNo) parts.push(meta.meterNo);
            if (meta.network) parts.push(meta.network.toUpperCase());
        } catch (e) {}
    }
    
    // Add description
    if (t.details) parts.push(t.details);
    
    return parts.length ? parts.join(' • ') : '—';
};
%>
