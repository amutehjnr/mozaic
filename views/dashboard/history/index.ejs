<header id="header">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-8">
        <h1 class="fw-bold mb-2">Transaction History</h1>
        <p class="lead mb-0 opacity-75">View, filter, and export all your transactions</p>
      </div>
      <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <button class="btn btn-theme" onclick="exportCSV()" id="exportBtn">
          <i class="bi bi-download me-1"></i> Export CSV
        </button>
      </div>
    </div>
  </div>
</header>

<main class="section py-4">
  <div class="container">

    <!-- Summary Stats -->
    <div class="summary-stats">
      <div class="row g-4">
        <div class="col-6 col-md-3">
          <div class="stat-item">
            <div class="stat-value"><%= formatNaira(transactions.reduce((sum, t) => sum + (t.amount > 0 ? t.amount : 0), 0)) %></div>
            <div class="stat-label">Total Credits</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-item">
            <div class="stat-value"><%= formatNaira(Math.abs(transactions.reduce((sum, t) => sum + (t.amount < 0 ? t.amount : 0), 0))) %></div>
            <div class="stat-label">Total Debits</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-item">
            <div class="stat-value"><%= transactions.length %></div>
            <div class="stat-label">Total Transactions</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="stat-item">
            <div class="stat-value"><%= transactions.filter(t => t.status === 'success').length %></div>
            <div class="stat-label">Successful</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="filter-section">
      <h5 class="fw-bold mb-3">
        <i class="bi bi-funnel me-2 text-primary"></i>
        Filter Transactions
      </h5>
      <form class="row g-3" method="GET" action="/dashboard/history" id="filterForm">
        <div class="col-md-3">
          <label class="form-label fw-semibold">Transaction Type</label>
          <select class="form-select" name="type">
            <option value="">All Types</option>
            <option value="credit" <%= type === 'credit' ? 'selected' : '' %>>Credits (Funding)</option>
            <option value="debit" <%= type === 'debit' ? 'selected' : '' %>>Debits (Payments)</option>
            <option value="data" <%= type === 'data' ? 'selected' : '' %>>Data Purchase</option>
            <option value="airtime" <%= type === 'airtime' ? 'selected' : '' %>>Airtime Purchase</option>
            <option value="electricity" <%= type === 'electricity' ? 'selected' : '' %>>Electricity</option>
            <option value="tv" <%= type === 'tv' ? 'selected' : '' %>>TV Subscription</option>
            <option value="withdrawal" <%= type === 'withdrawal' ? 'selected' : '' %>>Withdrawal</option>
          </select>
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Status</label>
          <select class="form-select" name="status">
            <option value="">All Statuses</option>
            <option value="success" <%= status === 'success' ? 'selected' : '' %>>Successful</option>
            <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="failed" <%= status === 'failed' ? 'selected' : '' %>>Failed</option>
            <option value="processing" <%= status === 'processing' ? 'selected' : '' %>>Processing</option>
          </select>
        </div>

        <div class="col-md-2">
          <label class="form-label fw-semibold">From Date</label>
          <input type="date" class="form-control" name="from" value="<%= from %>" max="<%= new Date().toISOString().split('T')[0] %>">
        </div>

        <div class="col-md-2">
          <label class="form-label fw-semibold">To Date</label>
          <input type="date" class="form-control" name="to" value="<%= to %>" max="<%= new Date().toISOString().split('T')[0] %>">
        </div>

        <div class="col-md-2 d-flex align-items-end">
          <div class="d-flex gap-2 w-100">
            <button type="submit" class="btn btn-theme flex-grow-1">
              <i class="bi bi-search me-1"></i> Apply
            </button>
            <a href="/dashboard/history" class="btn btn-outline-secondary">
              <i class="bi bi-x-lg"></i>
            </a>
          </div>
        </div>
      </form>
    </div>

    <!-- Transactions Table -->
    <div class="card">
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Date & Time</th>
              <th>Type</th>
              <th>Details</th>
              <th>Status</th>
              <th class="text-end">Amount</th>
              <th class="text-center">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (rows.length === 0) { %>
              <tr>
                <td colspan="6">
                  <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h6 class="mt-3">No transactions found</h6>
                    <p class="text-muted mb-0">Try adjusting your filters or make your first transaction</p>
                  </div>
                </td>
              </tr>
            <% } else { 
              rows.forEach(t => { 
                const amount = normAmount(t);
                const isCredit = t.type === 'credit' || amount > 0;
            %>
                <tr>
                  <td>
                    <div class="fw-semibold"><%= formatDate(normDate(t)) %></div>
                    <small class="text-muted"><%= normRef(t) %></small>
                  </td>
                  <td>
                    <span class="badge-soft"><%= normType(t) %></span>
                  </td>
                  <td class="small">
                    <%= normDetails(t) %>
                  </td>
                  <td>
                    <span class="badge-soft <%= getStatusBadgeClass(t.status) %>">
                      <%= t.status?.charAt(0).toUpperCase() + t.status?.slice(1) || 'Unknown' %>
                    </span>
                  </td>
                  <td class="text-end">
                    <span class="fw-bold <%= isCredit ? 'text-success' : 'text-danger' %>">
                      <%= isCredit ? '+' : '-' %> <%= formatNaira(Math.abs(amount)) %>
                    </span>
                  </td>
                  <td class="text-center">
                    <div class="dropdown">
                      <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-three-dots-vertical"></i>
                      </button>
                      <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                          <a class="dropdown-item" href="/receipt?ref=<%= encodeURIComponent(normRef(t)) %>">
                            <i class="bi bi-receipt me-2"></i> View Receipt
                          </a>
                        </li>
                        <% if (t.status === 'pending') { %>
                        <li>
                          <button class="dropdown-item" onclick="requeryTransaction('<%= normRef(t) %>')">
                            <i class="bi bi-arrow-repeat me-2"></i> Requery
                          </button>
                        </li>
                        <% } %>
                        <li>
                          <button class="dropdown-item" onclick="downloadReceipt('<%= normRef(t) %>')">
                            <i class="bi bi-download me-2"></i> Download PDF
                          </button>
                        </li>
                      </ul>
                    </div>
                  </td>
                </tr>
            <% }); } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (pages > 1) { %>
      <div class="card-footer bg-white d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <small class="text-muted">
          Showing <span class="fw-semibold"><%= rows.length %></span> of 
          <span class="fw-semibold"><%= total %></span> transactions
        </small>

        <nav aria-label="Transaction pagination">
          <ul class="pagination mb-0">
            <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
              <a class="page-link" href="<%= currentPage <= 1 ? '#' : qkeep({page: currentPage - 1}) %>" aria-label="Previous">
                <i class="bi bi-chevron-left"></i>
              </a>
            </li>
            
            <% 
              let startPage = Math.max(1, currentPage - 2);
              let endPage = Math.min(pages, startPage + 4);
              if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
              }
              
              if (startPage > 1) { 
            %>
              <li class="page-item"><a class="page-link" href="<%= qkeep({page: 1}) %>">1</a></li>
              <% if (startPage > 2) { %>
                <li class="page-item disabled"><span class="page-link">...</span></li>
              <% }
            }
            
            for (let p = startPage; p <= endPage; p++) { %>
              <li class="page-item <%= p === currentPage ? 'active' : '' %>">
                <a class="page-link" href="<%= qkeep({page: p}) %>"><%= p %></a>
              </li>
            <% }
            
            if (endPage < pages) { 
              if (endPage < pages - 1) { %>
                <li class="page-item disabled"><span class="page-link">...</span></li>
              <% } %>
              <li class="page-item"><a class="page-link" href="<%= qkeep({page: pages}) %>"><%= pages %></a></li>
            <% } %>
            
            <li class="page-item <%= currentPage >= pages ? 'disabled' : '' %>">
              <a class="page-link" href="<%= currentPage >= pages ? '#' : qkeep({page: currentPage + 1}) %>" aria-label="Next">
                <i class="bi bi-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      </div>
      <% } %>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3 mt-2">
      <div class="col-md-6">
        <div class="card p-3">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-question-circle fs-1 text-primary opacity-50"></i>
            <div>
              <h6 class="fw-bold mb-1">Need help with a transaction?</h6>
              <p class="small text-muted mb-2">If a transaction is stuck or failed, you can requery it.</p>
              <a href="/dashboard/requery" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-arrow-repeat me-1"></i> Go to Requery
              </a>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card p-3">
          <div class="d-flex align-items-center gap-3">
            <i class="bi bi-download fs-1 text-success opacity-50"></i>
            <div>
              <h6 class="fw-bold mb-1">Download Statement</h6>
              <p class="small text-muted mb-2">Get a complete statement of all your transactions.</p>
              <button class="btn btn-sm btn-outline-success" onclick="exportCSV()">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> Export CSV
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<!-- Requery Modal -->
