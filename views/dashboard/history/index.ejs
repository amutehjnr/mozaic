<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
// Transaction data for export
const exportData = <%- JSON.stringify(rows.map(t => ({
    date: formatDateShort(normDate(t)),
    type: normType(t),
    details: normDetails(t),
    status: t.status,
    amount: normAmount(t),
    reference: normRef(t)
}))) %>;

/**
 * Export transactions to CSV
 */
async function exportCSV() {
    const btn = document.getElementById('exportBtn');
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Exporting...';
    
    try {
        // Create CSV content
        let csv = 'Date,Type,Details,Status,Amount,Reference\n';
        
        exportData.forEach(row => {
            const line = [
                row.date,
                row.type,
                row.details,
                row.status,
                row.amount,
                row.reference
            ].map(v => `"${String(v || '').replace(/"/g, '""')}"`).join(',');
            
            csv += line + '\n';
        });
        
        // Create and download file
        const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' }); // Add BOM for UTF-8
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        
        a.href = url;
        a.download = `transactions_${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
        
        // Show success message
        showToast('Export completed successfully', 'success');
        
    } catch (error) {
        console.error('Export error:', error);
        showToast('Export failed: ' + error.message, 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
}

/**
 * Show toast notification
 */
function showToast(message, type = 'success') {
    // Create toast container if it doesn't exist
    let container = document.querySelector('.toast-container');
    if (!container) {
        container = document.createElement('div');
        container.className = 'toast-container position-fixed bottom-0 end-0 p-3';
        container.style.zIndex = '1060';
        document.body.appendChild(container);
    }
    
    // Create toast element
    const toastId = 'toast-' + Date.now();
    const toastHtml = `
        <div id="${toastId}" class="toast align-items-center text-bg-${type} border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    ${message}
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    `;
    
    container.insertAdjacentHTML('beforeend', toastHtml);
    
    const toastElement = document.getElementById(toastId);
    const toast = new bootstrap.Toast(toastElement, {
        autohide: true,
        delay: 5000
    });
    
    toast.show();
    
    // Remove toast after hidden
    toastElement.addEventListener('hidden.bs.toast', () => {
        toastElement.remove();
    });
}

/**
 * Requery transaction
 */
let currentRequeryRef = '';

function requeryTransaction(reference) {
    currentRequeryRef = reference;
    document.getElementById('requeryRef').textContent = reference;
    
    const modal = new bootstrap.Modal(document.getElementById('requeryModal'));
    modal.show();
}

document.getElementById('confirmRequery')?.addEventListener('click', async () => {
    const btn = document.getElementById('confirmRequery');
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Processing...';
    
    try {
        const formData = new FormData();
        formData.append('_csrf', '<%= csrfToken %>');
        formData.append('reference', currentRequeryRef);
        
        const response = await fetch('/api/wallet/requery', {
            method: 'POST',
            body: formData,
            credentials: 'same-origin'
        });
        
        const data = await response.json();
        
        if (!response.ok || data.error) {
            throw new Error(data.error || 'Requery failed');
        }
        
        showToast('Transaction requeried successfully', 'success');
        
        // Close modal and reload after 2 seconds
        setTimeout(() => {
            bootstrap.Modal.getInstance(document.getElementById('requeryModal')).hide();
            window.location.reload();
        }, 2000);
        
    } catch (error) {
        console.error('Requery error:', error);
        showToast(error.message, 'danger');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
});

