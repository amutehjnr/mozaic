<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
(function() {
    'use strict';

    // DOM Elements
    const formCheck = document.getElementById('rq');
    const resultBox = document.getElementById('result');
    const statusEl = document.getElementById('statusText');
    const statusBadge = document.getElementById('statusBadge');
    const amountEl = document.getElementById('amount');
    const statusIcon = document.getElementById('statusIcon');
    const transactionRef = document.getElementById('transactionRef');
    const transactionDetails = document.getElementById('transactionDetails');
    const reprocessBtn = document.getElementById('reprocessBtn');
    const viewReceiptBtn = document.getElementById('viewReceiptBtn');
    const newSearchBtn = document.getElementById('newSearchBtn');
    const recentTransactions = document.getElementById('recentTransactions');

    // Detail elements
    const txType = document.getElementById('txType');
    const txProvider = document.getElementById('txProvider');
    const txDate = document.getElementById('txDate');
    const txExternalRef = document.getElementById('txExternalRef');

    // Toast function
    function showToast(message, type = 'success') {
        const container = document.querySelector('.toast-container');
        const toastId = 'toast-' + Date.now();
        
        const bgColor = {
            'success': 'text-bg-success',
            'error': 'text-bg-danger',
            'warning': 'text-bg-warning',
            'info': 'text-bg-info'
        }[type] || 'text-bg-success';
        
        const icon = {
            'success': 'bi-check-circle-fill',
            'error': 'bi-exclamation-triangle-fill',
            'warning': 'bi-exclamation-circle-fill',
            'info': 'bi-info-circle-fill'
        }[type] || 'bi-bell-fill';
        
        const toastHtml = `
            <div id="${toastId}" class="toast align-items-center ${bgColor} border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body d-flex align-items-center gap-2">
                        <i class="bi ${icon}"></i>
                        <span>${escapeHtml(message)}</span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        `;
        
        container.insertAdjacentHTML('beforeend', toastHtml);
        
        const toastElement = document.getElementById(toastId);
        const toast = new bootstrap.Toast(toastElement, { autohide: true, delay: 5000 });
        toast.show();
        
        toastElement.addEventListener('hidden.bs.toast', () => toastElement.remove());
    }

    function escapeHtml(s) {
        if (!s) return '';
        return String(s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function formatNaira(amount) {
        return '₦' + Number(amount).toLocaleString('en-NG', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    function formatDate(dateStr) {
        if (!dateStr) return '—';
        const date = new Date(dateStr);
        if (isNaN(date.getTime())) return dateStr;
        return date.toLocaleString('en-NG', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    }

    function getStatusConfig(status) {
        const configs = {
            'success': { class: 'badge-soft-success', icon: 'bi-check-circle-fill text-success' },
            'pending': { class: 'badge-soft-warning', icon: 'bi-hourglass-split text-warning' },
            'failed': { class: 'badge-soft-danger', icon: 'bi-x-circle-fill text-danger' },
            'processing': { class: 'badge-soft-info', icon: 'bi-arrow-repeat text-info' },
            'queued': { class: 'badge-soft-secondary', icon: 'bi-clock-history text-secondary' }
        };
        return configs[status?.toLowerCase()] || { class: 'badge-soft-secondary', icon: 'bi-question-circle text-secondary' };
    }

    // Load recent transactions
    async function loadRecentTransactions() {
        try {
            const response = await fetch('/api/wallet/transactions?limit=5', {
                credentials: 'same-origin'
            });
            
            const data = await response.json();
            
            if (!response.ok || !data.ok) {
                throw new Error(data.error || 'Failed to load transactions');
            }
            
            if (!data.transactions || data.transactions.length === 0) {
                recentTransactions.innerHTML = `
                    <div class="text-center py-4">
                        <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
                        <p class="small text-muted">No recent transactions</p>
                    </div>
                `;
                return;
            }
            
            let html = '';
            data.transactions.slice(0, 5).forEach(tx => {
                const status = getStatusConfig(tx.status);
                html += `
                    <div class="recent-item d-flex justify-content-between align-items-center" onclick="document.querySelector('[name=reference]').value='${escapeHtml(tx.reference)}'">
                        <div>
                            <div class="fw-semibold small">${escapeHtml(tx.type)}</div>
                            <small class="text-muted">${escapeHtml(tx.reference)}</small>
                        </div>
                        <div class="text-end">
                            <span class="badge-soft ${status.class}">${tx.status}</span>
                            <div class="small mt-1">${formatNaira(tx.amount)}</div>
                        </div>
                    </div>
                `;
            });
            
            recentTransactions.innerHTML = html;
            
        } catch (error) {
            console.error('Load recent transactions error:', error);
            recentTransactions.innerHTML = `
                <div class="text-center py-4">
                    <i class="bi bi-exclamation-triangle text-danger d-block mb-2"></i>
                    <p class="small text-muted">Failed to load transactions</p>
                </div>
            `;
        }
    }

    // Handle form submission
    formCheck.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!formCheck.checkValidity()) {
            formCheck.classList.add('was-validated');
            return;
        }
        
        const submitBtn = document.getElementById('checkBtn');
        const originalText = submitBtn.innerHTML;
        const reference = formCheck.querySelector('[name=reference]').value.trim();
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Checking...';
        
        try {
            const response = await fetch('/api/wallet/transactions?reference=' + encodeURIComponent(reference), {
                credentials: 'same-origin'
            });
            
            const data = await response.json();
            
            if (!response.ok || data.error) {
                throw new Error(data.error || 'Transaction not found');
            }
            
            // Update result display
            const tx = data.transaction || data;
            const status = getStatusConfig(tx.status);
            
            statusIcon.innerHTML = `<i class="bi ${status.icon}" style="font-size: 2rem;"></i>`;
            statusEl.textContent = tx.status.charAt(0).toUpperCase() + tx.status.slice(1);
            statusBadge.textContent = tx.status.toUpperCase();
            statusBadge.className = `badge-soft ${status.class}`;
            amountEl.textContent = formatNaira(tx.amount);
            transactionRef.textContent = `Ref: ${tx.reference}`;
            
            // Show details
            txType.textContent = tx.type || '—';
            txProvider.textContent = tx.provider || '—';
            txDate.textContent = formatDate(tx.created_at);
            txExternalRef.textContent = tx.external_ref || '—';
            transactionDetails.style.display = 'block';
            
            // Show/hide action buttons
            if (tx.status === 'pending' || tx.status === 'failed') {
                reprocessBtn.style.display = 'inline-block';
                reprocessBtn.dataset.ref = tx.reference;
            } else {
                reprocessBtn.style.display = 'none';
            }
            
            if (tx.status === 'success') {
                viewReceiptBtn.style.display = 'inline-block';
                viewReceiptBtn.onclick = () => window.location.href = `/receipt?ref=${encodeURIComponent(tx.reference)}`;
            } else {
                viewReceiptBtn.style.display = 'none';
            }
            
            resultBox.classList.remove('d-none');
            
        } catch (error) {
            console.error('Requery error:', error);
            
            // Show error state
            statusIcon.innerHTML = '<i class="bi bi-exclamation-triangle text-danger" style="font-size: 2rem;"></i>';
            statusEl.textContent = 'Not Found';
            statusBadge.textContent = 'ERROR';
            statusBadge.className = 'badge-soft badge-soft-danger';
            amountEl.textContent = '₦0.00';
            transactionRef.textContent = '';
            transactionDetails.style.display = 'none';
            reprocessBtn.style.display = 'none';
            viewReceiptBtn.style.display = 'none';
            resultBox.classList.remove('d-none');
            
            showToast(error.message, 'error');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });

    // Reprocess button click
    reprocessBtn.addEventListener('click', () => {
        const ref = reprocessBtn.dataset.ref;
        if (!ref) return;
        
        document.getElementById('reprocessRef').textContent = ref;
        const modal = new bootstrap.Modal(document.getElementById('reprocessModal'));
        modal.show();
    });

    // Confirm reprocess
    document.getElementById('confirmReprocess').addEventListener('click', async () => {
        const ref = document.getElementById('reprocessRef').textContent;
        const btn = document.getElementById('confirmReprocess');
        const originalText = btn.innerHTML;
        
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Processing...';
        
        try {
            const formData = new FormData();
            formData.append('_csrf', '<%= csrfToken %>');
            formData.append('reference', ref);
            
            const response = await fetch('/api/wallet/requery', {
                method: 'POST',
                body: formData,
                credentials: 'same-origin'
            });
            
            const data = await response.json();
            
            if (!response.ok || data.error) {
                throw new Error(data.error || 'Reprocess failed');
            }
            
            showToast('Transaction requeried successfully', 'success');
            
            // Close modal
            bootstrap.Modal.getInstance(document.getElementById('reprocessModal')).hide();
            
            // Re-run search after 2 seconds
            setTimeout(() => {
                document.querySelector('[name=reference]').value = ref;
                formCheck.dispatchEvent(new Event('submit'));
            }, 2000);
            
        } catch (error) {
            console.error('Reprocess error:', error);
            showToast(error.message, 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalText;
        }
    });

    // New search button
    newSearchBtn.addEventListener('click', () => {
        resultBox.classList.add('d-none');
        document.querySelector('[name=reference]').value = '';
        document.querySelector('[name=reference]').focus();
    });

    // Load recent transactions on page load
    loadRecentTransactions();

    // Check for reference in URL
    const urlParams = new URLSearchParams(window.location.search);
    const refParam = urlParams.get('ref');
    if (refParam) {
        document.querySelector('[name=reference]').value = refParam;
        formCheck.dispatchEvent(new Event('submit'));
    }
})();
</script>

<%- include('../../partials/footer') %>