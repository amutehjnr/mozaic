      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card {
    animation: slideIn 0.3s ease-out;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .btn {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
    }
