<%- include('./_layout_start') %>

<div class="kpi-grid mb-4" id="kpiGrid">
  <div class="kpi-tile" style="--tile-color:var(--a-accent)">
    <div class="label">Total Users</div>
    <div class="value a-skeleton" style="height:36px;width:60%;border-radius:4px;">&nbsp;</div>
    <div class="sub">loading...</div>
    <i class="bi bi-people icon"></i>
  </div>
  <div class="kpi-tile" style="--tile-color:var(--a-info)">
    <div class="label">New (period)</div>
    <div class="value a-skeleton" style="height:36px;width:60%;border-radius:4px;">&nbsp;</div>
    <div class="sub">loading...</div>
    <i class="bi bi-person-plus icon"></i>
  </div>
  <div class="kpi-tile" style="--tile-color:var(--a-success)">
    <div class="label">Total Volume</div>
    <div class="value a-skeleton" style="height:36px;width:60%;border-radius:4px;">&nbsp;</div>
    <div class="sub">loading...</div>
    <i class="bi bi-currency-dollar icon"></i>
  </div>
  <div class="kpi-tile" style="--tile-color:var(--a-warning)">
    <div class="label">Transactions</div>
    <div class="value a-skeleton" style="height:36px;width:60%;border-radius:4px;">&nbsp;</div>
    <div class="sub">loading...</div>
    <i class="bi bi-arrow-left-right icon"></i>
  </div>
  <div class="kpi-tile" style="--tile-color:var(--a-accent)">
    <div class="label">Pending KYC</div>
    <div class="value a-skeleton" style="height:36px;width:60%;border-radius:4px;">&nbsp;</div>
    <div class="sub">loading...</div>
    <i class="bi bi-shield-exclamation icon"></i>
  </div>
</div>

<div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;margin-bottom:.85rem;">
  <h2 style="font-family:var(--font-mono);font-size:1rem;font-weight:700;color:#fff;margin:0;">Revenue Overview</h2>
  <div style="display:flex;gap:.5rem;" id="periodBtns">
    <button class="a-btn a-btn-ghost a-btn-sm period-btn" data-period="day">Day</button>
    <button class="a-btn a-btn-primary a-btn-sm period-btn" data-period="month">Month</button>
    <button class="a-btn a-btn-ghost a-btn-sm period-btn" data-period="week">Week</button>
    <button class="a-btn a-btn-ghost a-btn-sm period-btn" data-period="year">Year</button>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-lg-8">
    <div class="a-card">
      <div class="a-card-header">
        <span class="a-card-title">Daily Revenue (last 30 days)</span>
        <span id="chartTotal" style="font-family:var(--font-mono);font-size:.85rem;color:var(--a-success);">—</span>
      </div>
      <div class="a-card-body" style="padding-bottom:.75rem;">
        <canvas id="revenueChart" height="220"></canvas>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="a-card h-100">
      <div class="a-card-header"><span class="a-card-title">By Status</span></div>
      <div class="a-card-body" id="statusBreakdown">
        <div class="a-skeleton" style="height:160px;border-radius:8px;"></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-6">
    <div class="a-card">
      <div class="a-card-header">
        <span class="a-card-title">Recent Users</span>
        <a href="/admin/users" class="a-btn a-btn-ghost a-btn-sm">View all</a>
      </div>
      <div style="overflow-x:auto;">
        <table class="a-table">
          <thead><tr><th>Name</th><th>Email</th><th>Joined</th><th>Status</th></tr></thead>
          <tbody id="recentUsersTbody">
            <tr><td colspan="4"><div class="a-skeleton" style="height:14px;border-radius:3px;"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="a-card">
      <div class="a-card-header">
        <span class="a-card-title">Recent Transactions</span>
        <a href="/admin/transactions" class="a-btn a-btn-ghost a-btn-sm">View all</a>
      </div>
      <div style="overflow-x:auto;">
        <table class="a-table">
          <thead><tr><th>Ref</th><th>Amount</th><th>Type</th><th>Status</th></tr></thead>
          <tbody id="recentTxTbody">
            <tr><td colspan="4"><div class="a-skeleton" style="height:14px;border-radius:3px;"></div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    var period = 'month';
    var chart  = null;

    function setPeriodUI() {
        document.querySelectorAll('.period-btn').forEach(function (b) {
            b.classList.toggle('a-btn-primary', b.dataset.period === period);
            b.classList.toggle('a-btn-ghost',   b.dataset.period !== period);
        });
    }

    document.getElementById('periodBtns').addEventListener('click', function (e) {
        var btn = e.target.closest('.period-btn');
        if (btn) { period = btn.dataset.period; setPeriodUI(); loadStats(); }
    });

    function setKpi(index, value, sub) {
        var tiles = document.querySelectorAll('.kpi-tile');
        var tile  = tiles[index];
        if (!tile) return;
        var valEl = tile.querySelector('.value');
        valEl.className = 'value';
        valEl.textContent = String(value);
        tile.querySelector('.sub').textContent = sub;
    }

    async function loadStats() {
        try {
            var data = await Admin.get('/api/admin/stats?period=' + period);
            var s    = data.stats;

            setKpi(0, s.users.total,                   'registered accounts');
            setKpi(1, s.users.new,                     'this ' + period);
            setKpi(2, Admin.fmtNaira(s.transactions.volume), 'total processed');
            setKpi(3, s.transactions.total,            'all time');
            var pendingKyc = (s.kyc || []).find(function (k) { return k._id === 'pending'; });
            setKpi(4, pendingKyc ? pendingKyc.count : 0, 'awaiting review');

            renderChart(s.revenue || []);
            renderStatusBreakdown(s.transactions.byStatus || []);

            var uRes = await Admin.get('/api/admin/users?limit=5&page=1');
            renderRecentUsers(uRes.users || []);

            var tRes = await Admin.get('/api/admin/transactions?limit=5&page=1');
            renderRecentTx(tRes.transactions || []);

        } catch (err) {
            Admin.toast('Stats error: ' + err.message, 'error');
        }
    }

    function renderChart(rev) {
        var labels  = rev.map(function (r) { return r._id; });
        var volumes = rev.map(function (r) { return r.volume || 0; });
        var total   = volumes.reduce(function (a, b) { return a + b; }, 0);
        document.getElementById('chartTotal').textContent = Admin.fmtNaira(total);

        var ctx = document.getElementById('revenueChart').getContext('2d');
        if (chart) chart.destroy();
        chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue', data: volumes,
                    backgroundColor: 'rgba(239,81,52,.25)',
                    borderColor: 'rgba(239,81,52,.8)',
                    borderWidth: 1.5, borderRadius: 4,
                    hoverBackgroundColor: 'rgba(239,81,52,.5)'
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#161e2e', borderColor: 'rgba(255,255,255,.08)',
                        borderWidth: 1, titleColor: '#e2e8f0', bodyColor: '#94a3b8',
                        callbacks: { label: function (ctx) { return ' ' + Admin.fmtNaira(ctx.raw); } }
                    }
                },
                scales: {
                    x: { grid: { color: 'rgba(255,255,255,.04)' }, ticks: { color: '#64748b', font: { size: 10 }, maxTicksLimit: 10 } },
                    y: { grid: { color: 'rgba(255,255,255,.04)' }, ticks: { color: '#64748b', font: { size: 10 }, callback: function (v) { return Admin.fmtNaira(v); } } }
                }
            }
        });
    }

    function renderStatusBreakdown(byStatus) {
        var total  = byStatus.reduce(function (a, b) { return a + (b.count || 0); }, 0);
        var colors = { success: 'var(--a-success)', pending: 'var(--a-warning)', failed: 'var(--a-danger)', processing: 'var(--a-info)' };
        var html   = byStatus.map(function (s) {
            var pct = total ? Math.round((s.count / total) * 100) : 0;
            var col = colors[s._id] || 'var(--a-muted)';
            return '<div style="margin-bottom:.85rem">' +
                '<div style="display:flex;justify-content:space-between;margin-bottom:.3rem">' +
                    '<span style="font-size:.82rem;font-weight:600;color:var(--a-text)">' + Admin.escHtml(s._id || '—') + '</span>' +
                    '<span style="font-family:var(--font-mono);font-size:.8rem;color:var(--a-muted)">' + s.count + ' (' + pct + '%)</span>' +
                '</div>' +
                '<div style="height:6px;background:var(--a-surface2);border-radius:99px;overflow:hidden">' +
                    '<div style="height:100%;width:' + pct + '%;background:' + col + ';border-radius:99px;"></div>' +
                '</div></div>';
        }).join('');
        document.getElementById('statusBreakdown').innerHTML = html || '<p style="color:var(--a-muted);font-size:.85rem">No data yet</p>';
    }

    function renderRecentUsers(users) {
        var tbody = document.getElementById('recentUsersTbody');
        if (!users.length) { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--a-muted);padding:1.5rem">No users</td></tr>'; return; }
        tbody.innerHTML = users.map(function (u) {
            return '<tr>' +
                '<td><a href="/admin/users/' + u._id + '" style="color:var(--a-accent);font-weight:600;text-decoration:none">' + Admin.escHtml(u.name || '—') + '</a></td>' +
                '<td style="color:var(--a-muted);font-size:.82rem">' + Admin.escHtml(u.email || '') + '</td>' +
                '<td style="font-size:.82rem">' + Admin.fmtDateShort(u.created_at) + '</td>' +
                '<td>' + Admin.badge(u.isActive ? 'active' : 'inactive') + '</td>' +
            '</tr>';
        }).join('');
    }

    function renderRecentTx(txs) {
        var tbody = document.getElementById('recentTxTbody');
        if (!txs.length) { tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--a-muted);padding:1.5rem">No transactions</td></tr>'; return; }
        tbody.innerHTML = txs.map(function (t) {
            return '<tr>' +
                '<td style="font-family:var(--font-mono);font-size:.78rem;color:var(--a-muted)">' + Admin.escHtml((t.reference || '').slice(-10)) + '</td>' +
                '<td style="font-weight:600;color:var(--a-success)">' + Admin.fmtNaira(t.amount) + '</td>' +
                '<td style="font-size:.82rem;text-transform:capitalize">' + Admin.escHtml(t.type || '—') + '</td>' +
                '<td>' + Admin.badge(t.status) + '</td>' +
            '</tr>';
        }).join('');
    }

    loadStats();
})();
</script>

<%- include('./_layout_end') %>
