  </main><!-- /adm-content -->
</div><!-- /adm-main -->

<!-- Toast Area -->
<div id="adminToastArea"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
/* ── Shared admin utilities ──────────────────────────────────── */
window.Admin = (function () {
    'use strict';

    const CSRF = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';

    // ── Toast ─────────────────────────────────────────────────
    function toast(msg, type) {
        type = type || 'info';
        var area = document.getElementById('adminToastArea');
        var icons = { success:'bi-check-circle-fill', error:'bi-x-circle-fill', info:'bi-info-circle-fill', warning:'bi-exclamation-triangle-fill' };
        var el = document.createElement('div');
        el.className = 'a-toast t-' + type;
        el.innerHTML =
            '<i class="bi ' + (icons[type]||'bi-bell-fill') + ' t-icon"></i>' +
            '<span class="t-msg">' + escHtml(msg) + '</span>';
        area.appendChild(el);
        setTimeout(function () {
            el.classList.add('removing');
            setTimeout(function () { el.remove(); }, 220);
        }, 4000);
    }

    // ── API ───────────────────────────────────────────────────
    async function api(method, url, body) {
        var opts = {
            method: method,
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF }
        };
        if (body) opts.body = JSON.stringify(Object.assign({ _csrf: CSRF }, body));
        var res  = await fetch(url, opts);
        var data = await res.json().catch(function(){ return { ok: false, error: 'Invalid response' }; });
        if (!res.ok || data.ok === false) throw new Error(data.error || 'Request failed');
        return data;
    }

    async function get(url)             { return api('GET',    url); }
    async function post(url, body)      { return api('POST',   url, body); }
    async function put(url, body)       { return api('PUT',    url, body); }
    async function del(url)             { return api('DELETE', url); }

    // ── Helpers ───────────────────────────────────────────────
    function escHtml(s) {
        var d = document.createElement('div');
        d.textContent = String(s || '');
        return d.innerHTML;
    }

    function fmtNaira(n) {
        return '₦' + Number(n || 0).toLocaleString('en-NG', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtDate(d) {
        if (!d) return '—';
        return new Date(d).toLocaleDateString('en-NG', { year:'numeric', month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });
    }

    function fmtDateShort(d) {
        if (!d) return '—';
        return new Date(d).toLocaleDateString('en-NG', { month:'short', day:'numeric', year:'numeric' });
    }

    function badge(status) {
        var map = {
            success:   'a-badge-success', active:   'a-badge-success',
            verified:  'a-badge-success', healthy:  'a-badge-success',
            pending:   'a-badge-warning', processing:'a-badge-warning',
            draft:     'a-badge-muted',
            failed:    'a-badge-danger',  rejected:  'a-badge-danger',
            inactive:  'a-badge-danger',  frozen:    'a-badge-danger',
            info:      'a-badge-info',    configured:'a-badge-info',
        };
        var cls = map[(status||'').toLowerCase()] || 'a-badge-muted';
        return '<span class="a-badge ' + cls + '">' + escHtml(status || '—') + '</span>';
    }

    function skeleton(rows, cols) {
        cols = cols || 5;
        var html = '';
        for (var r = 0; r < (rows||5); r++) {
            html += '<tr>';
            for (var c = 0; c < cols; c++) {
                var w = [60,80,100,70,90][c % 5];
                html += '<td><div class="a-skeleton" style="height:14px;width:' + w + '%;border-radius:4px;"></div></td>';
            }
            html += '</tr>';
        }
        return html;
    }

    function buildPagination(pagination, onPage) {
        if (!pagination || pagination.pages <= 1) return '';
        var p = pagination.page, total = pagination.pages;
        var btns = '';

        btns += '<button class="a-page-btn" ' + (p<=1?'disabled':'') + ' data-page="'+(p-1)+'"><i class="bi bi-chevron-left"></i></button>';

        var pages = [];
        if (total <= 7) {
            for (var i = 1; i <= total; i++) pages.push(i);
        } else {
            pages = [1,2];
            if (p > 4) pages.push('...');
            for (var j = Math.max(3, p-1); j <= Math.min(total-2, p+1); j++) pages.push(j);
            if (p < total-3) pages.push('...');
            pages.push(total-1, total);
        }

        pages.forEach(function(pg) {
            if (pg === '...') {
                btns += '<span class="a-page-btn" style="pointer-events:none">…</span>';
            } else {
                btns += '<button class="a-page-btn' + (pg===p?' active':'') + '" data-page="'+pg+'">'+pg+'</button>';
            }
        });

        btns += '<button class="a-page-btn" ' + (p>=total?'disabled':'') + ' data-page="'+(p+1)+'"><i class="bi bi-chevron-right"></i></button>';

        var div = document.createElement('div');
        div.className = 'a-pagination';
        div.innerHTML = btns;
        div.addEventListener('click', function(e) {
            var btn = e.target.closest('[data-page]');
            if (btn && !btn.disabled) onPage(parseInt(btn.dataset.page));
        });
        return div;
    }

    // ── Sidebar toggle ────────────────────────────────────────
    var toggle  = document.getElementById('menuToggle');
    var sidebar = document.getElementById('sidebar');
    var overlay = document.getElementById('sidebarOverlay');
    if (toggle) {
        toggle.addEventListener('click', function() {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });
        overlay.addEventListener('click', function() {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });
    }

    // ── Health dot in topbar ──────────────────────────────────
    (async function checkHealth() {
        try {
            var data = await get('/api/admin/health');
            var dot   = document.getElementById('healthDot');
            var label = document.getElementById('healthLabel');
            if (dot && label) {
                var ok = data.status === 'healthy';
                dot.style.background   = ok ? 'var(--a-success)' : 'var(--a-warning)';
                dot.style.boxShadow    = ok ? '0 0 6px var(--a-success)' : '0 0 6px var(--a-warning)';
                label.textContent      = ok ? 'All systems go' : 'Degraded';
            }
        } catch (e) {
            var dot = document.getElementById('healthDot');
            if (dot) { dot.style.background = 'var(--a-danger)'; dot.style.boxShadow = '0 0 6px var(--a-danger)'; }
            var label = document.getElementById('healthLabel');
            if (label) label.textContent = 'Offline';
        }
    })();

    return { toast, api, get, post, put, del, escHtml, fmtNaira, fmtDate, fmtDateShort, badge, skeleton, buildPagination, CSRF };
})();
</script>

</body>
</html>
