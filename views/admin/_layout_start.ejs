<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= typeof title !== 'undefined' ? title : 'MozAic Admin' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
  <style>
    :root{--a-bg:#080c14;--a-surface:#0f1623;--a-surface2:#161e2e;--a-border:rgba(255,255,255,.07);
      --a-accent:#EF5134;--a-accent2:#22d3ee;--a-text:#e2e8f0;--a-muted:#64748b;
      --a-success:#10b981;--a-warning:#f59e0b;--a-danger:#ef4444;--a-info:#3b82f6;
      --sidebar-w:240px;--font-mono:'Space Mono',monospace;--font-body:'DM Sans',sans-serif;}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    html,body{height:100%;}
    body{font-family:var(--font-body);background:var(--a-bg);color:var(--a-text);display:flex;}
    .adm-sidebar{width:var(--sidebar-w);min-height:100vh;background:var(--a-surface);
      border-right:1px solid var(--a-border);display:flex;flex-direction:column;
      position:fixed;top:0;left:0;z-index:100;transition:transform .3s ease;}
    .adm-logo{padding:1.5rem 1.25rem 1rem;border-bottom:1px solid var(--a-border);}
    .adm-logo .wordmark{font-family:var(--font-mono);font-weight:700;font-size:1.2rem;color:#fff;letter-spacing:-.5px;}
    .adm-logo .wordmark span{color:var(--a-accent);}
    .adm-logo .pill{display:inline-block;font-size:.65rem;font-weight:700;letter-spacing:1.5px;
      text-transform:uppercase;background:rgba(239,81,52,.15);color:var(--a-accent);
      padding:.15rem .5rem;border-radius:4px;margin-top:.25rem;}
    .adm-nav{flex:1;padding:1rem .75rem;overflow-y:auto;}
    .adm-nav-label{font-size:.65rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;
      color:var(--a-muted);padding:1rem .5rem .35rem;}
    .adm-nav-link{display:flex;align-items:center;gap:.75rem;padding:.6rem .75rem;border-radius:8px;
      color:var(--a-muted);text-decoration:none;font-size:.9rem;font-weight:500;
      transition:all .15s;margin-bottom:2px;background:none;border:none;cursor:pointer;width:100%;text-align:left;}
    .adm-nav-link i{font-size:1rem;width:1.1rem;text-align:center;}
    .adm-nav-link:hover{color:var(--a-text);background:var(--a-surface2);}
    .adm-nav-link.active{color:#fff;background:rgba(239,81,52,.15);
      border-left:3px solid var(--a-accent);padding-left:calc(.75rem - 3px);}
    .adm-nav-link.active i{color:var(--a-accent);}
    .adm-sidebar-footer{padding:1rem .75rem;border-top:1px solid var(--a-border);}
    .adm-user-chip{display:flex;align-items:center;gap:.6rem;padding:.5rem .75rem;
      border-radius:8px;background:var(--a-surface2);}
    .adm-user-chip .avatar{width:32px;height:32px;border-radius:50%;
      background:linear-gradient(135deg,var(--a-accent),#ff8a5c);
      display:flex;align-items:center;justify-content:center;
      font-weight:700;font-size:.8rem;color:#fff;flex-shrink:0;}
    .adm-user-chip .name{font-size:.8rem;font-weight:600;color:var(--a-text);
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .adm-user-chip .role{font-size:.7rem;color:var(--a-muted);}
    .adm-main{margin-left:var(--sidebar-w);flex:1;min-height:100vh;display:flex;flex-direction:column;}
    .adm-topbar{height:60px;background:var(--a-surface);border-bottom:1px solid var(--a-border);
      display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;
      position:sticky;top:0;z-index:50;}
    .adm-topbar .page-title{font-family:var(--font-mono);font-size:.9rem;font-weight:700;
      color:var(--a-text);letter-spacing:-.3px;}
    .adm-topbar .breadcrumb-trail{font-size:.78rem;color:var(--a-muted);}
    .adm-topbar .breadcrumb-trail span{color:var(--a-accent);}
    .adm-content{flex:1;padding:1.75rem;overflow-y:auto;}
    .a-card{background:var(--a-surface);border:1px solid var(--a-border);border-radius:12px;overflow:hidden;}
    .a-card-header{padding:1rem 1.25rem;border-bottom:1px solid var(--a-border);
      display:flex;align-items:center;justify-content:space-between;gap:1rem;}
    .a-card-title{font-family:var(--font-mono);font-size:.85rem;font-weight:700;
      color:var(--a-text);letter-spacing:-.2px;}
    .a-card-body{padding:1.25rem;}
    .kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;}
    .kpi-tile{background:var(--a-surface);border:1px solid var(--a-border);border-radius:12px;
      padding:1.25rem;position:relative;overflow:hidden;}
    .kpi-tile::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;
      background:var(--tile-color,var(--a-accent));}
    .kpi-tile .label{font-size:.72rem;font-weight:600;letter-spacing:.8px;text-transform:uppercase;
      color:var(--a-muted);margin-bottom:.5rem;}
    .kpi-tile .value{font-family:var(--font-mono);font-size:1.75rem;font-weight:700;
      color:#fff;line-height:1;margin-bottom:.35rem;}
    .kpi-tile .sub{font-size:.78rem;color:var(--a-muted);}
    .kpi-tile .icon{position:absolute;right:1rem;top:50%;transform:translateY(-50%);
      font-size:2.5rem;opacity:.06;color:var(--tile-color,var(--a-accent));}
    .a-table{width:100%;border-collapse:collapse;}
    .a-table th{padding:.65rem 1rem;font-size:.7rem;font-weight:700;letter-spacing:1px;
      text-transform:uppercase;color:var(--a-muted);border-bottom:1px solid var(--a-border);
      text-align:left;white-space:nowrap;background:var(--a-surface);}
    .a-table td{padding:.85rem 1rem;font-size:.87rem;border-bottom:1px solid var(--a-border);
      color:var(--a-text);vertical-align:middle;}
    .a-table tbody tr:last-child td{border-bottom:none;}
    .a-table tbody tr{transition:background .1s;}
    .a-table tbody tr:hover{background:var(--a-surface2);}
    .a-badge{display:inline-flex;align-items:center;gap:.3rem;padding:.2rem .6rem;
      border-radius:4px;font-size:.72rem;font-weight:700;letter-spacing:.3px;text-transform:uppercase;}
    .a-badge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;}
    .a-badge-success{background:rgba(16,185,129,.12);color:#10b981;}
    .a-badge-warning{background:rgba(245,158,11,.12);color:#f59e0b;}
    .a-badge-danger{background:rgba(239,68,68,.12);color:#ef4444;}
    .a-badge-info{background:rgba(59,130,246,.12);color:#3b82f6;}
    .a-badge-muted{background:rgba(100,116,139,.12);color:#94a3b8;}
    .a-btn{display:inline-flex;align-items:center;gap:.4rem;padding:.45rem 1rem;border-radius:7px;
      font-size:.83rem;font-weight:600;border:none;cursor:pointer;transition:all .15s;text-decoration:none;}
    .a-btn-primary{background:var(--a-accent);color:#fff;}
    .a-btn-primary:hover{background:#e3472b;color:#fff;}
    .a-btn-ghost{background:var(--a-surface2);color:var(--a-text);border:1px solid var(--a-border);}
    .a-btn-ghost:hover{border-color:var(--a-accent);color:var(--a-accent);}
    .a-btn-success{background:rgba(16,185,129,.15);color:#10b981;border:1px solid rgba(16,185,129,.25);}
    .a-btn-success:hover{background:rgba(16,185,129,.25);}
    .a-btn-danger{background:rgba(239,68,68,.12);color:#ef4444;border:1px solid rgba(239,68,68,.2);}
    .a-btn-danger:hover{background:rgba(239,68,68,.22);}
    .a-btn-sm{padding:.3rem .65rem;font-size:.78rem;}
    .a-input,.a-select{background:var(--a-surface2);border:1px solid var(--a-border);
      border-radius:7px;color:var(--a-text);padding:.5rem .85rem;font-size:.87rem;
      font-family:var(--font-body);width:100%;transition:border-color .15s;}
    .a-input:focus,.a-select:focus{outline:none;border-color:var(--a-accent);
      box-shadow:0 0 0 3px rgba(239,81,52,.12);}
    .a-input::placeholder{color:var(--a-muted);}
    .a-select option{background:var(--a-surface);}
    textarea.a-input{resize:vertical;}
    .a-pagination{display:flex;align-items:center;gap:.35rem;}
    .a-page-btn{width:32px;height:32px;display:flex;align-items:center;justify-content:center;
      border-radius:6px;background:var(--a-surface2);border:1px solid var(--a-border);
      color:var(--a-muted);font-size:.83rem;cursor:pointer;transition:all .15s;}
    .a-page-btn:hover{border-color:var(--a-accent);color:var(--a-accent);}
    .a-page-btn.active{background:var(--a-accent);border-color:var(--a-accent);color:#fff;}
    .a-page-btn:disabled{opacity:.35;pointer-events:none;}
    .a-skeleton{background:linear-gradient(90deg,var(--a-surface2) 25%,var(--a-surface) 50%,var(--a-surface2) 75%);
      background-size:200% 100%;animation:shimmer 1.4s infinite;border-radius:6px;}
    @keyframes shimmer{from{background-position:200% 0}to{background-position:-200% 0}}
    #adminToastArea{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;
      display:flex;flex-direction:column;gap:.5rem;}
    .a-toast{display:flex;align-items:center;gap:.75rem;background:var(--a-surface);
      border:1px solid var(--a-border);border-radius:10px;padding:.75rem 1rem;min-width:280px;
      box-shadow:0 8px 32px rgba(0,0,0,.4);animation:toastIn .2s ease;}
    .a-toast.removing{animation:toastOut .2s ease forwards;}
    @keyframes toastIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
    @keyframes toastOut{to{opacity:0;transform:translateX(20px)}}
    .a-toast .t-icon{font-size:1.1rem;flex-shrink:0;}
    .a-toast .t-msg{font-size:.87rem;color:var(--a-text);}
    .a-toast.t-success{border-left:3px solid var(--a-success);}
    .a-toast.t-success .t-icon{color:var(--a-success);}
    .a-toast.t-error{border-left:3px solid var(--a-danger);}
    .a-toast.t-error .t-icon{color:var(--a-danger);}
    .a-toast.t-info{border-left:3px solid var(--a-info);}
    .a-toast.t-info .t-icon{color:var(--a-info);}
    .a-toast.t-warning{border-left:3px solid var(--a-warning);}
    .a-toast.t-warning .t-icon{color:var(--a-warning);}
    .a-modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.65);
      backdrop-filter:blur(3px);z-index:1000;display:none;align-items:center;justify-content:center;}
    .a-modal-backdrop.open{display:flex;}
    .a-modal{background:var(--a-surface);border:1px solid var(--a-border);border-radius:14px;
      padding:1.5rem;width:100%;max-width:480px;box-shadow:0 20px 60px rgba(0,0,0,.5);
      animation:modalIn .2s ease;}
    @keyframes modalIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}
    .a-modal-title{font-family:var(--font-mono);font-size:1rem;font-weight:700;color:#fff;margin-bottom:1rem;}
    .mono{font-family:var(--font-mono);}
    .text-accent{color:var(--a-accent)!important;}
    .adm-menu-toggle{display:none;background:none;border:none;color:var(--a-text);
      font-size:1.25rem;cursor:pointer;padding:.25rem;}
    @media(max-width:900px){
      .adm-sidebar{transform:translateX(-100%);}
      .adm-sidebar.open{transform:none;}
      .adm-main{margin-left:0;}
      .adm-menu-toggle{display:block;}
      .adm-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99;display:none;}
      .adm-overlay.open{display:block;}
    }
    ::-webkit-scrollbar{width:5px;height:5px;}
    ::-webkit-scrollbar-track{background:transparent;}
    ::-webkit-scrollbar-thumb{background:var(--a-border);border-radius:99px;}
  </style>

  <%# ── Admin utilities defined HERE in <head> so they are available to ALL page scripts ── %>
  <script>
  window.Admin = (function () {
      'use strict';

      var CSRF = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';

      // ── Toast ─────────────────────────────────────────────────
      function toast(msg, type) {
          type = type || 'info';
          var area = document.getElementById('adminToastArea');
          if (!area) { console.warn('[Admin] toast area not found'); return; }
          var icons = {
              success: 'bi-check-circle-fill',
              error:   'bi-x-circle-fill',
              info:    'bi-info-circle-fill',
              warning: 'bi-exclamation-triangle-fill'
          };
          var el = document.createElement('div');
          el.className = 'a-toast t-' + type;
          el.innerHTML =
              '<i class="bi ' + (icons[type] || 'bi-bell-fill') + ' t-icon"></i>' +
              '<span class="t-msg">' + escHtml(msg) + '</span>';
          area.appendChild(el);
          setTimeout(function () {
              el.classList.add('removing');
              setTimeout(function () { if (el.parentNode) el.remove(); }, 220);
          }, 4000);
      }

      // ── API fetch helpers ─────────────────────────────────────
      function apiFetch(method, url, body) {
          var opts = {
              method:      method,
              credentials: 'same-origin',
              headers:     { 'X-CSRF-Token': CSRF }
          };
          if (body) {
              opts.headers['Content-Type'] = 'application/json';
              opts.body = JSON.stringify(Object.assign({ _csrf: CSRF }, body));
          }
          return fetch(url, opts).then(function (res) {
              return res.json().catch(function () {
                  return { ok: false, error: 'Invalid JSON response (' + res.status + ')' };
              }).then(function (data) {
                  if (!res.ok || data.ok === false) {
                      throw new Error(data.error || ('HTTP ' + res.status));
                  }
                  return data;
              });
          });
      }

      function get(url)        { return apiFetch('GET',    url); }
      function post(url, body) { return apiFetch('POST',   url, body); }
      function put(url, body)  { return apiFetch('PUT',    url, body); }
      function del(url)        { return apiFetch('DELETE', url); }

      // ── Utilities ─────────────────────────────────────────────
      function escHtml(s) {
          var d = document.createElement('div');
          d.textContent = String(s == null ? '' : s);
          return d.innerHTML;
      }

      function fmtNaira(n) {
          return '\u20a6' + Number(n || 0).toLocaleString('en-NG', {
              minimumFractionDigits: 2, maximumFractionDigits: 2
          });
      }

      function fmtDate(d) {
          if (!d) return '\u2014';
          return new Date(d).toLocaleDateString('en-NG', {
              year: 'numeric', month: 'short', day: 'numeric',
              hour: '2-digit', minute: '2-digit'
          });
      }

      function fmtDateShort(d) {
          if (!d) return '\u2014';
          return new Date(d).toLocaleDateString('en-NG', {
              month: 'short', day: 'numeric', year: 'numeric'
          });
      }

      function badge(status) {
          var map = {
              success: 'a-badge-success', active:      'a-badge-success',
              verified:'a-badge-success', healthy:     'a-badge-success',
              pending: 'a-badge-warning', processing:  'a-badge-warning',
              draft:   'a-badge-muted',   configured:  'a-badge-info',
              failed:  'a-badge-danger',  rejected:    'a-badge-danger',
              inactive:'a-badge-danger',  frozen:      'a-badge-danger',
              missing: 'a-badge-danger',  unhealthy:   'a-badge-danger',
              info:    'a-badge-info'
          };
          var cls = map[(status || '').toLowerCase()] || 'a-badge-muted';
          return '<span class="a-badge ' + cls + '">' + escHtml(status || '\u2014') + '</span>';
      }

      function skeleton(rows, cols) {
          cols = cols || 5;
          var html = '';
          for (var r = 0; r < (rows || 5); r++) {
              html += '<tr>';
              for (var c = 0; c < cols; c++) {
                  var w = [60, 80, 100, 70, 90][c % 5];
                  html += '<td><div class="a-skeleton" style="height:14px;width:' + w + '%;border-radius:4px;"></div></td>';
              }
              html += '</tr>';
          }
          return html;
      }

      function buildPagination(pagination, onPage) {
          if (!pagination || pagination.pages <= 1) return document.createDocumentFragment();
          var p     = pagination.page;
          var total = pagination.pages;

          var div = document.createElement('div');
          div.className = 'a-pagination';

          function btn(label, page, active, disabled) {
              var el = document.createElement('button');
              el.className = 'a-page-btn' + (active ? ' active' : '');
              el.innerHTML = label;
              if (disabled) el.disabled = true;
              else el.dataset.page = page;
              return el;
          }

          div.appendChild(btn('<i class="bi bi-chevron-left"></i>', p - 1, false, p <= 1));

          var pages = [];
          if (total <= 7) {
              for (var i = 1; i <= total; i++) pages.push(i);
          } else {
              pages = [1, 2];
              if (p > 4) pages.push('...');
              for (var j = Math.max(3, p - 1); j <= Math.min(total - 2, p + 1); j++) pages.push(j);
              if (p < total - 3) pages.push('...');
              pages.push(total - 1, total);
          }

          pages.forEach(function (pg) {
              if (pg === '...') {
                  var s = document.createElement('span');
                  s.className = 'a-page-btn';
                  s.style.pointerEvents = 'none';
                  s.textContent = '\u2026';
                  div.appendChild(s);
              } else {
                  div.appendChild(btn(pg, pg, pg === p, false));
              }
          });

          div.appendChild(btn('<i class="bi bi-chevron-right"></i>', p + 1, false, p >= total));

          div.addEventListener('click', function (e) {
              var b = e.target.closest('[data-page]');
              if (b && !b.disabled) onPage(parseInt(b.dataset.page));
          });
          return div;
      }

      return {
          CSRF, toast, get, post, put, del,
          escHtml, fmtNaira, fmtDate, fmtDateShort,
          badge, skeleton, buildPagination
      };
  })();
  </script>
</head>
<body>

<%
var adminUser = typeof user !== 'undefined' ? user : { name: 'Admin', role: 'admin' };
var activePg  = typeof activePage !== 'undefined' ? activePage : '';
var initials  = (adminUser.name || 'A').split(' ').map(function(n){ return n[0]; }).join('').toUpperCase().slice(0,2);
var navItems  = [
  { page:'dashboard',    href:'/admin/dashboard',   icon:'bi-grid-1x2',         label:'Dashboard'   },
  { page:'users',        href:'/admin/users',        icon:'bi-people',           label:'Users'        },
  { page:'transactions', href:'/admin/transactions', icon:'bi-arrow-left-right', label:'Transactions' },
  { page:'kyc',          href:'/admin/kyc',          icon:'bi-shield-check',     label:'KYC Review'   },
  { page:'health',       href:'/admin/health',       icon:'bi-activity',         label:'System Health'},
];
%>

<div class="adm-overlay" id="sidebarOverlay"></div>

<aside class="adm-sidebar" id="sidebar">
  <div class="adm-logo">
    <div class="wordmark">Moz<span>Aic</span></div>
    <div class="pill">Admin Panel</div>
  </div>
  <nav class="adm-nav">
    <div class="adm-nav-label">Menu</div>
    <% navItems.forEach(function(item){ %>
      <a href="<%= item.href %>" class="adm-nav-link<%= activePg === item.page ? ' active' : '' %>">
        <i class="bi <%= item.icon %>"></i><%= item.label %>
      </a>
    <% }); %>
    <div class="adm-nav-label" style="margin-top:.5rem">Account</div>
    <a href="/dashboard/user" class="adm-nav-link">
      <i class="bi bi-arrow-left-circle"></i> Back to App
    </a>
    <form method="POST" action="/auth/logout">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
      <button type="submit" class="adm-nav-link">
        <i class="bi bi-box-arrow-left"></i> Logout
      </button>
    </form>
  </nav>
  <div class="adm-sidebar-footer">
    <div class="adm-user-chip">
      <div class="avatar"><%= initials %></div>
      <div>
        <div class="name"><%= adminUser.name || 'Admin' %></div>
        <div class="role"><%= adminUser.role || 'admin' %></div>
      </div>
    </div>
  </div>
</aside>

<div class="adm-main">
  <header class="adm-topbar">
    <div style="display:flex;align-items:center;gap:.75rem;">
      <button class="adm-menu-toggle" id="menuToggle"><i class="bi bi-list"></i></button>
      <div>
        <div class="page-title"><%= (typeof title !== 'undefined' ? title : 'Dashboard').replace('Admin — ','') %></div>
        <div class="breadcrumb-trail">MozAic / <span>Admin</span></div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:.5rem;">
      <div id="healthDot" style="width:8px;height:8px;border-radius:50%;background:var(--a-muted);flex-shrink:0;"></div>
      <span style="font-size:.78rem;color:var(--a-muted);" id="healthLabel">checking...</span>
    </div>
  </header>

  <main class="adm-content">
