  <!-- Scripts -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
  // Year
  document.addEventListener('DOMContentLoaded', function() {
    const yearElement = document.getElementById('y');
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear();
    }
    
    // Simple counter animation
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const el = e.target;
          const goal = parseFloat(el.dataset.count);
          const isSeconds = el.textContent.trim().endsWith('s');
          let cur = 0;
          const step = goal / 40; // 40 frames
          
          const int = setInterval(() => {
            cur += step;
            if (cur >= goal) {
              cur = goal;
              clearInterval(int);
            }
            
            el.textContent = isSeconds ? Math.round(cur) + 's' : 
              (Number.isInteger(goal) ? Math.round(cur) : cur.toFixed(1));
            
            if (el.nextElementSibling && el.nextElementSibling.textContent.includes('top‑ups') && cur === goal) {
              el.textContent = goal + 'k+';
            }
            if (el.nextElementSibling && el.nextElementSibling.textContent.includes('Uptime') && cur === goal) {
              el.textContent = goal + '%';
            }
          }, 30);
          
          observer.unobserve(el);
        }
      });
    }, { threshold: .6 });
    
    document.querySelectorAll('[data-count]').forEach(el => observer.observe(el));
  });
  </script>

